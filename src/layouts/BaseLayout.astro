---
interface Props {
  title: string
  description?: string
  image?: string
  ogType?: string
  jsonLd?: Record<string, any>
}

const {
  title,
  description = 'Acecore（エースコア）は、システム開発・Webサイト制作・サーバー運用・デザイン・IT教育をワンストップで提供するテクノロジー集団です。',
  image,
  ogType = 'website',
  jsonLd,
} = Astro.props

const pageTitle = title === 'ホーム' ? 'Acecore' : `${title} | Acecore`
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImage = image || new URL('/uploads/og-default.svg', Astro.site).href

const pageNameMap: Record<string, string> = {
  services: 'サービス',
  schools: 'Acecore Schools',
  about: '会社概要',
  contact: 'お問い合わせ',
  blog: 'ブログ',
  acestudio: 'AceStudio',
  privacy: 'プライバシーポリシー',
}
const pathParts = Astro.url.pathname.split('/').filter(Boolean)
const breadcrumbLd = pathParts.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://acecore.net/" },
    ...pathParts.map((part, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": pageNameMap[part] || title,
      "item": `https://acecore.net/${pathParts.slice(0, i + 1).join('/')}/`,
    })),
  ],
} : null

import '@fontsource-variable/noto-sans-jp'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Acecore" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@acecorenet" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <link rel="dns-prefetch" href="https://wsrv.nl" />
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G79SGTMYEX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G79SGTMYEX');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Acecore",
      "url": "https://acecore.net",
      "description": description,
      "sameAs": [
        "https://x.com/acecorenet",
        "https://github.com/acecore-systems",
        "https://asv.acecore.net"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Acecore",
      "url": "https://acecore.net",
    })} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="font-sans text-slate-800 bg-white min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-100 focus:top-2 focus:left-2 focus:rounded focus:bg-brand-500 focus:text-white focus:px-4 focus:py-2 focus:text-sm">本文へスキップ</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      addEventListener('scroll', function loadAds() {
        removeEventListener('scroll', loadAds)
        const s = document.createElement('script')
        s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3935803464310919'
        s.async = true
        s.crossOrigin = 'anonymous'
        document.body.appendChild(s)
      }, { once: true, passive: true })
    </script>
  </body>
</html>
