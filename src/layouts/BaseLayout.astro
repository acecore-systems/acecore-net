---
import { getLocaleFromUrl, t, getAlternateUrls, getLocalizedUrl, type Locale } from '../i18n'
import { defaultLocale, locales, ogLocaleMap, htmlLangMap } from '../i18n'

interface Props {
  title: string
  description?: string
  image?: string
  ogType?: string
  jsonLd?: Record<string, any> | Record<string, any>[]
  publishedTime?: Date
  modifiedTime?: Date
  prevPage?: string
  nextPage?: string
  robots?: string
  tags?: string[]
  author?: string
  preloadImage?: { src: string; srcset?: string; sizes?: string }
  locale?: Locale
}

const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const {
  title,
  description = t(locale, 'meta.defaultDescription'),
  image,
  ogType = 'website',
  jsonLd,
  publishedTime,
  modifiedTime,
  prevPage,
  nextPage,
  robots = 'index, follow',
  tags,
  author,
  preloadImage,
} = Astro.props

const isHome = title === t(locale, 'nav.home')
const enableClientRouter = !isHome
const pageTitle = isHome
  ? t(locale, 'meta.siteTitle')
  : `${title} | Acecore`
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImage = image || new URL('/uploads/og-default.png', Astro.site).href
const isMonetizedPage =
  Astro.url.pathname === '/blog/' || Astro.url.pathname.startsWith('/blog/')

const pageNameMap: Record<string, string> = Object.fromEntries(
  Object.entries({
    services: t(locale, 'pageNames.services'),
    schools: t(locale, 'pageNames.schools'),
    about: t(locale, 'pageNames.about'),
    contact: t(locale, 'pageNames.contact'),
    blog: t(locale, 'pageNames.blog'),
    acestudio: t(locale, 'pageNames.acestudio'),
    privacy: t(locale, 'pageNames.privacy'),
    tags: t(locale, 'pageNames.tags'),
    authors: t(locale, 'pageNames.authors'),
    archive: t(locale, 'pageNames.archive'),
    page: t(locale, 'pageNames.page'),
  }),
)
const knownRoutes = new Set([
  '',
  'services',
  'schools',
  'about',
  'contact',
  'blog',
  'acestudio',
  'privacy',
])
// locale プレフィクスを除外してパスパーツを取得
const rawParts = Astro.url.pathname.split('/').filter(Boolean)
const pathParts = (rawParts[0] && (locales as readonly string[]).includes(rawParts[0]) && rawParts[0] !== defaultLocale)
  ? rawParts.slice(1)
  : rawParts
const siteOrigin = Astro.site?.origin || 'https://acecore.net'
const buildAbsoluteUrl = (path: string) => new URL(path, `${siteOrigin}/`).toString()
const breadcrumbLd =
  pathParts.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: t(locale, 'common.home'),
            item: buildAbsoluteUrl(getLocalizedUrl('/', locale)),
          },
          ...pathParts.map((part, i) => {
            const path = pathParts.slice(0, i + 1).join('/')
            return {
              '@type': 'ListItem',
              position: i + 2,
              name: pageNameMap[part] || decodeURIComponent(part),
              item: buildAbsoluteUrl(`${getLocalizedUrl('/' + path + '/', locale)}/`.replace(/\/+/g, '/')),
            }
          }),
        ],
      }
    : null

const alternateUrls = getAlternateUrls(Astro.url.pathname, siteOrigin)

import { ClientRouter } from 'astro:transitions'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import SearchModal from '../components/SearchModal.astro'
import ScrollToTop from '../components/ScrollToTop.astro'
import AnchorAd from '../components/AnchorAd.astro'
import { SITE } from '../data/site'
---

<!doctype html>
<html lang={htmlLangMap[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content={robots} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {locales.filter(l => l !== locale).map(l => (
      <meta property="og:locale:alternate" content={ogLocaleMap[l]} />
    ))}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Acecore" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@acecorenet" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    {author && <meta name="author" content={author} />}
    {
      publishedTime && (
        <meta
          property="article:published_time"
          content={publishedTime.toISOString()}
        />
      )
    }
    {
      modifiedTime && (
        <meta
          property="article:modified_time"
          content={modifiedTime.toISOString()}
        />
      )
    }
    {tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    {tags?.[0] && <meta property="article:section" content={tags[0]} />}
    {prevPage && <link rel="prev" href={prevPage} />}
    {nextPage && <link rel="next" href={nextPage} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={t(locale, 'blog.rssTitle')}
      href={locale === defaultLocale ? '/rss.xml' : `/${locale}/rss.xml`}
    />
    {alternateUrls.map(({ locale: l, url }) => (
      <link rel="alternate" hreflang={htmlLangMap[l]} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternateUrls.find(a => a.locale === defaultLocale)?.url} />
    <link rel="preconnect" href={SITE.url} />
    {
      preloadImage && (
        <link
          rel="preload"
          as="image"
          href={preloadImage.src}
          imagesrcset={preloadImage.srcset}
          imagesizes={preloadImage.sizes}
          fetchpriority="high"
        />
      )
    }
    {
      isMonetizedPage && (
        <>
          <link
            rel="dns-prefetch"
            href="https://pagead2.googlesyndication.com"
          />
          <link rel="dns-prefetch" href="https://googleads.g.doubleclick.net" />
          <link
            rel="preconnect"
            href="https://pagead2.googlesyndication.com"
            crossorigin="anonymous"
          />
          <link
            rel="preconnect"
            href="https://googleads.g.doubleclick.net"
            crossorigin="anonymous"
          />
        </>
      )
    }
    <!-- Google Analytics (GA4) -->
    <script
      is:inline
      set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.aceTrackEvent = function(name, params) {
        if (!name) return;
        gtag('event', name, params || {});
      };
      gtag('js', new Date());
      gtag('config', '${SITE.ga4Id}');
      (function() {
        var gaLoaded = false;
        function loadGA() {
          if (gaLoaded || document.querySelector('script[src*="gtag/js"]')) return;
          gaLoaded = true;
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=${SITE.ga4Id}';
          s.async = true;
          document.head.appendChild(s);
        }

        function bindInteractionLoad() {
          ['pointerdown', 'keydown', 'touchstart', 'scroll'].forEach(function(eventName) {
            window.addEventListener(eventName, loadGA, { once: true, passive: true });
          });
        }

        bindInteractionLoad();
        setTimeout(loadGA, 4000);
      })();
    `}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Acecore',
        url: 'https://acecore.net',
        description: description,
        logo: 'https://acecore.net/favicon.svg',
        address: {
          '@type': 'PostalAddress',
          addressCountry: 'JP',
        },
        contactPoint: {
          '@type': 'ContactPoint',
          telephone: SITE.phoneIntl,
          email: SITE.email,
          contactType: 'customer service',
          availableLanguage: 'Japanese',
        },
        sameAs: [SITE.social.x, SITE.social.github, SITE.social.aceserver],
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Acecore',
        url: 'https://acecore.net',
        potentialAction: {
          '@type': 'SearchAction',
          target: 'https://acecore.net/blog/?q={search_term_string}',
          'query-input': 'required name=search_term_string',
        },
      })}
    />
    {
      breadcrumbLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbLd)}
        />
      )
    }
    {
      jsonLd &&
        (Array.isArray(jsonLd) ? (
          jsonLd.map((ld) => (
            <script type="application/ld+json" set:html={JSON.stringify(ld)} />
          ))
        ) : (
          <script
            type="application/ld+json"
            set:html={JSON.stringify(jsonLd)}
          />
        ))
    }
    {enableClientRouter && <ClientRouter />}
    <script is:inline>
      (function() {
        if (localStorage.getItem('preferred-locale')) return;
        var path = location.pathname;
        if (path !== '/' && path !== '') return;
        var lang = (navigator.language || '').toLowerCase();
        var map = {
          en:'en',de:'de',fr:'fr',es:'es',pt:'pt',ko:'ko',ru:'ru',
          'zh-cn':'zh-cn','zh-hans':'zh-cn','zh':'zh-cn'
        };
        var detected = map[lang] || map[lang.split('-')[0]];
        if (detected && detected !== 'ja') {
          localStorage.setItem('preferred-locale', detected);
          location.replace('/' + detected + '/');
        }
      })();
    </script>
    <script is:inline>
      (function() {
        if (window.__aceAnalyticsClickTrackingInitialized) return;
        window.__aceAnalyticsClickTrackingInitialized = true;

        function camelToSnake(value) {
          return value.replace(/[A-Z]/g, function (match) {
            return '_' + match.toLowerCase();
          });
        }

        function getLabel(element) {
          return (
            element.dataset.gaLabel ||
            (element.getAttribute('aria-label') || '').trim() ||
            (element.textContent || '').replace(/\s+/g, ' ').trim().slice(0, 120)
          );
        }

        function buildParams(element) {
          var params = {
            page_path: location.pathname,
            page_title: document.title,
          };

          Object.keys(element.dataset).forEach(function (key) {
            if (!key.startsWith('ga') || key === 'gaEvent') return;
            var paramName = camelToSnake(key.slice(2).replace(/^./, function (char) {
              return char.toLowerCase();
            }));
            params[paramName] = element.dataset[key];
          });

          return params;
        }

        document.addEventListener('click', function (event) {
          var target = event.target;
          if (!(target instanceof Element)) return;

          var trackedElement = target.closest('[data-ga-event]');
          if (trackedElement) {
            window.aceTrackEvent(
              trackedElement.dataset.gaEvent,
              buildParams(trackedElement),
            );
            return;
          }

          var anchor = target.closest('a[href]');
          if (!(anchor instanceof HTMLAnchorElement)) return;

          var href = anchor.getAttribute('href') || '';
          if (!href || href.startsWith('#')) return;

          if (anchor.className.indexOf('ac-btn') !== -1) {
            window.aceTrackEvent('cta_click', {
              page_path: location.pathname,
              page_title: document.title,
              label: getLabel(anchor),
              destination: anchor.href,
              location: 'generic_cta',
            });
            return;
          }

          var destination;
          try {
            destination = new URL(anchor.href, location.origin);
          } catch {
            return;
          }

          if (destination.origin !== location.origin) {
            window.aceTrackEvent('external_link_click', {
              page_path: location.pathname,
              page_title: document.title,
              label: getLabel(anchor),
              destination: destination.href,
              location: 'generic_external_link',
            });
          }
        }, true);
      })();
    </script>
  </head>
  <body class="font-sans text-slate-800 bg-white min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-100 focus:top-2 focus:left-2 focus:rounded focus:bg-brand-500 focus:text-white focus:px-4 focus:py-2 focus:text-sm"
      >{t(locale, 'common.skipToContent')}</a
    >
    <Header locale={locale} />
    <main id="main" tabindex="-1" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <ScrollToTop locale={locale} />
    {isMonetizedPage && <AnchorAd />}
    <SearchModal />
    {isMonetizedPage && (
      <script>
        import { initAdsRuntime } from '../scripts/ads'

        initAdsRuntime()
      </script>
    )}
    <script>
      let searchModalModulePromise: Promise<
        typeof import('../scripts/search-modal')
      > | null = null

      function loadSearchModalModule() {
        if (!searchModalModulePromise) {
          searchModalModulePromise = import('../scripts/search-modal')
        }

        return searchModalModulePromise
      }

      async function openSearch(query?: string) {
        const module = await loadSearchModalModule()
        await module.openSearch(query)
      }

      function initSearchBootstrap() {
        ;(window as any).openSearch = openSearch

        const queryParam = new URLSearchParams(window.location.search).get('q')
        if (queryParam) {
          void openSearch(queryParam)
        }
      }

      function bindSearchShortcuts() {
        if ((window as any).__aceSearchShortcutsBound) return

        ;(window as any).__aceSearchShortcutsBound = true
        document.addEventListener('keydown', (event) => {
          if ((event.ctrlKey || event.metaKey) && event.key === 'k') {
            event.preventDefault()
            void openSearch()
            return
          }

          const dialog = document.getElementById(
            'search-dialog',
          ) as HTMLDialogElement | null
          if (event.key === 'Escape' && dialog?.open) {
            dialog.close()
          }
        })
      }

      bindSearchShortcuts()
      initSearchBootstrap()
      document.addEventListener('astro:after-swap', initSearchBootstrap)
    </script>
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        var main = document.getElementById('main')
        if (main) main.focus({ preventScroll: true })
      })
    </script>
  </body>
</html>
<style is:global>
  .prose a.external-link::after {
    content: ' ↗';
    font-size: 0.75em;
    opacity: 0.5;
  }
</style>
