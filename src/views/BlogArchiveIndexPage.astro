---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { getCollection } from 'astro:content'
import { t, getLocalizedUrl, getDateParts, type Locale } from '../i18n'
import { isBasePost } from '../utils/blog-i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const breadcrumbItems = [
  { label: t(locale, 'blog.title'), href: u('/blog/') },
  { label: t(locale, 'blog.archive'), href: u('/blog/archive/') },
]

const allPosts = (await getCollection('blog')).filter(isBasePost)
const archiveMap = new Map<
  string,
  { count: number; year: number; month: number }
>()

for (const post of allPosts) {
  const { year, month } = getDateParts(post.data.date)
  const key = `${year}-${String(month).padStart(2, '0')}`
  const entry = archiveMap.get(key)
  if (entry) {
    entry.count += 1
  } else {
    archiveMap.set(key, { count: 1, year, month })
  }
}

const archives = [...archiveMap.entries()].sort((a, b) =>
  b[0].localeCompare(a[0]),
)

const archiveIndexLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t(locale, 'blog.archive'),
  description: t(locale, 'blog.archiveListDescription'),
  url: `https://acecore.net${u('/blog/archive/')}`,
  hasPart: archives.map(([key]) => ({
    '@type': 'CollectionPage',
    url: `https://acecore.net${u(`/blog/archive/${key}/`)}`,
  })),
}
---

<BaseLayout
  title={t(locale, 'blog.archive')}
  description={t(locale, 'blog.archiveListDescription')}
  robots="noindex, follow"
  jsonLd={archiveIndexLd}
  locale={locale}
  breadcrumbItems={breadcrumbItems.map((item) => ({
    name: item.label,
    item: item.href,
  }))}
>
  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      <Breadcrumb items={breadcrumbItems} locale={locale} />
      <h1 class="mb-4 break-words text-2xl ac-heading sm:text-3xl">
        {t(locale, 'blog.archive')}
      </h1>
      <p class="mb-8 max-w-2xl leading-relaxed text-slate-600">
        {t(locale, 'blog.archiveListDescription')}
      </p>
      <ul class="m-0 grid list-none gap-4 p-0 sm:grid-cols-2" role="list">
        {
          archives.map(([key, { count, year, month }]) => (
            <li>
              <a
                href={u(`/blog/archive/${key}/`)}
                class="ac-card flex min-h-16 items-center justify-between gap-4 p-5 no-underline transition-colors hover:border-brand-300 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
              >
                <span class="font-600 text-slate-800">
                  {t(locale, 'blog.yearMonth', {
                    year: String(year),
                    month: String(month),
                  })}
                </span>
                <span class="inline-flex min-h-9 items-center rounded-lg bg-brand-50 px-3 text-sm font-700 text-brand-600">
                  {t(locale, 'blog.postsCount', { count })}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <div class="mt-10 text-center">
        <a href={u('/blog/')} class="ac-btn-outline"
          >{t(locale, 'blog.backToBlog')}</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
