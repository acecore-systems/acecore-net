---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import Icon from '../components/Icon.astro'
import { SITE } from '../data/site'
import { t, getLocalizedUrl, type Locale } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)

const thanksCopy: Record<
  string,
  {
    title: string
    description: string
    eyebrow: string
    heading: string
    lead: string
    responseTitle: string
    responseBody: string
    mailTitle: string
    mailBody: string
    lineTitle: string
    lineBody: string
    contactAgain: string
    lineCta: string
    servicesCta: string
    homeCta: string
  }
> = {
  ja: {
    title: 'お問い合わせを受け付けました',
    description:
      'Acecoreへのお問い合わせ送信後に、受付状況と次の確認事項を案内するページです。',
    eyebrow: '送信完了',
    heading: 'お問い合わせありがとうございます',
    lead: '内容を確認し、通常1〜2営業日以内に返信します。',
    responseTitle: '返信について',
    responseBody:
      '入力いただいたメールアドレス宛に確認メールを送信しています。届かない場合は迷惑メールフォルダもご確認ください。',
    mailTitle: '補足がある場合',
    mailBody:
      '送信後に補足したい内容がある場合は、同じ内容が分かるようにフォームから再送してください。',
    lineTitle: '短い確認はLINEでも可能です',
    lineBody: '教室関連の連絡や短い相談は、公式LINEからも受け付けています。',
    contactAgain: '追加で送る',
    lineCta: '公式LINEを開く',
    servicesCta: 'サービスを見る',
    homeCta: 'ホームへ戻る',
  },
  en: {
    title: 'Inquiry Sent',
    description: 'Confirmation page after sending an inquiry to Acecore.',
    eyebrow: 'Sent',
    heading: 'Thank you for contacting Acecore',
    lead: 'We will review your message and usually reply within 1-2 business days.',
    responseTitle: 'About the reply',
    responseBody:
      'A confirmation email has been sent to the address you entered. If it does not arrive, please check your spam folder.',
    mailTitle: 'If you need to add details',
    mailBody:
      'Please send the form again with enough context so we can match it to your original inquiry.',
    lineTitle: 'Short follow-ups can use LINE',
    lineBody:
      'School-related messages and short consultations are also accepted through the official LINE account.',
    contactAgain: 'Send another message',
    lineCta: 'Open official LINE',
    servicesCta: 'View services',
    homeCta: 'Back to home',
  },
}

const copy = thanksCopy[locale] ?? thanksCopy.en
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  robots="noindex, nofollow"
  locale={locale}
  languageSwitcherPath="/contact/thanks/"
>
  <section class="ac-section">
    <div class="ac-container max-w-3xl">
      <Breadcrumb
        items={[
          { label: t(locale, 'pages.contact.title'), href: u('/contact/') },
          { label: copy.title },
        ]}
        locale={locale}
      />

      <div
        class="rounded-lg border border-emerald-100 bg-emerald-50 p-6 sm:p-8"
      >
        <div class="flex items-start gap-4">
          <span
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white text-emerald-600 shadow-sm"
          >
            <Icon name="circle-check" class="text-2xl" />
          </span>
          <div>
            <p class="ac-eyebrow mb-2 text-emerald-700">{copy.eyebrow}</p>
            <h1 class="text-2xl ac-heading sm:text-3xl">{copy.heading}</h1>
            <p class="mt-3 text-slate-700">{copy.lead}</p>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <section class="ac-card p-5">
          <Icon name="mail-check" class="mb-3 text-xl text-brand-500" />
          <h2 class="font-600 text-slate-900">{copy.responseTitle}</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            {copy.responseBody}
          </p>
        </section>
        <section class="ac-card p-5">
          <Icon name="file-plus-2" class="mb-3 text-xl text-brand-500" />
          <h2 class="font-600 text-slate-900">{copy.mailTitle}</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            {copy.mailBody}
          </p>
        </section>
        <section class="ac-card p-5">
          <Icon name="message-circle" class="mb-3 text-xl text-brand-500" />
          <h2 class="font-600 text-slate-900">{copy.lineTitle}</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            {copy.lineBody}
          </p>
        </section>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a href={u('/contact/')} class="ac-btn-outline">{copy.contactAgain}</a>
        <a
          href={SITE.line}
          target="_blank"
          rel="noopener noreferrer"
          class="ac-btn-secondary"
        >
          {copy.lineCta}<span class="sr-only"
            >{t(locale, 'common.opensInNewTab')}</span
          >
        </a>
        <a href={u('/services/')} class="ac-btn-outline">{copy.servicesCta}</a>
        <a href={u('/')} class="ac-btn-outline">{copy.homeCta}</a>
      </div>
    </div>
  </section>
</BaseLayout>
