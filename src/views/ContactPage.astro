---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import Faq from '../components/Faq.astro'
import Icon from '../components/Icon.astro'
import { optimizeImage } from '../utils/image'
import { SITE } from '../data/site'
import { t, getLocalizedUrl, type Locale } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const contactThanksUrl = u('/contact/thanks/')

const faqItems = [
  {
    question: t(locale, 'pages.contact.faqQ1'),
    answer: t(locale, 'pages.contact.faqA1'),
  },
  {
    question: t(locale, 'pages.contact.faqQ2'),
    answer: t(locale, 'pages.contact.faqA2'),
  },
  {
    question: t(locale, 'pages.contact.faqQ3'),
    answer: t(locale, 'pages.contact.faqA3'),
  },
  {
    question: t(locale, 'pages.contact.faqQ4'),
    answer: t(locale, 'pages.contact.faqA4'),
  },
]

const contactPageLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `${t(locale, 'pages.contact.title')} | Acecore`,
  description: t(locale, 'pages.contact.description'),
  url: 'https://acecore.net/contact/',
  mainEntity: {
    '@type': 'Organization',
    name: 'Acecore',
    telephone: SITE.phoneIntl,
    email: SITE.email,
  },
}

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}
---

<BaseLayout
  title={t(locale, 'pages.contact.title')}
  description={t(locale, 'pages.contact.description')}
  jsonLd={[contactPageLd, faqLd]}
  locale={locale}
>
  <Hero
    title={t(locale, 'pages.contact.heroTitle')}
    subtitle={t(locale, 'pages.contact.heroSubtitle')}
    images={[
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: t(locale, 'pages.contact.heroImgAlt'),
      },
    ]}
  />

  <section class="ac-section">
    <div class="ac-container max-w-2xl">
      <Breadcrumb
        items={[{ label: t(locale, 'pages.contact.title') }]}
        locale={locale}
      />
      <div id="contact-faq" class="mb-10 scroll-mt-24">
        <Faq title={t(locale, 'pages.contact.faqTitle')} items={faqItems} />
        <div class="mt-4 flex flex-wrap gap-2">
          <a href={u('/services/')} class="ac-chip">
            {t(locale, 'pageNames.services')}
          </a>
          <a href={u('/schools/')} class="ac-chip">
            {t(locale, 'pageNames.schools')}
          </a>
          <a href={u('/blog/')} class="ac-chip">
            {t(locale, 'pageNames.blog')}
          </a>
          <a href={u('/privacy/')} class="ac-chip">
            {t(locale, 'pageNames.privacy')}
          </a>
        </div>
      </div>

      <section
        class="mb-10 rounded-lg border border-brand-100 bg-brand-50 p-5"
        aria-labelledby="ai-contact-heading"
      >
        <div
          class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
        >
          <div class="flex items-start gap-3">
            <span class="ac-icon-box shrink-0">
              <Icon name="sparkles" class="text-lg" />
            </span>
            <div>
              <h2 id="ai-contact-heading" class="text-lg ac-heading">
                {t(locale, 'pages.contact.aiHeading')}
              </h2>
              <p class="mt-1 text-sm leading-relaxed text-slate-600">
                {t(locale, 'pages.contact.aiLead')}
              </p>
            </div>
          </div>
          <button
            type="button"
            class="ac-btn-primary shrink-0"
            data-ace-chat-open
            data-ga-event="ai_chat_open_click"
            data-ga-label="contact_ai_chat"
            data-ga-location="contact_ai_assist"
          >
            <Icon name="bot-message-square" class="text-base" />
            {t(locale, 'pages.contact.aiSubmit')}
          </button>
        </div>
      </section>

      <div
        class="mb-10 flex flex-col gap-4 rounded-lg border border-brand-100 bg-white p-5 sm:flex-row sm:items-center sm:justify-between"
      >
        <div class="flex items-start gap-3">
          <span class="ac-icon-box shrink-0">
            <Icon name="message-circle" class="text-lg" />
          </span>
          <div>
            <h2 class="text-lg ac-heading">
              {t(locale, 'pages.contact.lineHeading')}
            </h2>
            <p class="mt-1 text-sm leading-relaxed text-slate-600">
              {t(locale, 'pages.contact.lineLead')}
            </p>
          </div>
        </div>
        <a
          href={SITE.line}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="contact_line_click"
          data-ga-label="contact_line_follow"
          data-ga-location="contact_line_assist"
          data-ga-destination={SITE.line}
          class="ac-btn-secondary shrink-0"
        >
          <Icon name="message-circle" class="text-base" />
          {t(locale, 'pages.contact.lineCta')}<span class="sr-only"
            >{t(locale, 'common.opensInNewTab')}</span
          >
        </a>
      </div>

      <div class="ac-surface mb-6 bg-brand-50 p-5">
        <div
          class="flex flex-col items-start gap-4 text-sm text-slate-700 sm:flex-row sm:items-center"
        >
          <div class="flex items-center gap-2">
            <Icon name="clock" class="text-brand-500 shrink-0" />
            <span>{t(locale, 'pages.contact.responseTime')}</span>
          </div>
          <div class="flex items-center gap-2">
            <Icon name="badge-check" class="text-brand-500 shrink-0" />
            <span>{t(locale, 'pages.contact.freeEstimate')}</span>
          </div>
        </div>
      </div>

      <form
        id="contact-form"
        action="/api/contact"
        method="post"
        class="space-y-6"
        data-t-sending={t(locale, 'pages.contact.formSending')}
        data-t-error={t(locale, 'pages.contact.formError')}
        data-t-validation-category={t(
          locale,
          'pages.contact.validationCategory',
        )}
        data-t-validation-name={t(locale, 'pages.contact.validationName')}
        data-t-validation-email={t(locale, 'pages.contact.validationEmail')}
        data-t-validation-message={t(locale, 'pages.contact.validationMessage')}
        data-success-url={contactThanksUrl}
      >
        <input type="hidden" name="_redirect" value={u('/contact/')} />
        <input
          type="hidden"
          name="_success_redirect"
          value={contactThanksUrl}
        />
        <input type="hidden" name="_error_redirect" value={u('/contact/')} />
        <input type="hidden" name="locale" value={locale} />
        <div>
          <label
            for="category"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            {t(locale, 'pages.contact.formCategoryLabel')}
            <span class="text-red-500" aria-hidden="true">*</span><span
              class="sr-only">{t(locale, 'common.required')}</span
            >
          </label>
          <select
            id="category"
            name="お問い合わせ種別"
            required
            class="ac-input"
          >
            <option value="" disabled selected
              >{t(locale, 'pages.contact.formCategoryPlaceholder')}</option
            >
            <option value="サービスについて"
              >{t(locale, 'pages.contact.formCategoryService')}</option
            >
            <option value="お見積り依頼"
              >{t(locale, 'pages.contact.formCategoryEstimate')}</option
            >
            <option value="パートナーシップ"
              >{t(locale, 'pages.contact.formCategoryPartnership')}</option
            >
            <option value="採用について"
              >{t(locale, 'pages.contact.formCategoryRecruit')}</option
            >
            <option value="その他"
              >{t(locale, 'pages.contact.formCategoryOther')}</option
            >
          </select>
          <p
            class="text-xs text-red-600 mt-1 hidden"
            id="category-error"
            role="alert"
          >
          </p>
        </div>
        <div>
          <label for="name" class="block text-sm font-600 text-slate-700 mb-2">
            {t(locale, 'pages.contact.formNameLabel')}
            <span class="text-red-500" aria-hidden="true">*</span><span
              class="sr-only">{t(locale, 'common.required')}</span
            >
          </label>
          <input
            type="text"
            id="name"
            name="お名前"
            required
            autocomplete="name"
            class="ac-input"
          />
          <p
            class="text-xs text-red-600 mt-1 hidden"
            id="name-error"
            role="alert"
          >
          </p>
        </div>
        <div>
          <label for="email" class="block text-sm font-600 text-slate-700 mb-2">
            {t(locale, 'pages.contact.formEmailLabel')}
            <span class="text-red-500" aria-hidden="true">*</span><span
              class="sr-only">{t(locale, 'common.required')}</span
            >
          </label>
          <input
            type="email"
            id="email"
            name="メールアドレス"
            required
            autocomplete="email"
            class="ac-input"
          />
          <p
            class="text-xs text-red-600 mt-1 hidden"
            id="email-error"
            role="alert"
          >
          </p>
        </div>
        <div>
          <label
            for="subject"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            {t(locale, 'pages.contact.formSubjectLabel')}
          </label>
          <input type="text" id="subject" name="件名" class="ac-input" />
        </div>
        <div>
          <label
            for="message"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            {t(locale, 'pages.contact.formMessageLabel')}
            <span class="text-red-500" aria-hidden="true">*</span><span
              class="sr-only">{t(locale, 'common.required')}</span
            >
          </label>
          <textarea
            id="message"
            name="お問い合わせ内容"
            rows="6"
            required
            class="ac-input resize-y"></textarea>
          <p
            class="text-xs text-red-600 mt-1 hidden"
            id="message-error"
            role="alert"
          >
          </p>
        </div>
        <div
          id="turnstile-widget"
          class="cf-turnstile"
          data-sitekey={SITE.turnstileSiteKey}
          data-language={locale}
          data-theme="light"
        >
        </div>
        <div>
          <button
            type="submit"
            id="contact-submit"
            class="ac-btn-primary w-full sm:w-auto disabled:opacity-50 disabled:cursor-not-allowed"
          >
            {t(locale, 'pages.contact.formSubmit')}
          </button>
          <p class="text-xs text-slate-600 mt-3">
            {t(locale, 'pages.contact.formSubmitNote')}
            <a href="#contact-faq" class="ac-link ml-1"
              >{t(locale, 'pages.contact.faqTitle')}</a
            >
          </p>
        </div>
        <div
          id="form-feedback"
          class="hidden rounded-lg p-4 text-sm"
          role="alert"
          aria-live="polite"
        >
        </div>
      </form>
    </div>
  </section>

  <section class="bg-slate-50 py-14 sm:py-16">
    <div class="ac-container max-w-2xl">
      <h2 class="text-center text-xl ac-heading">
        {t(locale, 'pages.contact.otherMethodsHeading')}
      </h2>
      <p class="mx-auto mt-2 mb-8 max-w-xl text-center text-sm text-slate-600">
        {t(locale, 'pages.contact.directMethodsNote')}
      </p>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a
          href={SITE.line}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="contact_line_click"
          data-ga-label="contact_card_line"
          data-ga-location="contact_methods"
          data-ga-destination={SITE.line}
          class="ac-card p-6 text-center no-underline transition-all hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md"
        >
          <span class="ac-icon-box mx-auto mb-3">
            <Icon name="message-circle" class="text-xl" />
          </span>
          <h3 class="font-600 text-slate-900 mb-1">LINE</h3>
          <p class="text-sm text-slate-600">
            {t(locale, 'pages.contact.methodLineDesc')}
          </p>
          <span class="sr-only">{t(locale, 'common.opensInNewTab')}</span>
        </a>
        <a
          href={SITE.social.x}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="contact_x_click"
          data-ga-label="contact_card_x"
          data-ga-location="contact_methods"
          data-ga-destination={SITE.social.x}
          class="ac-card p-6 text-center no-underline transition-all hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md"
        >
          <span class="ac-icon-box mx-auto mb-3">
            <Icon name="at-sign" class="text-xl" />
          </span>
          <h3 class="font-600 text-slate-900 mb-1">X</h3>
          <p class="text-sm text-slate-600">
            {t(locale, 'pages.contact.methodXDesc')}
          </p>
          <span class="sr-only">{t(locale, 'common.opensInNewTab')}</span>
        </a>
        <div class="ac-card p-6 text-center">
          <span class="ac-icon-box mx-auto mb-3">
            <Icon name="mail" class="text-xl" />
          </span>
          <h3 class="font-600 text-slate-900 mb-1">
            {t(locale, 'pages.contact.methodEmail')}
          </h3>
          <p class="text-sm text-slate-600">
            <a
              href={`mailto:${SITE.email}`}
              data-ga-event="contact_email_click"
              data-ga-label="contact_card_email"
              data-ga-location="contact_methods"
              data-ga-destination={`mailto:${SITE.email}`}
              class="text-brand-500 hover:underline">{SITE.email}</a
            >
          </p>
        </div>
        <div class="ac-card p-6 text-center">
          <span class="ac-icon-box mx-auto mb-3">
            <Icon name="phone" class="text-xl" />
          </span>
          <h3 class="font-600 text-slate-900 mb-1">
            {t(locale, 'pages.contact.methodPhone')}
          </h3>
          <p class="text-sm text-slate-600 font-600">
            <a
              href={`tel:${SITE.phone.replace(/-/g, '')}`}
              data-ga-event="contact_phone_click"
              data-ga-label="contact_card_phone"
              data-ga-location="contact_methods"
              data-ga-destination={`tel:${SITE.phone.replace(/-/g, '')}`}
              class="text-brand-500 hover:underline">{SITE.phone}</a
            >
          </p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function initContactTurnstile() {
      const turnstileEl = document.getElementById('turnstile-widget')
      if (!turnstileEl) return

      if (turnstileEl.dataset.widgetId) return

      const sitekey = turnstileEl.dataset.sitekey
      const language = turnstileEl.dataset.language
      const theme = turnstileEl.dataset.theme || 'light'

      if (!sitekey) return

      function renderTurnstile() {
        if (
          typeof window.turnstile === 'undefined' ||
          turnstileEl.dataset.widgetId
        ) {
          return
        }

        const widgetId = window.turnstile.render(turnstileEl, {
          sitekey,
          language,
          theme,
        })
        turnstileEl.dataset.widgetId = String(widgetId)
      }

      if (typeof window.turnstile !== 'undefined') {
        renderTurnstile()
        return
      }

      const existingScript = document.querySelector(
        'script[data-ace-turnstile-script]',
      )

      if (existingScript) {
        let attempts = 0
        const waitForTurnstile = function () {
          if (typeof window.turnstile !== 'undefined') {
            renderTurnstile()
            return
          }
          if (attempts >= 50) return
          attempts += 1
          window.setTimeout(waitForTurnstile, 100)
        }
        waitForTurnstile()
        return
      }

      const script = document.createElement('script')
      script.dataset.aceTurnstileScript = 'true'
      script.src =
        'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit'
      script.async = true
      script.addEventListener('load', renderTurnstile, { once: true })
      document.head.appendChild(script)
    }

    document.addEventListener('astro:page-load', initContactTurnstile)
    initContactTurnstile()
  </script>
  <script is:inline>
    {
      const contactForm = document.getElementById('contact-form')
      const vCat = contactForm?.getAttribute('data-t-validation-category') || ''
      const vName = contactForm?.getAttribute('data-t-validation-name') || ''
      const vEmail = contactForm?.getAttribute('data-t-validation-email') || ''
      const vMsg = contactForm?.getAttribute('data-t-validation-message') || ''
      const rules = {
        category: function (v) {
          return v ? '' : vCat
        },
        name: function (v) {
          return v.trim() ? '' : vName
        },
        email: function (v) {
          return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? '' : vEmail
        },
        message: function (v) {
          return v.trim() ? '' : vMsg
        },
      }
      function showError(id, msg) {
        const el = document.getElementById(id + '-error')
        const input = document.getElementById(id)
        if (!el || !input) return
        if (msg) {
          el.textContent = msg
          el.classList.remove('hidden')
          input.classList.add('border-red-400')
          input.setAttribute('aria-invalid', 'true')
          input.setAttribute('aria-describedby', id + '-error')
        } else {
          el.textContent = ''
          el.classList.add('hidden')
          input.classList.remove('border-red-400')
          input.removeAttribute('aria-invalid')
          input.removeAttribute('aria-describedby')
        }
      }
      Object.keys(rules).forEach(function (id) {
        var el = document.getElementById(id)
        if (el) {
          el.addEventListener('blur', function () {
            showError(id, rules[id](el.value))
          })
          el.addEventListener('input', function () {
            if (el.getAttribute('aria-invalid'))
              showError(id, rules[id](el.value))
          })
        }
      })
    }
  </script>
  <script is:inline>
    {
      const form = document.getElementById('contact-form')
      if (form) {
        const feedback = document.getElementById('form-feedback')
        const errorText = form.getAttribute('data-t-error') || 'Failed to send.'
        const successUrl =
          form.getAttribute('data-success-url') || '/contact/thanks/'

        function showFeedback(type, text) {
          if (!feedback) return
          feedback.textContent = text
          feedback.className =
            type === 'success'
              ? 'rounded-lg p-4 text-sm bg-emerald-50 text-emerald-800 border border-emerald-200'
              : 'rounded-lg p-4 text-sm bg-red-50 text-red-800 border border-red-200'
        }

        function resetTurnstile() {
          const turnstileEl = document.getElementById('turnstile-widget')
          const widgetId = turnstileEl?.dataset.widgetId
          if (typeof turnstile !== 'undefined' && widgetId) {
            turnstile.reset(widgetId)
          }
        }

        const currentUrl = new URL(window.location.href)
        const contactState = currentUrl.searchParams.get('contact')
        if (contactState === 'sent') {
          window.location.replace(successUrl)
        } else if (contactState === 'error') {
          showFeedback('error', errorText)
          currentUrl.searchParams.delete('contact')
          window.history.replaceState({}, '', currentUrl)
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault()
          const formData = new FormData(form)
          const btn = document.getElementById('contact-submit')
          if (!btn || !feedback) return
          const sendingText = form.getAttribute('data-t-sending') || 'Sending…'
          const originalText = btn.textContent
          btn.disabled = true
          btn.textContent = sendingText
          feedback.className = 'hidden rounded-lg p-4 text-sm'
          fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
              Accept: 'application/json',
            },
          })
            .then(async function (res) {
              const payload = await res.json().catch(function () {
                return null
              })
              if (!res.ok || (payload && payload.ok === false)) {
                throw new Error('Failed')
              }
              if (window.aceTrackEvent) {
                window.aceTrackEvent('generate_lead', {
                  page_path: window.location.pathname,
                  page_title: document.title,
                  location: 'contact_form',
                  contact_category: String(
                    formData.get('お問い合わせ種別') || '',
                  ),
                })
              }
              window.location.assign(successUrl)
            })
            .catch(function () {
              showFeedback('error', errorText)
              resetTurnstile()
            })
            .finally(function () {
              btn.disabled = false
              btn.textContent = originalText
            })
        })
      }
    }
  </script>
</BaseLayout>
