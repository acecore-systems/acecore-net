---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import BlogPostCard from '../components/BlogPostCard.astro'
import BlogSidebar from '../components/BlogSidebar.astro'
import { getCollection } from 'astro:content'
import { optimizeImage } from '../utils/image'
import AdUnit from '../components/AdUnit.astro'
import { POSTS_PER_PAGE, buildPageNumbers } from '../utils/pagination'
import { t, getLocalizedUrl, getYearMonthKey, type Locale } from '../i18n'
import { isBasePost, localizePost } from '../utils/blog-i18n'
import { getAllTags, getLocalizedTagName } from '../utils/tags'

import type { CollectionEntry } from 'astro:content'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)

const allRawPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const allPosts = allRawPosts.filter(isBasePost)
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE)
const posts = allPosts.slice(0, POSTS_PER_PAGE)
const tagsData = await getAllTags()
const tagCounts = new Map<string, number>()
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)
  }
}
const sortedTags = [...tagCounts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
)
const uniqueTagCount = sortedTags.length
const archiveCount = new Set(
  allPosts.map((post) => getYearMonthKey(post.data.date)),
).size

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: t(locale, 'blog.itemListName'),
  itemListElement: posts.map((post: CollectionEntry<'blog'>, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://acecore.net${u(`/blog/${post.id}/`)}`,
  })),
}

const pageNumbers = buildPageNumbers(1, totalPages)
---

<BaseLayout
  title={t(locale, 'blog.title')}
  description={t(locale, 'blog.indexDescription')}
  jsonLd={itemListLd}
  nextPage={totalPages > 1 ? u('/blog/page/2/') : undefined}
  locale={locale}
>
  <Hero
    title={t(locale, 'blog.title')}
    subtitle={t(locale, 'blog.subtitle')}
    images={[
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: t(locale, 'blog.heroAlt'),
      },
    ]}
  />

  <section class="ac-section">
    <div class="ac-container">
      <Breadcrumb
        items={[{ label: t(locale, 'blog.title') }]}
        locale={locale}
      />
      <div class="mb-10 grid gap-4 sm:grid-cols-2">
        <a
          href={u('/blog/tags/')}
          class="ac-card p-6 no-underline transition-colors hover:border-brand-300 hover:bg-brand-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
        >
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="mb-1 text-sm font-700 text-slate-900">
                {t(locale, 'blog.tagList')}
              </p>
              <p class="text-sm leading-relaxed text-slate-600">
                {t(locale, 'blog.tagListDescription')}
              </p>
            </div>
            <span
              class="inline-flex h-11 min-w-11 items-center justify-center rounded-lg bg-brand-50 px-3 text-xl font-700 text-brand-600"
              >{uniqueTagCount}</span
            >
          </div>
        </a>
        <a
          href={u('/blog/archive/')}
          class="ac-card p-6 no-underline transition-colors hover:border-brand-300 hover:bg-brand-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
        >
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="mb-1 text-sm font-700 text-slate-900">
                {t(locale, 'blog.archive')}
              </p>
              <p class="text-sm leading-relaxed text-slate-600">
                {t(locale, 'blog.archiveListDescription')}
              </p>
            </div>
            <span
              class="inline-flex h-11 min-w-11 items-center justify-center rounded-lg bg-brand-50 px-3 text-xl font-700 text-brand-600"
              >{archiveCount}</span
            >
          </div>
        </a>
      </div>
      {
        sortedTags.length > 0 && (
          <nav class="mb-10" aria-label={t(locale, 'blog.filtersLabel')}>
            <p class="mb-3 text-sm font-700 text-slate-900">
              {t(locale, 'blog.filtersLabel')}
            </p>
            <div class="flex flex-wrap gap-2">
              {sortedTags.slice(0, 12).map(([tag, count]) => (
                <a
                  href={u(`/blog/tags/${tag}/`)}
                  class="ac-chip gap-2 border-brand-100 bg-brand-50 text-brand-600"
                >
                  <span>{getLocalizedTagName(tagsData, tag, locale)}</span>
                  <span class="rounded-md bg-white px-2 py-0.5 text-[0.68rem] font-700 text-brand-500">
                    {count}
                  </span>
                </a>
              ))}
              <a href={u('/blog/tags/')} class="ac-chip">
                {t(locale, 'blog.tagList')}
              </a>
            </div>
          </nav>
        )
      }
      <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_280px] lg:gap-10">
        <div>
          {
            posts.length === 0 ? (
              <p class="text-center text-slate-500">
                {t(locale, 'blog.noPosts')}
              </p>
            ) : (
              <div class="space-y-6">
                {posts.map((post, i: number) => (
                  <Fragment>
                    {i > 0 && i % 3 === 0 && (
                      <AdUnit containerClass="ac-card overflow-hidden p-3" />
                    )}
                    <BlogPostCard
                      post={localizePost(post, allRawPosts, locale)}
                      locale={locale}
                    />
                  </Fragment>
                ))}
              </div>
            )
          }

          {
            totalPages > 1 && (
              <nav
                class="mt-10 flex flex-wrap items-center justify-center gap-2"
                aria-label={t(locale, 'blog.pageNav')}
              >
                <span
                  class="inline-flex min-h-11 items-center px-3 text-sm text-slate-300"
                  aria-disabled="true"
                >
                  {t(locale, 'blog.prev')}
                </span>
                {pageNumbers.map((p) =>
                  p === '...' ? (
                    <span class="px-2 text-slate-400">…</span>
                  ) : p === 1 ? (
                    <span
                      class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg bg-brand-500 px-4 text-sm font-700 text-white"
                      aria-current="page"
                    >
                      {p}
                    </span>
                  ) : (
                    <a
                      href={u(`/blog/page/${p}/`)}
                      class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg border border-slate-300 px-4 text-sm font-700 text-slate-600 transition-colors hover:border-brand-300 hover:bg-brand-50 hover:text-brand-600"
                    >
                      {p}
                    </a>
                  ),
                )}
                {totalPages > 1 && (
                  <a
                    href={u('/blog/page/2/')}
                    class="inline-flex min-h-11 items-center rounded-lg px-3 text-sm font-700 text-slate-600 transition-colors hover:bg-slate-50 hover:text-brand-600"
                  >
                    {t(locale, 'blog.next')}
                  </a>
                )}
              </nav>
            )
          }

          <div class="ac-surface mt-12 bg-brand-50 p-6 text-center sm:p-8">
            <p class="mb-2 text-lg font-700 text-slate-800">
              {t(locale, 'blog.blogCtaHeading')}
            </p>
            <p class="mb-5 text-sm leading-relaxed text-slate-600">
              {t(locale, 'blog.blogCtaBody')}
            </p>
            <div
              class="flex flex-col items-center justify-center gap-3 sm:flex-row"
            >
              <a href={u('/services/')} class="ac-btn-primary"
                >{t(locale, 'blog.blogCtaServices')}</a
              >
              <a href={u('/contact/')} class="ac-btn-outline"
                >{t(locale, 'blog.blogCtaContact')}</a
              >
            </div>
          </div>
        </div>
        <BlogSidebar allPosts={allPosts} locale={locale} />
      </div>
    </div>
  </section>
</BaseLayout>
