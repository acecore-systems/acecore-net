  <script>
    function initServicesSpy() {
      const nav = document.querySelector<HTMLElement>(
        'section.ac-section nav.mb-12',
      )
      if (!nav) return
      const links = [...nav.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')]
      const ids = links.map((a) => a.getAttribute('href')!.slice(1))
      const sections = ids
        .map((id) => document.getElementById(id))
        .filter(Boolean) as HTMLElement[]
      if (!sections.length) return

      const activeClass = 'border-brand-300 text-brand-600 bg-brand-50'
      const inactiveClass = 'border-slate-200 text-slate-600 bg-white'

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const idx = sections.indexOf(entry.target as HTMLElement)
            if (idx === -1) continue
            const link = links[idx]
            if (entry.isIntersecting) {
              links.forEach((l) => {
                l.className = l.className
                  .replace(/border-brand-300|text-brand-600|bg-brand-50/g, '')
                  .trim()
                if (!l.className.includes('border-slate-200'))
                  l.className += ' ' + inactiveClass
              })
              link.className =
                link.className
                  .replace(/border-slate-200|text-slate-600|bg-white/g, '')
                  .trim() +
                ' ' +
                activeClass
            }
          }
        },
        { rootMargin: '-20% 0px -60% 0px' },
      )

      sections.forEach((s) => observer.observe(s))
    }
    initServicesSpy()
    document.addEventListener('astro:after-swap', initServicesSpy)
  </script>
