---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import CampaignNotice from '../components/CampaignNotice.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import Icon from '../components/Icon.astro'
import InsightGrid from '../components/InsightGrid.astro'
import ServiceSectionActions from '../components/ServiceSectionActions.astro'
import Timeline from '../components/Timeline.astro'
import { optimizeImage, generateSrcSet } from '../utils/image'
import { SITE } from '../data/site'
import { getWorksCopy } from '../data/works'
import { t, getTranslationValue, getLocalizedUrl, type Locale } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const worksCopy = getWorksCopy(locale)
const serviceWorks = worksCopy.serviceLinks
const contentImageWidths = [480, 800, 1200, 1600]
const contentImageOptions = { aspectRatio: 16 / 9, quality: 80 }
const contentImageSizes = '(min-width: 1024px) 56rem, calc(100vw - 3rem)'

interface ServicePricingItem {
  icon: string
  label: string
  price: string
  note: string
  href: string
}

interface TimelineItem {
  date: string
  title: string
  description: string
}

const getList = <T,>(key: string): T[] =>
  getTranslationValue<T[]>(locale, key) ?? []

const resolvePricingHref = (href: string) => {
  const normalizedHref = href.trim()
  if (
    !normalizedHref ||
    normalizedHref.startsWith('#') ||
    /^[a-z][a-z\d+.-]*:/i.test(normalizedHref)
  ) {
    return normalizedHref
  }
  return normalizedHref.startsWith('/') ? u(normalizedHref) : normalizedHref
}

const serviceMap = [
  {
    title: t(locale, 'pages.services.mapDevTitle'),
    description: t(locale, 'pages.services.mapDevDesc'),
    icon: 'code-xml',
    href: u('/services/#system-development'),
    tone: 'brand',
  },
  {
    title: t(locale, 'pages.services.mapInfraTitle'),
    description: t(locale, 'pages.services.mapInfraDesc'),
    icon: 'server',
    href: u('/services/#server'),
    tone: 'emerald',
  },
  {
    title: t(locale, 'pages.services.mapPublishTitle'),
    description: t(locale, 'pages.services.mapPublishDesc'),
    icon: 'globe',
    href: u('/services/#web'),
    tone: 'amber',
  },
  {
    title: t(locale, 'pages.services.mapEducationTitle'),
    description: t(locale, 'pages.services.mapEducationDesc'),
    icon: 'graduation-cap',
    href: u('/schools/'),
    tone: 'slate',
  },
] as const

const deliveryTimeline = getList<TimelineItem>('pages.services.timeline')
const systemDevExamples = getList<string>('pages.services.systemDev.examples')
const serverExamples = getList<string>('pages.services.server.examples')
const webExamples = getList<string>('pages.services.web.examples')
const designExamples = getList<string>('pages.services.design.examples')
const educationCourses = getList<string>('pages.services.education.courses')
const aceserverFeatures = getList<string>('pages.services.aceserver.features')
const acestudioAreas = getList<string>('pages.services.acestudio.areas')

const servicePricingItems = getList<ServicePricingItem>(
  'pages.services.pricing.items',
).map((item) => ({
  ...item,
  href: resolvePricingHref(item.href),
}))
const isBlogPricingHref = (href: string) => href.includes('/blog/')
const isWebPricingHref = (href: string) => href.includes('/services/#web')
const webBasePricingItem = servicePricingItems.find((item) =>
  isWebPricingHref(item.href),
)
const webFeatureItems = servicePricingItems.filter((item) =>
  isBlogPricingHref(item.href),
)
const webPricingTableItems = [
  ...(webBasePricingItem ? [webBasePricingItem] : []),
  ...webFeatureItems,
]
const servicePricingCoreItems = servicePricingItems.filter(
  (item) => !isBlogPricingHref(item.href) && !isWebPricingHref(item.href),
)
const webPricingTableTitle = webBasePricingItem
  ? `${webBasePricingItem.label} / ${t(
      locale,
      'pages.services.web.featureLinksTitle',
    )}`
  : t(locale, 'pages.services.web.featureLinksTitle')

const serviceLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: t(locale, 'pages.services.systemDev.title'),
      description: t(locale, 'pages.services.systemDev.desc'),
      provider: { '@type': 'Organization', name: 'Acecore' },
      url: 'https://acecore.net/services/#system-development',
    },
    {
      '@type': 'Service',
      name: t(locale, 'pages.services.server.title'),
      description: t(locale, 'pages.services.server.desc'),
      provider: { '@type': 'Organization', name: 'Acecore' },
      url: 'https://acecore.net/services/#server',
    },
    {
      '@type': 'Service',
      name: t(locale, 'pages.services.web.title'),
      description: t(locale, 'pages.services.web.desc'),
      provider: { '@type': 'Organization', name: 'Acecore' },
      url: 'https://acecore.net/services/#web',
    },
    {
      '@type': 'Service',
      name: t(locale, 'pages.services.design.title'),
      description: t(locale, 'pages.services.design.desc'),
      provider: { '@type': 'Organization', name: 'Acecore' },
      url: 'https://acecore.net/services/#design',
    },
    {
      '@type': 'Service',
      name: t(locale, 'pages.services.education.title'),
      description: t(locale, 'pages.services.education.desc'),
      provider: { '@type': 'Organization', name: 'Acecore' },
      url: `https://acecore.net${u('/schools/')}`,
    },
  ],
}
---

<BaseLayout
  title={t(locale, 'pages.services.title')}
  description={t(locale, 'pages.services.description')}
  jsonLd={serviceLd}
  locale={locale}
>
  <Hero
    title={t(locale, 'pages.services.heroTitle')}
    subtitle={t(locale, 'pages.services.heroSubtitle')}
    images={[
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: t(locale, 'pages.services.heroImgAlt'),
      },
    ]}
  />

  <CampaignNotice locale={locale} page="services" />

  <div class="ac-container mt-4">
    <Breadcrumb
      items={[{ label: t(locale, 'pages.services.title') }]}
      locale={locale}
    />
  </div>

  <section class="ac-section bg-slate-50">
    <div class="ac-container">
      <InsightGrid
        variant="card"
        eyebrow={t(locale, 'pages.services.serviceMapEyebrow')}
        title={t(locale, 'pages.services.serviceMapTitle')}
        description={t(locale, 'pages.services.serviceMapDesc')}
        items={serviceMap}
      />
    </div>
  </section>

  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      <nav class="mb-12 flex flex-wrap justify-center gap-2">
        <a href="#system-development" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navDev')}</a
        >
        <a href="#server" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navServer')}</a
        >
        <a href="#web" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navWeb')}</a
        >
        <a href="#design" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navDesign')}</a
        >
        <a href="#education" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navEducation')}</a
        >
        <a href="#aceserver" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navAceserver')}</a
        >
        <a href="#acestudio" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navAcestudio')}</a
        >
        <a href="#pricing" class="ac-chip text-sm"
          >{t(locale, 'pages.services.navPricing')}</a
        >
      </nav>

      <!-- System Development -->
      <div class="mb-16" id="system-development">
        <div class="mb-4 flex items-center gap-3">
          <span class="ac-icon-box"
            ><Icon name="code-xml" class="text-xl" /></span
          >
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.services.systemDev.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.services.systemDev.desc')}
          <a href={u('/contact/')} class="ac-link"
            >{t(locale, 'pages.services.ctaContact')}</a
          >
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.services.systemDev.examplesLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              systemDevExamples.map((example) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {example}
                </li>
              ))
            }
          </ul>
        </div>
        <ServiceSectionActions
          locale={locale}
          gaLabel="service_system_development_contact"
          gaLocation="services_system_development"
          serviceKey="system-development"
          workLink={serviceWorks.systemDev}
        />
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage(
            'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&h=450&fit=crop&q=80&fm=webp',
            { width: 1200, height: 675, quality: 80 },
          )}
          srcset={generateSrcSet(
            'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&h=450&fit=crop&q=80&fm=webp',
            contentImageWidths,
            contentImageOptions,
          )}
          sizes={contentImageSizes}
          alt={t(locale, 'pages.services.systemDev.imgAlt')}
          class="w-full rounded-lg object-cover aspect-video"
          width="1200"
          height="675"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- Server -->
      <div class="mb-16" id="server">
        <div class="mb-4 flex items-center gap-3">
          <span class="ac-icon-box"><Icon name="server" class="text-xl" /></span
          >
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.services.server.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.services.server.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.services.server.examplesLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              serverExamples.map((example) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {example}
                </li>
              ))
            }
          </ul>
        </div>
        <ServiceSectionActions
          locale={locale}
          gaLabel="service_server_contact"
          gaLocation="services_server"
          serviceKey="server"
          workLink={serviceWorks.server}
        />
      </div>

      <!-- Web -->
      <div class="mb-16" id="web">
        <div class="mb-4 flex items-center gap-3">
          <span class="ac-icon-box"><Icon name="globe" class="text-xl" /></span>
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.services.web.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.services.web.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.services.web.examplesLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              webExamples.map((example) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {example}
                </li>
              ))
            }
          </ul>
        </div>
        <ServiceSectionActions
          locale={locale}
          gaLabel="service_web_contact"
          gaLocation="services_web"
          serviceKey="web"
          workLink={serviceWorks.web}
        />
        {
          webPricingTableItems.length > 0 && (
            <div class="mt-6 border-y border-slate-200 py-5">
              <div class="mb-4">
                <h3 class="text-lg ac-heading">{webPricingTableTitle}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">
                  {t(locale, 'pages.services.web.featureLinksBody')}
                </p>
              </div>
              <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
                <table class="w-full min-w-220 border-collapse text-left text-sm">
                  <thead class="bg-slate-50 text-slate-900">
                    <tr>
                      <th class="border-b border-slate-200 px-4 py-3 font-700">
                        {t(locale, 'pages.pricing.feeItem')}
                      </th>
                      <th class="border-b border-slate-200 px-4 py-3 font-700">
                        {t(locale, 'pages.pricing.feeAmount')}
                      </th>
                      <th class="border-b border-slate-200 px-4 py-3 font-700">
                        {t(locale, 'pages.pricing.feeNote')}
                      </th>
                      <th class="border-b border-slate-200 px-4 py-3 font-700">
                        {t(locale, 'pages.pricing.detailLink')}
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {webPricingTableItems.map((item) => (
                      <tr
                        class={`align-top transition hover:bg-brand-50/50 ${
                          isWebPricingHref(item.href) ? 'bg-brand-50/40' : ''
                        }`}
                      >
                        <th class="border-b border-slate-100 px-4 py-4 font-700 text-slate-900">
                          <a
                            href={item.href}
                            class="group inline-flex items-center gap-3 no-underline"
                          >
                            <span class="ac-icon-box shrink-0">
                              <Icon name={item.icon} class="text-base" />
                            </span>
                            <span class="transition group-hover:text-brand-600">
                              {item.label}
                            </span>
                          </a>
                        </th>
                        <td class="border-b border-slate-100 px-4 py-4 font-800 text-brand-700">
                          {item.price}
                        </td>
                        <td class="border-b border-slate-100 px-4 py-4 leading-relaxed text-slate-600">
                          {item.note}
                        </td>
                        <td class="border-b border-slate-100 px-4 py-4">
                          <a
                            href={item.href}
                            class="inline-flex items-center gap-1 font-700 text-brand-600 no-underline hover:underline"
                          >
                            {isBlogPricingHref(item.href)
                              ? t(
                                  locale,
                                  'pages.services.web.featureLinksArticleLabel',
                                )
                              : t(locale, 'pages.pricing.detailLink')}
                            <Icon name="arrow-right" class="text-xs" />
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )
        }
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage(
            'https://images.unsplash.com/photo-1547658719-da2b51169166?w=800&h=450&fit=crop&q=80&fm=webp',
            { width: 1200, height: 675, quality: 80 },
          )}
          srcset={generateSrcSet(
            'https://images.unsplash.com/photo-1547658719-da2b51169166?w=800&h=450&fit=crop&q=80&fm=webp',
            contentImageWidths,
            contentImageOptions,
          )}
          sizes={contentImageSizes}
          alt={t(locale, 'pages.services.web.imgAlt')}
          class="w-full rounded-lg object-cover aspect-video"
          width="1200"
          height="675"
          decoding="async"
          loading="lazy"
        />
      </div>

      <div class="mb-16">
        <Timeline
          title={t(locale, 'pages.services.timelineTitle')}
          items={deliveryTimeline}
          locale={locale}
        />
      </div>

      <!-- Design -->
      <div class="mb-16" id="design">
        <div class="mb-4 flex items-center gap-3">
          <span class="ac-icon-box"
            ><Icon name="palette" class="text-xl" /></span
          >
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.services.design.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.services.design.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.services.design.examplesLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              designExamples.map((example) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {example}
                </li>
              ))
            }
          </ul>
        </div>
        <ServiceSectionActions
          locale={locale}
          gaLabel="service_design_contact"
          gaLocation="services_design"
          serviceKey="design"
          workLink={serviceWorks.design}
        />
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage(
            'https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=800&h=450&fit=crop&q=80&fm=webp',
            { width: 1200, height: 675, quality: 80 },
          )}
          srcset={generateSrcSet(
            'https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=800&h=450&fit=crop&q=80&fm=webp',
            contentImageWidths,
            contentImageOptions,
          )}
          sizes={contentImageSizes}
          alt={t(locale, 'pages.services.design.imgAlt')}
          class="w-full rounded-lg object-cover aspect-video"
          width="1200"
          height="675"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- Education -->
      <div class="mb-16" id="education">
        <div class="mb-4 flex items-center gap-3">
          <span class="ac-icon-box"
            ><Icon name="graduation-cap" class="text-xl" /></span
          >
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.services.education.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.services.education.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.services.education.coursesLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              educationCourses.map((course) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {course}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="mt-4">
          <a
            href={u('/schools/')}
            class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1"
          >
            <Icon name="arrow-right" class="text-sm" />
            {t(locale, 'pages.services.education.detailLink')}
          </a>
        </div>
        <ServiceSectionActions
          locale={locale}
          gaLabel="service_education_contact"
          gaLocation="services_education"
          serviceKey="education"
          workLink={serviceWorks.education}
        />
      </div>

      <!-- Aceserver -->
      <div class="mb-16" id="aceserver">
        <div class="mb-4 flex items-center gap-3">
          <span class="ac-icon-box"
            ><Icon name="gamepad-2" class="text-xl" /></span
          >
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.services.aceserver.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.services.aceserver.desc')}
        </p>
        <div class="ac-surface mb-4 bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.services.aceserver.featuresLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              aceserverFeatures.map((feature) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {feature}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="flex flex-wrap gap-3 mb-4">
          <a
            href={SITE.social.aceserver}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1"
          >
            <Icon name="external-link" class="text-sm" />
            {t(locale, 'pages.services.aceserver.portalLink')}<span
              class="sr-only">{t(locale, 'common.opensInNewTab')}</span
            >
          </a>
          <a
            href="https://aceserver-wiki.acecore.systems/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1"
          >
            <Icon name="external-link" class="text-sm" />
            {t(locale, 'pages.services.aceserver.wikiLink')}<span
              class="sr-only">{t(locale, 'common.opensInNewTab')}</span
            >
          </a>
          <a
            href={SITE.social.discord}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1"
          >
            <Icon name="external-link" class="text-sm" />
            {t(locale, 'pages.services.aceserver.discordLink')}<span
              class="sr-only">{t(locale, 'common.opensInNewTab')}</span
            >
          </a>
        </div>
        <ServiceSectionActions
          locale={locale}
          gaLabel="service_aceserver_contact"
          gaLocation="services_aceserver"
          serviceKey="aceserver"
          workLink={serviceWorks.aceserver}
        />
      </div>

      <!-- AceStudio -->
      <div class="mb-16" id="acestudio">
        <div class="mb-4 flex items-center gap-3">
          <span class="ac-icon-box"
            ><Icon name="clapperboard" class="text-xl" /></span
          >
          <h2 class="text-2xl ac-heading">
            AceStudio <span class="text-sm font-400 text-slate-500 ml-2"
              >{t(locale, 'pages.services.acestudio.comingSoon')}</span
            >
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.services.acestudio.desc')}
        </p>
        <div class="ac-surface mb-4 bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.services.acestudio.areasLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              acestudioAreas.map((area) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {area}
                </li>
              ))
            }
          </ul>
        </div>
        <p class="text-sm text-slate-500 mb-4">
          {t(locale, 'pages.services.acestudio.note')}
        </p>
        <div class="mt-2">
          <a
            href={u('/acestudio/')}
