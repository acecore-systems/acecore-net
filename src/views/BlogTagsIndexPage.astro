---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { getCollection } from 'astro:content'
import { t, getLocalizedUrl, type Locale } from '../i18n'
import { isBasePost } from '../utils/blog-i18n'
import { getAllTags, getLocalizedTagName } from '../utils/tags'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const breadcrumbItems = [
  { label: t(locale, 'blog.title'), href: u('/blog/') },
  { label: t(locale, 'blog.tagList'), href: u('/blog/tags/') },
]

const allPosts = (await getCollection('blog')).filter(isBasePost)
const tags = await getAllTags()
const tagCounts = new Map<string, number>()
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1])
---

<BaseLayout
  title={t(locale, 'blog.tagList')}
  description={t(locale, 'blog.tagListDescription')}
  robots="noindex, follow"
  locale={locale}
  breadcrumbItems={breadcrumbItems.map((item) => ({
    name: item.label,
    item: item.href,
  }))}
>
  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      <Breadcrumb items={breadcrumbItems} locale={locale} />
      <h1 class="mb-4 break-words text-2xl ac-heading sm:text-3xl">
        {t(locale, 'blog.tagList')}
      </h1>
      <p class="mb-8 max-w-2xl leading-relaxed text-slate-600">
        {t(locale, 'blog.tagListDescription')}
      </p>
      <div class="flex flex-wrap gap-3">
        {
          sortedTags.map(([tag, count]) => (
            <a
              href={u(`/blog/tags/${tag}/`)}
              class="ac-chip gap-2 px-4 py-2 text-sm no-underline transition-colors hover:border-brand-200 hover:bg-brand-50"
            >
              <span class="font-600">
                {getLocalizedTagName(tags, tag, locale)}
              </span>
              <span class="rounded-md bg-white px-2 py-0.5 text-xs font-700 text-brand-600">
                {count}
              </span>
            </a>
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <a href={u('/blog/')} class="ac-btn-outline"
          >{t(locale, 'blog.backToBlog')}</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
