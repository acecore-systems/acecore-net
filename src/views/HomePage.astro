---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import CampaignNotice from '../components/CampaignNotice.astro'
import ServiceCard from '../components/ServiceCard.astro'
import InsightGrid from '../components/InsightGrid.astro'
import { getCollection } from 'astro:content'
import {
  optimizeImage,
  generateSrcSet,
  resolveImageSource,
  type GenerateSrcSetOptions,
} from '../utils/image'
import {
  t,
  formatDate,
  getTranslationValue,
  getLocalizedUrl,
  type Locale,
} from '../i18n'
import {
  isBasePost,
  localizePost,
  getBaseSlug,
  getLocalizedAuthor,
} from '../utils/blog-i18n'
import { getSchoolsUrl } from '../utils/schools-url'
import {
  getAllAuthors,
  findAuthorById,
  type AuthorData,
} from '../utils/authors'

interface Props {
  locale: Locale
}

type HomeLayer = {
  title: string
  description: string
  icon: string
  href: string
  tone: 'brand' | 'emerald' | 'amber' | 'slate'
}

type HeroImage = {
  src: string
  alt: string
  srcsetWidths?: number[]
  srcsetOptions?: GenerateSrcSetOptions
  sizes?: string
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const getList = <T,>(key: string): T[] =>
  getTranslationValue<T[]>(locale, key) ?? []
const resolveCardHref = (href: string) =>
  href.startsWith('http') ? href : u(href)
const homeHeroSrcSetWidths = [360, 480, 640, 828, 1080, 1280, 1600]
const homeHeroSrcSetOptions = {
  aspectRatio: 1,
  quality: 75,
} satisfies GenerateSrcSetOptions
const homeHeroImageSizes =
  '(min-width: 1280px) 36.5rem, (min-width: 1024px) 40vw, calc(100vw - 2.5rem)'
const homePostImageWidths = [320, 640, 960, 1200]
const homePostImageOptions = { aspectRatio: 16 / 9, quality: 80 }

const allPosts = await getCollection('blog')
const authors: AuthorData[] = await getAllAuthors()
const posts = allPosts
  .filter(isBasePost)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((p) => localizePost(p, allPosts, locale))

const serviceCards = getList<HomeLayer>('pages.home.serviceCards').map(
  (item) => ({ ...item, href: resolveCardHref(item.href) }),
)
const coreLayers = getList<HomeLayer>('pages.home.layerItems').map((item) => ({
  ...item,
  href: resolveCardHref(item.href),
}))
const homeHeroImages: HeroImage[] = [
  {
    src: optimizeImage(
      'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1280&h=1280&fit=crop&q=90&fm=webp',
      { width: 1280, height: 1280, quality: 75 },
    ),
    alt: t(locale, 'pages.home.heroImgTeam'),
    srcsetWidths: homeHeroSrcSetWidths,
    srcsetOptions: homeHeroSrcSetOptions,
    sizes: homeHeroImageSizes,
  },
  {
    src: optimizeImage(
      'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1280&h=1280&fit=crop&q=90&fm=webp',
      { width: 1280, height: 1280, quality: 75 },
    ),
    alt: t(locale, 'pages.home.heroImgMeeting'),
    srcsetWidths: homeHeroSrcSetWidths,
    srcsetOptions: homeHeroSrcSetOptions,
    sizes: homeHeroImageSizes,
  },
]
const firstHeroImage = homeHeroImages[0]

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: t(locale, 'meta.siteTitle'),
  description: t(locale, 'meta.defaultDescription'),
  url: 'https://acecore.net/',
}
---

<BaseLayout
  locale={locale}
  title={t(locale, 'nav.home')}
  jsonLd={webPageLd}
  preloadImage={firstHeroImage
    ? {
        src: firstHeroImage.src,
        srcset: generateSrcSet(
          firstHeroImage.src,
          firstHeroImage.srcsetWidths,
          firstHeroImage.srcsetOptions,
        ),
        sizes: firstHeroImage.sizes ?? '100vw',
      }
    : undefined}
>
  <Hero
    title={t(locale, 'pages.home.heroTitle')}
    titleLines={locale === 'ja'
      ? ['開発からデザイン、', '教育まで。', 'ワンストップで届けるIT支援']
      : undefined}
    subtitle={t(locale, 'pages.home.heroSubtitle')}
    showCTA={true}
    images={homeHeroImages}
  />

  <CampaignNotice locale={locale} page="home" />

  <section
    class="ac-blueprint-soft border-y border-brand-100 bg-brand-50/70 pt-14 pb-8 sm:pt-16 sm:pb-10 lg:pt-20 lg:pb-10"
  >
    <div class="ac-container">
      <div class="ac-section-intro">
        <h2 class="mb-4 text-2xl ac-heading sm:text-3xl">
          {t(locale, 'pages.home.servicesHeading')}
        </h2>
        <p class="ac-muted">
          {t(locale, 'pages.home.servicesLead')}
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          serviceCards.map((item) => (
            <ServiceCard
              icon={item.icon}
              title={item.title}
              description={item.description}
              href={item.href}
              locale={locale}
              tone={item.tone}
            />
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <a href={u('/services/')} class="ac-btn-outline"
          >{t(locale, 'pages.home.viewServicesDetail')}</a
        >
      </div>
    </div>
  </section>

  <section class="bg-white py-10 sm:py-12 lg:py-14">
    <div class="ac-container">
      <InsightGrid
        variant="card"
        eyebrow={t(locale, 'pages.home.layersEyebrow')}
        title={t(locale, 'pages.home.layersTitle')}
        description={t(locale, 'pages.home.layersDescription')}
        items={coreLayers}
      />
    </div>
  </section>

  <section class="ac-section bg-brand-900 text-white">
    <div class="ac-container">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-2xl font-800 leading-tight text-white sm:text-3xl">
          {t(locale, 'pages.home.aboutHeading')}
        </h2>
        <p class="text-lg leading-relaxed text-white/80 mb-4">
          {t(locale, 'pages.home.aboutBody1')}
        </p>
        <p
          class="text-lg leading-relaxed text-white/80 mb-8"
          set:html={t(locale, 'pages.home.aboutBody2', {
            link: `<a href="${getSchoolsUrl(locale)}" class="text-white underline underline-offset-2 hover:text-brand-100">${t(locale, 'pages.home.aboutEducationLink')}</a>`,
          })}
        />
        <div
          class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4"
        >
          <a href={u('/about/')} class="ac-btn-primary"
            >{t(locale, 'pages.home.viewAbout')}</a
          >
          <a
            href={u('/services/')}
            class="ac-btn border-2 border-white bg-transparent text-white hover:bg-white/10"
            >{t(locale, 'pages.home.viewServices')}</a
          >
        </div>
      </div>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="border-b border-brand-100 bg-white py-8 sm:py-10">
        <div class="ac-container">
          <div class="ac-section-intro">
            <h2 class="text-2xl ac-heading sm:text-3xl">
              {t(locale, 'pages.home.latestBlog')}
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {posts.map((post) => {
              const postImage = resolveImageSource(
                post.data.uploadedImage,
                post.data.image,
              )
              const rawAuthor = findAuthorById(authors, post.data.author)
              const author = rawAuthor
                ? getLocalizedAuthor(rawAuthor, locale)
                : null

              return (
                <a
                  href={u(`/blog/${getBaseSlug(post.id)}/`)}
                  class="ac-card ac-rule-top group overflow-hidden pt-0 no-underline transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-[0_18px_38px_rgba(15,35,56,0.1)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
                >
                  {postImage && (
                    <img
                      src={optimizeImage(postImage, {
                        width: 800,
                        height: 400,
                        quality: 80,
                      })}
                      srcset={generateSrcSet(
                        postImage,
                        homePostImageWidths,
                        homePostImageOptions,
                      )}
                      sizes="(min-width: 768px) calc(33vw - 2rem), calc(100vw - 2rem)"
                      alt={post.data.title}
                      class="h-44 w-full object-cover"
                      width="800"
                      height="400"
                      decoding="async"
                      loading="lazy"
                    />
                  )}
                  <div class="p-6">
                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-slate-600">
                      <time datetime={post.data.date.toISOString()}>
                        {formatDate(post.data.date, locale)}
                      </time>
                      {post.data.author && (
                        <span>by {author?.name || post.data.author}</span>
                      )}
                    </div>
                    <h3 class="mt-3 mb-3 text-lg font-700 leading-snug text-slate-900 transition-colors group-hover:text-brand-600">
                      {post.data.title}
                    </h3>
                    <p class="line-clamp-3 text-sm leading-relaxed text-slate-600">
                      {post.data.description}
                    </p>
                  </div>
                </a>
              )
            })}
          </div>
          <div class="mt-10 text-center">
            <a href={u('/blog/')} class="ac-btn-outline">
              {t(locale, 'pages.home.viewAllPosts')}
            </a>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
