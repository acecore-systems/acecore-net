---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import ServiceCard from '../components/ServiceCard.astro'
import InsightGrid from '../components/InsightGrid.astro'
import Icon from '../components/Icon.astro'
import { getCollection } from 'astro:content'
import {
  optimizeImage,
  generateSrcSet,
  resolveImageSource,
} from '../utils/image'
import { SITE } from '../data/site'
import { getWorksCopy } from '../data/works'
import { t, formatDate, getLocalizedUrl, type Locale } from '../i18n'
import {
  isBasePost,
  localizePost,
  getBaseSlug,
  getLocalizedAuthor,
} from '../utils/blog-i18n'
import {
  getAllAuthors,
  findAuthorById,
  type AuthorData,
} from '../utils/authors'

interface Props {
  locale: Locale
}

type HomeLayer = {
  title: string
  description: string
  icon: string
  tone: 'brand' | 'emerald' | 'amber' | 'slate'
}

type HeroImage = {
  src: string
  alt: string
  srcsetWidths?: number[]
  sizes?: string
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const worksCopy = getWorksCopy(locale)
const homeHeroSrcSetWidths = [360, 480, 640, 828, 1080, 1280]

const allPosts = await getCollection('blog')
const authors: AuthorData[] = await getAllAuthors()
const posts = allPosts
  .filter(isBasePost)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((p) => localizePost(p, allPosts, locale))

const coreLayers: HomeLayer[] = [
  {
    title: t(locale, 'pages.home.layerDesign'),
    description: t(locale, 'pages.home.layerDesignDesc'),
    icon: 'code-2',
    tone: 'brand',
  },
  {
    title: t(locale, 'pages.home.layerInfra'),
    description: t(locale, 'pages.home.layerInfraDesc'),
    icon: 'server-cog',
    tone: 'emerald',
  },
  {
    title: t(locale, 'pages.home.layerExpression'),
    description: t(locale, 'pages.home.layerExpressionDesc'),
    icon: 'swatch-book',
    tone: 'amber',
  },
  {
    title: t(locale, 'pages.home.layerEducation'),
    description: t(locale, 'pages.home.layerEducationDesc'),
    icon: 'graduation-cap',
    tone: 'slate',
  },
]
const homeHeroImages: HeroImage[] = [
  {
    src: optimizeImage(
      'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1400&h=600&fit=crop&q=70&fm=webp',
      { quality: 40 },
    ),
    alt: t(locale, 'pages.home.heroImgTeam'),
    srcsetWidths: homeHeroSrcSetWidths,
    sizes: '100vw',
  },
  {
    src: optimizeImage(
      'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1400&h=600&fit=crop&q=70&fm=webp',
      { quality: 40 },
    ),
    alt: t(locale, 'pages.home.heroImgCollaboration'),
    srcsetWidths: homeHeroSrcSetWidths,
    sizes: '100vw',
  },
  {
    src: optimizeImage(
      'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1400&h=600&fit=crop&q=70&fm=webp',
      { quality: 40 },
    ),
    alt: t(locale, 'pages.home.heroImgMeeting'),
    srcsetWidths: homeHeroSrcSetWidths,
    sizes: '100vw',
  },
  {
    src: optimizeImage(
      'https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1400&h=600&fit=crop&q=70&fm=webp',
      { quality: 40 },
    ),
    alt: t(locale, 'pages.home.heroImgStrategy'),
    srcsetWidths: homeHeroSrcSetWidths,
    sizes: '100vw',
  },
]
const firstHeroImage = homeHeroImages[0]

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: t(locale, 'meta.siteTitle'),
  description: t(locale, 'meta.defaultDescription'),
  url: 'https://acecore.net/',
}
---

<BaseLayout
  locale={locale}
  title={t(locale, 'nav.home')}
  jsonLd={webPageLd}
  preloadImage={firstHeroImage
    ? {
        src: firstHeroImage.src,
        srcset: generateSrcSet(firstHeroImage.src, firstHeroImage.srcsetWidths),
        sizes: firstHeroImage.sizes ?? '100vw',
      }
    : undefined}
>
  <Hero
    title={t(locale, 'pages.home.heroTitle')}
    subtitle={t(locale, 'pages.home.heroSubtitle')}
    showCTA={true}
    images={homeHeroImages}
  />

  <section class="ac-section bg-slate-900 text-white">
    <div class="ac-container">
      <div
        class="grid gap-10 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-center"
      >
        <div>
          <h2 class="text-2xl sm:text-3xl font-800 mb-4">
            {worksCopy.homeHeading}
          </h2>
          <p class="text-slate-300 leading-relaxed mb-6">
            {worksCopy.homeLead}
          </p>
          <a
            href={u('/works/')}
            class="inline-flex items-center gap-2 rounded-lg border border-white/30 px-5 py-3 min-h-11 text-sm font-700 text-white no-underline hover:bg-white/10 transition-colors"
          >
            <Icon name="briefcase-business" class="text-lg" />
            {worksCopy.homeCta}
          </a>
        </div>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          {
            worksCopy.stats.map((stat) => (
              <div class="rounded-lg border border-white/10 bg-white/10 p-6">
                <div class="mb-4 flex items-center gap-3">
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-white/10 text-white">
                    <Icon name={stat.icon} class="text-lg" />
                  </span>
                  <p class="text-2xl sm:text-3xl font-800 leading-none">
                    {stat.value}
                  </p>
                </div>
                <h3 class="text-sm font-700 text-white mb-1">{stat.label}</h3>
                <p class="text-sm leading-relaxed text-slate-300">
                  {stat.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="ac-section bg-slate-50">
    <div class="ac-container">
      <div class="ac-section-intro">
        <h2 class="mb-4 text-2xl ac-heading sm:text-3xl">
          {t(locale, 'pages.home.servicesHeading')}
        </h2>
        <p class="ac-muted">
          {t(locale, 'pages.home.servicesLead')}
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <ServiceCard
          icon="code-2"
          title={t(locale, 'pages.home.serviceSystem')}
          description={t(locale, 'pages.home.serviceSystemDesc')}
          href={u('/services/#system-development')}
          locale={locale}
        />
        <ServiceCard
          icon="server"
          title={t(locale, 'pages.home.serviceServer')}
          description={t(locale, 'pages.home.serviceServerDesc')}
          href={u('/services/#server')}
          locale={locale}
        />
        <ServiceCard
          icon="globe"
          title={t(locale, 'pages.home.serviceWeb')}
          description={t(locale, 'pages.home.serviceWebDesc')}
          href={u('/services/#web')}
          locale={locale}
        />
        <ServiceCard
          icon="palette"
          title={t(locale, 'pages.home.serviceDesign')}
          description={t(locale, 'pages.home.serviceDesignDesc')}
          href={u('/services/#design')}
          locale={locale}
        />
        <ServiceCard
          icon="graduation-cap"
          title={t(locale, 'pages.home.serviceSchools')}
          description={t(locale, 'pages.home.serviceSchoolsDesc')}
          href={u('/schools/')}
          locale={locale}
        />
        <ServiceCard
          icon="gamepad-2"
          title={t(locale, 'pages.home.serviceAceserver')}
          description={t(locale, 'pages.home.serviceAceserverDesc')}
          href={SITE.social.aceserver}
          locale={locale}
        />
      </div>
      <div class="mt-10 text-center">
        <a href={u('/services/')} class="ac-btn-outline"
          >{t(locale, 'pages.home.viewServicesDetail')}</a
        >
      </div>
    </div>
  </section>

  <section class="ac-section">
    <div class="ac-container">
      <InsightGrid
        variant="card"
        eyebrow={t(locale, 'pages.home.layersEyebrow')}
        title={t(locale, 'pages.home.layersTitle')}
        description={t(locale, 'pages.home.layersDescription')}
        items={coreLayers}
      />
    </div>
  </section>

  <section class="ac-section">
    <div class="ac-container">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-6 text-2xl ac-heading sm:text-3xl">
          {t(locale, 'pages.home.aboutHeading')}
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.home.aboutBody1')}
        </p>
        <p
          class="text-lg text-slate-600 leading-relaxed mb-8"
          set:html={t(locale, 'pages.home.aboutBody2', {
            link: `<a href="${u('/schools/')}" class="ac-link">${t(locale, 'pages.home.aboutEducationLink')}</a>`,
          })}
        />
        <div
          class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4"
        >
          <a href={u('/about/')} class="ac-btn-primary"
            >{t(locale, 'pages.home.viewAbout')}</a
          >
          <a href={u('/services/')} class="ac-btn-outline"
            >{t(locale, 'pages.home.viewServices')}</a
          >
        </div>
      </div>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="ac-section bg-slate-50">
        <div class="ac-container">
          <div class="ac-section-intro">
            <h2 class="text-2xl ac-heading sm:text-3xl">
              {t(locale, 'pages.home.latestBlog')}
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {posts.map((post) => {
              const postImage = resolveImageSource(
                post.data.uploadedImage,
                post.data.image,
              )
              const rawAuthor = findAuthorById(authors, post.data.author)
              const author = rawAuthor
                ? getLocalizedAuthor(rawAuthor, locale)
                : null

              return (
                <a
                  href={u(`/blog/${getBaseSlug(post.id)}/`)}
                  class="ac-card group overflow-hidden no-underline transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
                >
                  {postImage && (
                    <img
                      src={optimizeImage(postImage)}
                      srcset={generateSrcSet(postImage, [200, 400, 800])}
                      sizes="(min-width: 768px) calc(33vw - 2rem), calc(100vw - 2rem)"
                      alt={post.data.title}
                      class="h-44 w-full object-cover"
                      width="400"
                      height="160"
                      decoding="async"
                      loading="lazy"
                    />
                  )}
                  <div class="p-6">
                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-slate-600">
                      <time datetime={post.data.date.toISOString()}>
                        {formatDate(post.data.date, locale)}
                      </time>
                      {post.data.author && (
                        <span>by {author?.name || post.data.author}</span>
                      )}
                    </div>
                    <h3 class="mt-3 mb-3 text-lg font-700 leading-snug text-slate-900 transition-colors group-hover:text-brand-600">
                      {post.data.title}
                    </h3>
                    <p class="line-clamp-3 text-sm leading-relaxed text-slate-600">
                      {post.data.description}
                    </p>
                  </div>
                </a>
              )
            })}
          </div>
          <div class="mt-10 text-center">
            <a href={u('/blog/')} class="ac-btn-outline">
              {t(locale, 'pages.home.viewAllPosts')}
            </a>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
