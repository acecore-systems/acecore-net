---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import BlogPostCard from '../components/BlogPostCard.astro'
import BlogSidebar from '../components/BlogSidebar.astro'
import { t, getLocalizedUrl, type Locale } from '../i18n'
import { localizePost } from '../utils/blog-i18n'

import type { CollectionEntry } from 'astro:content'

interface Props {
  locale: Locale
  month: string
  posts: CollectionEntry<'blog'>[]
  allPosts: CollectionEntry<'blog'>[]
}

const { locale, month, posts, allPosts } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const [year, m] = month.split('-')
const label = t(locale, 'blog.yearMonth', { year, month: String(parseInt(m)) })
const archiveUrl = `https://acecore.net${u('/blog/archive/' + month + '/')}`
const breadcrumbItems = [
  { label: t(locale, 'blog.title'), href: u('/blog/') },
  { label: t(locale, 'blog.archive'), href: u('/blog/archive/') },
  { label, href: u(`/blog/archive/${month}/`) },
]
const archivePageLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t(locale, 'blog.articlesInMonth', { label }),
  description: t(locale, 'blog.monthDescription', { label }),
  url: archiveUrl,
  hasPart: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: localizePost(post, allPosts, locale).data.title,
    url: `https://acecore.net${u('/blog/' + post.id + '/')}`,
  })),
}
---

<BaseLayout
  title={t(locale, 'blog.articlesInMonth', { label })}
  description={t(locale, 'blog.monthDescription', { label })}
  robots="noindex, follow"
  jsonLd={archivePageLd}
  locale={locale}
  breadcrumbItems={breadcrumbItems.map((item) => ({
    name: item.label,
    item: item.href,
  }))}
>
  <section class="ac-section">
    <div class="ac-container">
      <Breadcrumb items={breadcrumbItems} locale={locale} />
      <div class="mb-8">
        <h1 class="mb-3 break-words text-2xl ac-heading sm:text-3xl">
          {t(locale, 'blog.articlesInMonth', { label })}
        </h1>
        <p class="max-w-2xl leading-relaxed text-slate-600">
          {t(locale, 'blog.monthDescription', { label })}
          <span
            class="ml-2 inline-flex rounded-lg bg-brand-50 px-3 py-1 text-sm font-700 text-brand-600"
          >
            {t(locale, 'blog.postsCount', { count: posts.length })}
          </span>
        </p>
      </div>
      <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_280px] lg:gap-10">
        <div class="space-y-6">
          {
            posts.map((post) => (
              <BlogPostCard
                post={localizePost(post, allPosts, locale)}
                locale={locale}
              />
            ))
          }
          <div class="mt-8 text-center">
            <a href={u('/blog/')} class="ac-btn-outline"
              >{t(locale, 'blog.backToBlog')}</a
            >
          </div>
        </div>
        <BlogSidebar allPosts={allPosts} locale={locale} />
      </div>
    </div>
  </section>
</BaseLayout>
