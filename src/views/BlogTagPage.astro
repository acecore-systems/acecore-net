---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import BlogPostCard from '../components/BlogPostCard.astro'
import BlogSidebar from '../components/BlogSidebar.astro'
import { t, getLocalizedUrl, translateTag, type Locale } from '../i18n'
import { localizePost } from '../utils/blog-i18n'

import type { CollectionEntry } from 'astro:content'

interface Props {
  locale: Locale
  tag: string
  posts: CollectionEntry<'blog'>[]
  allPosts: CollectionEntry<'blog'>[]
}

const { locale, tag, posts, allPosts } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const displayTag = translateTag(tag, locale)
---

<BaseLayout
  title={t(locale, 'blog.articlesByTag', { tag: displayTag })}
  description={t(locale, 'blog.tagDescription', { tag: displayTag })}
  locale={locale}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: t(locale, 'blog.articlesByTag', { tag: displayTag }),
    url: `https://acecore.net${u(`/blog/tags/${tag}/`)}`,
    description: t(locale, 'blog.tagDescription', { tag: displayTag }),
    hasPart: posts.map((post) => ({
      '@type': 'BlogPosting',
      headline: localizePost(post, allPosts, locale).data.title,
      url: `https://acecore.net${u(`/blog/${post.id}/`)}`,
    })),
  }}
>
  <section class="ac-section">
    <div class="ac-container">
      <Breadcrumb
        items={[
          { label: t(locale, 'blog.title'), href: u('/blog/') },
          { label: t(locale, 'blog.tagList'), href: u('/blog/tags/') },
          { label: t(locale, 'blog.tagPrefix', { tag: displayTag }) },
        ]}
        locale={locale}
      />
      <h1 class="text-2xl sm:text-3xl ac-heading mb-8">
        {t(locale, 'blog.articlesByTag', { tag: displayTag })}
      </h1>
      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
        <div class="space-y-6">
          {posts.map((post) => <BlogPostCard post={localizePost(post, allPosts, locale)} locale={locale} />)}
        </div>
        <BlogSidebar allPosts={allPosts} locale={locale} />
      </div>
      <div class="mt-8 text-center">
        <a href={u('/blog/')} class="ac-btn-outline">{t(locale, 'blog.backToBlog')}</a>
      </div>
    </div>
  </section>
</BaseLayout>
