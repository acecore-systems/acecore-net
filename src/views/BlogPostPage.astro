---
import '../styles/prose.css'
import BaseLayout from '../layouts/BaseLayout.astro'
import { render } from 'astro:content'
import authors from '../data/authors.json'
import { optimizeImage, generateSrcSet } from '../utils/image'
import Callout from '../components/Callout.astro'
import Timeline from '../components/Timeline.astro'
import YouTubeEmbed from '../components/YouTubeEmbed.astro'
import Faq from '../components/Faq.astro'
import Gallery from '../components/Gallery.astro'
import LinkCard from '../components/LinkCard.astro'
import ProcessFigure from '../components/ProcessFigure.astro'
import CompareTable from '../components/CompareTable.astro'
import Checklist from '../components/Checklist.astro'
import InsightGrid from '../components/InsightGrid.astro'
import Testimonial from '../components/Testimonial.astro'
import PullQuote from '../components/PullQuote.astro'
import AdUnit from '../components/AdUnit.astro'
import TableOfContents from '../components/TableOfContents.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import ShareButtons from '../components/ShareButtons.astro'
import CopyCodeButton from '../components/CopyCodeButton.astro'
import { t, getLocalizedUrl, formatDate, defaultLocale, translateTag, htmlLangMap, type Locale } from '../i18n'
import { getCollection } from 'astro:content'
import { localizePost, isBasePost, getLocalizedAuthor } from '../utils/blog-i18n'

import type { CollectionEntry } from 'astro:content'

interface Props {
  locale: Locale
  post: CollectionEntry<'blog'>
  allPosts: CollectionEntry<'blog'>[]
}

const { locale, post: basePost, allPosts } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const isDefaultLocale = locale === defaultLocale

const allRawPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const post = localizePost(basePost, allRawPosts, locale)
const baseSlug = basePost.id

const { Content, headings } = await render(post)
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3)
const rawAuthor = post.data.author
  ? authors.find((a) => a.id === post.data.author)
  : null
const author = rawAuthor ? getLocalizedAuthor(rawAuthor, locale) : null

const basePosts = allRawPosts.filter(isBasePost)

const currentIndex = basePosts.findIndex((p) => p.id === baseSlug)
const prevBasePost =
  currentIndex < basePosts.length - 1 ? basePosts[currentIndex + 1] : null
const nextBasePost = currentIndex > 0 ? basePosts[currentIndex - 1] : null
const prevPost = prevBasePost ? { id: prevBasePost.id, data: localizePost(prevBasePost, allRawPosts, locale).data } : null
const nextPost = nextBasePost ? { id: nextBasePost.id, data: localizePost(nextBasePost, allRawPosts, locale).data } : null

const currentTags = post.data.tags ?? []
const relatedPosts =
  currentTags.length > 0
    ? basePosts
        .filter((p) => p.id !== baseSlug)
        .map((p) => ({
          post: p,
          score: (p.data.tags ?? []).filter((tag: string) =>
            currentTags.includes(tag),
          ).length,
        }))
        .filter((p) => p.score > 0)
        .sort(
          (a, b) =>
            b.score - a.score ||
            b.post.data.date.getTime() - a.post.data.date.getTime(),
        )
        .slice(0, 4)
        .map((p) => {
          const lp = localizePost(p.post, allRawPosts, locale)
          return { id: p.post.id, data: lp.data }
        })
    : []

const ogImage = new URL(`/blog/og/${baseSlug}.png`, Astro.site).href
const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  ...(post.data.lastUpdated && {
    dateModified: post.data.lastUpdated.toISOString(),
  }),
  ...(ogImage && { image: ogImage }),
  ...(author && {
    author: {
      '@type': 'Person',
      name: author.name,
      ...(author.url && { url: author.url }),
      ...([author.github, author.twitter].filter(Boolean).length > 0 && {
        sameAs: [author.github, author.twitter].filter(Boolean),
      }),
    },
  }),
  publisher: {
    '@type': 'Organization',
    name: 'Acecore',
    url: 'https://acecore.net',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://acecore.net/blog/${baseSlug}/`,
  },
  inLanguage: htmlLangMap[locale],
}

const faqLd = post.data.faq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.data.faq.items.map(
        (item: { question: string; answer: string }) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        }),
      ),
    }
  : null

const jsonLdData = faqLd ? [blogPostingLd, faqLd] : blogPostingLd

const tags = post.data.tags ?? []

const ctaHeading = isDefaultLocale
  ? (() => {
      const variants = [
        {
          match: ['教育', 'Acecore Schools'],
          heading: 'ITスクールに興味がありますか？',
          body: 'Acecore Schools では、初心者から経験者まで実践的に学べるカリキュラムをご用意しています。',
          primary: { label: 'スクール詳細を見る', href: '/schools/' },
          secondary: { label: 'お問い合わせ', href: '/contact/' },
        },
        {
          match: ['インフラ', 'DNS', 'メール', 'Cloudflare', 'セキュリティ'],
          heading: '運用・インフラのお悩みはありませんか？',
          body: 'サーバー構築からメール移行、セキュリティ対策まで、安定運用をサポートします。',
          primary: { label: 'サービス一覧', href: '/services/' },
          secondary: { label: '無料で相談する', href: '/contact/' },
        },
        {
          match: ['システム開発', 'Web制作', 'Astro'],
          heading: '開発・Web制作のご相談はお気軽に',
          body: '要件整理からデザイン・実装・運用まで、ワンストップでサポートします。',
          primary: { label: 'サービス一覧', href: '/services/' },
          secondary: { label: 'お問い合わせ', href: '/contact/' },
        },
      ]
      const defaultCta = {
        heading: 'ご相談・ご依頼はお気軽に',
        body: '記事の内容に関するご質問や、サービスについてのご相談をお待ちしています。',
        primary: { label: 'お問い合わせ', href: '/contact/' },
        secondary: { label: 'サービス一覧', href: '/services/' },
      }
      return (
        variants.find((v) => tags.some((tg: string) => v.match.includes(tg))) ??
        defaultCta
      )
    })()
  : {
      heading: t(locale, 'blog.blogCtaHeading'),
      body: t(locale, 'blog.blogCtaBody'),
      primary: { label: t(locale, 'blog.blogCtaServices'), href: u('/services/') },
      secondary: { label: t(locale, 'blog.blogCtaContact'), href: u('/contact/') },
    }
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  ogType="article"
  jsonLd={jsonLdData}
  publishedTime={post.data.date}
  modifiedTime={post.data.lastUpdated}
  tags={post.data.tags}
  author={author?.name}
  locale={locale}
  preloadImage={post.data.image ? { src: optimizeImage(post.data.image), srcset: generateSrcSet(post.data.image, [400, 800, 1200]), sizes: '(min-width: 768px) 56rem, 100vw' } : undefined}
>
  <div class="ac-section">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:grid lg:grid-cols-[1fr_260px] lg:gap-8 xl:grid-cols-[200px_1fr_280px]"
    >
      <aside class="hidden xl:block" aria-label={t(locale, 'blog.toc')}>
        <div class="sticky top-20">
          <TableOfContents headings={tocHeadings} locale={locale} />
        </div>
      </aside>
      <article class="min-w-0" {...(isDefaultLocale ? { 'data-pagefind-body': true } : {})}>
        {
          isDefaultLocale && (
            <div class="hidden" aria-hidden="true">
              {author && <span data-pagefind-filter="著者">{author.name}</span>}
              <span data-pagefind-filter="年">{post.data.date.getFullYear()}</span>
              {post.data.tags?.map((tag: string) => (
                <span data-pagefind-filter="タグ">{tag}</span>
              ))}
            </div>
          )
        }
        <div class="mb-8">
          <Breadcrumb
            items={[
              { label: t(locale, 'blog.title'), href: u('/blog/') },
              { label: post.data.title },
            ]}
            locale={locale}
          />
          <h1 class="text-3xl sm:text-4xl ac-heading mb-4">
            {post.data.title}
          </h1>
          <div class="flex items-center gap-3 text-sm text-slate-500">
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date, locale)}
            </time>
            {
              post.data.lastUpdated && (
                <span class="flex items-center gap-1">
                  <span
                    class="i-lucide-refresh-cw text-xs"
                    aria-hidden="true"
                  />
                  <time datetime={post.data.lastUpdated.toISOString()}>
                    {formatDate(post.data.lastUpdated, locale)}
                  </time>
                </span>
              )
            }
            {
              author && (
                <a href={u(`/blog/authors/${post.data.author}/`)} class="ac-link">
                  by {author.name}
                </a>
              )
            }
          </div>
          {
            post.data.tags && (
              <div class="flex flex-wrap gap-2 mt-4" data-pagefind-ignore>
                {post.data.tags.map((tag: string) => (
                  <a
                    href={u(`/blog/tags/${tag}/`)}
                    class="text-xs bg-brand-50 text-brand-600 px-2 py-1 rounded-full hover:bg-brand-100 transition-colors"
                  >
                    {translateTag(tag, locale)}
                  </a>
                ))}
              </div>
            )
          }
        </div>
        {
          tocHeadings.length > 0 && (
            <details class="lg:hidden mb-8 ac-card p-4" data-pagefind-ignore>
              <summary class="text-sm font-700 text-slate-700 cursor-pointer flex items-center gap-2">
                <div class="i-lucide-list text-sm" aria-hidden="true" />
                {t(locale, 'blog.toc')}
              </summary>
              <ul class="mt-3 space-y-1 text-sm border-l-2 border-slate-200 ml-1">
                {tocHeadings.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="block py-1 text-slate-500 hover:text-brand-500 transition-colors"
                      style={`padding-left: ${(h.depth - 2) * 12 + 12}px`}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          )
        }
        {
          post.data.image && (
            <div class="mb-8 rounded-xl overflow-hidden">
              <img
                src={optimizeImage(post.data.image)}
                srcset={generateSrcSet(post.data.image, [400, 800, 1200])}
                sizes="(min-width: 768px) 56rem, 100vw"
                alt={post.data.title}
                class="w-full h-auto"
                width="960"
                height="400"
                decoding="async"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          )
        }
        {post.data.callout && <Callout {...post.data.callout} />}
        {post.data.insightGrid && <InsightGrid {...post.data.insightGrid} />}
        <div class="ac-prose max-w-none">
          <Content />
        </div>
        {post.data.timeline && <Timeline {...post.data.timeline} locale={locale} />}
        {
          post.data.processFigure && (
            <ProcessFigure {...post.data.processFigure} />
          )
        }
        {post.data.compareTable && <CompareTable {...post.data.compareTable} />}
        {post.data.gallery && <Gallery {...post.data.gallery} />}
        {post.data.youtube && <YouTubeEmbed {...post.data.youtube} locale={locale} />}
        {post.data.checklist && <Checklist {...post.data.checklist} />}
        {post.data.testimonials?.map((testimonial) => <Testimonial {...testimonial} />)}
        {post.data.pullQuote && <PullQuote {...post.data.pullQuote} />}
        {post.data.linkCards?.map((lc) => <LinkCard {...lc} />)}
        {post.data.faq && <Faq {...post.data.faq} />}
        <div class="my-8" data-pagefind-ignore>
          <AdUnit />
        </div>

        <div class="my-8 py-6 border-t border-slate-200">
          <ShareButtons
            url={`https://acecore.net/blog/${baseSlug}/`}
            title={post.data.title}
            locale={locale}
          />
        </div>

        {
          author && (
            <div
              class="lg:hidden mt-12 pt-8 border-t border-slate-200"
              data-pagefind-ignore
            >
              <div class="flex items-start gap-4">
                {author.avatarImage || author.avatar ? (
                  <img
                    src={author.avatarImage || author.avatar}
                    alt={author.name}
                    class="w-16 h-16 rounded-full object-cover shrink-0"
                    width="64"
                    height="64"
                    decoding="async"
                  />
                ) : (
                  <div class="w-16 h-16 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xl font-700 shrink-0">
                    {author.name.charAt(0)}
                  </div>
                )}
                <div>
                  <h3 class="font-700 text-lg text-slate-900">
                    <a
                      href={u(`/blog/authors/${post.data.author}/`)}
                      class="no-underline text-inherit hover:text-brand-500 transition-colors"
                    >
                      {author.name}
                    </a>
                  </h3>
                  {author.bio && (
                    <p class="text-sm text-slate-600 mt-1 whitespace-pre-line">
                      {author.bio}
                    </p>
                  )}
                  {author.skills?.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {author.skills.map((skill: string) => (
                        <span class="text-xs bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">
                          {skill}
                        </span>
                      ))}
                    </div>
                  )}
                  {(author.github || author.twitter) && (
                    <div class="flex items-center gap-3 mt-3">
                      {author.github && (
                        <a
                          href={author.github}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-slate-400 hover:text-slate-600 transition-colors"
                          aria-label="GitHub"
                        >
                          <div
                            class="i-lucide-github text-lg"
                            aria-hidden="true"
                          />
                        </a>
                      )}
                      {author.twitter && (
                        <a
                          href={author.twitter}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-slate-400 hover:text-slate-600 transition-colors"
                          aria-label="X"
                        >
                          <div
                            class="i-lucide-twitter text-lg"
                            aria-hidden="true"
                          />
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>
          )
        }

        <div
          class="mt-12 pt-8 border-t border-slate-200 bg-brand-50 rounded-xl p-6 sm:p-8 text-center"
          data-pagefind-ignore
        >
          <p class="text-lg font-700 text-slate-800 mb-2">
            {ctaHeading.heading}
          </p>
          <p class="text-sm text-slate-600 mb-4">{ctaHeading.body}</p>
          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-3"
          >
            <a href={isDefaultLocale ? ctaHeading.primary.href : u(ctaHeading.primary.href)} class="ac-btn-primary"
              >{ctaHeading.primary.label}</a
            >
            <a href={isDefaultLocale ? ctaHeading.secondary.href : u(ctaHeading.secondary.href)} class="ac-btn-outline"
              >{ctaHeading.secondary.label}</a
            >
          </div>
        </div>

        {
          relatedPosts.length > 0 && (
            <section
              class="mt-12 pt-8 border-t border-slate-200"
              data-pagefind-ignore
            >
              <h2 class="text-xl font-700 text-slate-800 mb-6 flex items-center gap-2">
                <div
                  class="i-lucide-newspaper text-lg text-brand-500"
                  aria-hidden="true"
                />
                {t(locale, 'blog.relatedPosts')}
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {relatedPosts.map((rp, i) => (
                  <Fragment>
                    {i === 2 && (
                      <div class="sm:col-span-2">
                        <AdUnit />
                      </div>
                    )}
                    <a
                      href={u(`/blog/${rp.id}/`)}
                      class="group flex flex-col p-4 rounded-lg border border-slate-200 hover:border-brand-300 hover:shadow-sm transition-all"
                    >
                      {rp.data.image && (
                        <img
                          src={optimizeImage(rp.data.image)}
                          srcset={generateSrcSet(rp.data.image, [200, 400])}
                          sizes="(min-width: 640px) 50vw, 100vw"
                          alt={rp.data.title}
                          class="w-full h-32 object-cover rounded-md mb-3"
                          width="400"
                          height="128"
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                      <span class="text-sm font-700 text-slate-700 group-hover:text-brand-600 transition-colors line-clamp-2">
                        {rp.data.title}
                      </span>
                      <span class="text-xs text-slate-600 mt-1">
                        {formatDate(rp.data.date, locale)}
                      </span>
                      {rp.data.tags && (
                        <div class="flex flex-wrap gap-1 mt-2">
                          {rp.data.tags.slice(0, 3).map((tag: string) => (
                            <span class="text-[10px] bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">
                              {translateTag(tag, locale)}
                            </span>
                          ))}
                        </div>
                      )}
                    </a>
                  </Fragment>
                ))}
              </div>
            </section>
          )
        }

        {
          (prevPost || nextPost) && (
            <nav
              class="mt-8 pt-8 border-t border-slate-200 grid grid-cols-1 sm:grid-cols-2 gap-4"
              aria-label={t(locale, 'blog.postNavLabel')}
              data-pagefind-ignore
            >
              {prevPost ? (
                <a
                  href={u(`/blog/${prevPost.id}/`)}
                  class="group flex flex-col p-4 rounded-lg border border-slate-200 hover:border-brand-300 transition-colors"
                >
                  <span class="text-xs text-slate-600 mb-1">{t(locale, 'blog.prevPost')}</span>
                  <span class="text-sm font-700 text-slate-700 group-hover:text-brand-600 transition-colors">
                    {prevPost.data.title}
                  </span>
                </a>
              ) : (
                <div />
              )}
              {nextPost && (
                <a
                  href={u(`/blog/${nextPost.id}/`)}
                  class="group flex flex-col p-4 rounded-lg border border-slate-200 hover:border-brand-300 transition-colors sm:text-right"
                >
                  <span class="text-xs text-slate-600 mb-1">{t(locale, 'blog.nextPost')}</span>
                  <span class="text-sm font-700 text-slate-700 group-hover:text-brand-600 transition-colors">
                    {nextPost.data.title}
                  </span>
                </a>
              )}
            </nav>
          )
        }
        <CopyCodeButton locale={locale} />
      </article>
      <aside class="hidden lg:block" aria-label={t(locale, 'blog.sidebar')}>
        <div class="sticky top-20 space-y-6">
          {
            tocHeadings.length > 0 && (
              <div class="xl:hidden">
                <TableOfContents headings={tocHeadings} locale={locale} />
              </div>
            )
          }
          {
            author && (
              <div class="ac-card p-5">
                <div class="flex items-center gap-3 mb-3">
                  {author.avatarImage || author.avatar ? (
                    <img
                      src={author.avatarImage || author.avatar}
                      alt={author.name}
                      class="w-12 h-12 rounded-full object-cover shrink-0"
                      width="48"
                      height="48"
                      decoding="async"
                    />
                  ) : (
                    <div class="w-12 h-12 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-lg font-700 shrink-0">
                      {author.name.charAt(0)}
                    </div>
                  )}
                  <div>
                    <p class="font-700 text-sm text-slate-900">
                      <a
                        href={u(`/blog/authors/${post.data.author}/`)}
                        class="no-underline text-inherit hover:text-brand-500 transition-colors"
                      >
                        {author.name}
                      </a>
                    </p>
                  </div>
                </div>
                {author.bio && (
                  <p class="text-xs text-slate-600 leading-relaxed whitespace-pre-line mb-3">
                    {author.bio}
                  </p>
                )}
                {author.skills?.length > 0 && (
                  <div class="flex flex-wrap gap-1 mb-3">
                    {author.skills.map((skill: string) => (
                      <span class="text-[10px] bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">
                        {skill}
                      </span>
                    ))}
                  </div>
                )}
                {(author.github || author.twitter) && (
                  <div class="flex items-center gap-2 pt-2 border-t border-slate-100">
                    {author.github && (
                      <a
                        href={author.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-slate-400 hover:text-slate-600 transition-colors"
                        aria-label="GitHub"
                      >
                        <div
                          class="i-lucide-github text-base"
                          aria-hidden="true"
                        />
                      </a>
                    )}
                    {author.twitter && (
                      <a
                        href={author.twitter}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-slate-400 hover:text-slate-600 transition-colors"
                        aria-label="X"
                      >
                        <div
                          class="i-lucide-twitter text-base"
                          aria-hidden="true"
                        />
                      </a>
                    )}
                  </div>
                )}
              </div>
            )
          }
          <AdUnit adSlot="4541792182" />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
