---
import '../styles/prose.css'
import BaseLayout from '../layouts/BaseLayout.astro'
import { render } from 'astro:content'
import {
  optimizeImage,
  generateSrcSet,
  resolveImageSource,
} from '../utils/image'
import Callout from '../components/Callout.astro'
import Timeline from '../components/Timeline.astro'
import YouTubeEmbed from '../components/YouTubeEmbed.astro'
import Faq from '../components/Faq.astro'
import Gallery from '../components/Gallery.astro'
import LinkCard from '../components/LinkCard.astro'
import ProcessFigure from '../components/ProcessFigure.astro'
import CompareTable from '../components/CompareTable.astro'
import Checklist from '../components/Checklist.astro'
import InsightGrid from '../components/InsightGrid.astro'
import Testimonial from '../components/Testimonial.astro'
import PullQuote from '../components/PullQuote.astro'
import AdUnit from '../components/AdUnit.astro'
import TableOfContents from '../components/TableOfContents.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import Icon from '../components/Icon.astro'
import ShareButtons from '../components/ShareButtons.astro'
import CopyCodeButton from '../components/CopyCodeButton.astro'
import BlogComments from '../components/BlogComments.astro'
import {
  t,
  getLocalizedUrl,
  getTranslationValue,
  formatDate,
  getDateParts,
  defaultLocale,
  htmlLangMap,
  type Locale,
} from '../i18n'
import { getCollection } from 'astro:content'
import {
  localizePost,
  isBasePost,
  getLocalizedAuthor,
} from '../utils/blog-i18n'
import { getAllAuthors, findAuthorById } from '../utils/authors'
import { getAllTags, getLocalizedTagName } from '../utils/tags'

import type { CollectionEntry } from 'astro:content'

interface Props {
  locale: Locale
  post: CollectionEntry<'blog'>
  allPosts: CollectionEntry<'blog'>[]
}

interface FeaturePricingItem {
  icon: string
  title: string
  price: string
  body: string
  href: string
}

const { locale, post: basePost, allPosts } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const isDefaultLocale = locale === defaultLocale

const allRawPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const authors = await getAllAuthors()
const tagsData = await getAllTags()
const post = localizePost(basePost, allRawPosts, locale)
const baseSlug = basePost.id
const normalizeInternalPath = (href: string) => {
  const withoutOrigin = href.trim().replace(/^https?:\/\/[^/]+/i, '')
  const withoutLocale = withoutOrigin.replace(
    /^\/(?:en|zh-cn|es|pt|fr|ko|de|ru)(?=\/)/,
    '',
  )
  return withoutLocale.endsWith('/') ? withoutLocale : `${withoutLocale}/`
}
const featurePricingItems =
  getTranslationValue<FeaturePricingItem[]>(locale, 'pages.pricing.items') ?? []
const featurePricingItem = featurePricingItems.find(
  (item) => normalizeInternalPath(item.href) === `/blog/${baseSlug}/`,
)
const featurePricingUrl = u('/pricing/')
const featureServiceUrl = u('/services/#web')
const featureContactUrl = `${u('/contact/')}?category=service&service=web#contact-form`

const { Content, headings } = await render(post)
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3)
const rawAuthor = findAuthorById(authors, post.data.author)
const author = rawAuthor ? getLocalizedAuthor(rawAuthor, locale) : null
const authorSkills = author?.skills ?? []
const postImage = resolveImageSource(post.data.uploadedImage, post.data.image)
const relatedImageWidths = [320, 640, 960, 1200]
const relatedImageOptions = { aspectRatio: 16 / 9, quality: 80 }

const basePosts = allRawPosts.filter(isBasePost)

const currentIndex = basePosts.findIndex((p) => p.id === baseSlug)
const prevBasePost =
  currentIndex < basePosts.length - 1 ? basePosts[currentIndex + 1] : null
const nextBasePost = currentIndex > 0 ? basePosts[currentIndex - 1] : null
const prevPost = prevBasePost
  ? {
      id: prevBasePost.id,
      data: localizePost(prevBasePost, allRawPosts, locale).data,
    }
  : null
const nextPost = nextBasePost
  ? {
      id: nextBasePost.id,
      data: localizePost(nextBasePost, allRawPosts, locale).data,
    }
  : null

const currentTags = post.data.tags ?? []
const relatedPosts =
  currentTags.length > 0
    ? basePosts
        .filter((p) => p.id !== baseSlug)
        .map((p) => ({
          post: p,
          score: (p.data.tags ?? []).filter((tag: string) =>
            currentTags.includes(tag),
          ).length,
        }))
        .filter((p) => p.score > 0)
        .sort(
          (a, b) =>
            b.score - a.score ||
            b.post.data.date.getTime() - a.post.data.date.getTime(),
        )
        .slice(0, 4)
        .map((p) => {
          const lp = localizePost(p.post, allRawPosts, locale)
          return { id: p.post.id, data: lp.data }
        })
    : []

const ogImage = new URL(`/blog/og/${baseSlug}.png`, Astro.site).href
const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  ...(post.data.lastUpdated && {
    dateModified: post.data.lastUpdated.toISOString(),
  }),
  ...(ogImage && { image: ogImage }),
  ...(author && {
    author: {
      '@type': 'Person',
      name: author.name,
      ...(author.url && { url: author.url }),
      ...([author.github, author.twitter].filter(Boolean).length > 0 && {
        sameAs: [author.github, author.twitter].filter(Boolean),
      }),
    },
  }),
  publisher: {
    '@type': 'Organization',
    name: 'Acecore',
    url: 'https://acecore.net',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://acecore.net/blog/${baseSlug}/`,
  },
  inLanguage: htmlLangMap[locale],
}

const faqLd = post.data.faq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.data.faq.items.map(
        (item: { question: string; answer: string }) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        }),
      ),
    }
  : null

const jsonLdData = faqLd ? [blogPostingLd, faqLd] : blogPostingLd

const tags = post.data.tags ?? []

const ctaHeading = isDefaultLocale
  ? (() => {
      const variants = [
        {
          match: ['教育', 'Acecore Schools'],
          heading: 'ITスクールに興味がありますか？',
          body: 'Acecore Schools では、初心者から経験者まで実践的に学べるカリキュラムをご用意しています。',
          primary: { label: 'スクール詳細を見る', href: '/schools/' },
          secondary: { label: 'お問い合わせ', href: '/contact/' },
        },
        {
          match: ['インフラ', 'DNS', 'メール', 'Cloudflare', 'セキュリティ'],
          heading: '運用・インフラのお悩みはありませんか？',
          body: 'サーバー構築からメール移行、セキュリティ対策まで、安定運用をサポートします。',
          primary: { label: 'サービス一覧', href: '/services/' },
          secondary: { label: '無料で相談する', href: '/contact/' },
        },
        {
          match: ['システム開発', 'Web制作', 'Astro'],
          heading: '開発・Web制作のご相談はお気軽に',
          body: '要件整理からデザイン・実装・運用まで、ワンストップでサポートします。',
          primary: { label: 'サービス一覧', href: '/services/' },
          secondary: { label: 'お問い合わせ', href: '/contact/' },
        },
      ]
      const defaultCta = {
        heading: 'ご相談・ご依頼はお気軽に',
        body: '記事の内容に関するご質問や、サービスについてのご相談をお待ちしています。',
        primary: { label: 'お問い合わせ', href: '/contact/' },
        secondary: { label: 'サービス一覧', href: '/services/' },
      }
      return (
        variants.find((v) => tags.some((tg: string) => v.match.includes(tg))) ??
        defaultCta
      )
    })()
  : {
      heading: t(locale, 'blog.blogCtaHeading'),
      body: t(locale, 'blog.blogCtaBody'),
      primary: {
        label: t(locale, 'blog.blogCtaServices'),
        href: u('/services/'),
      },
      secondary: {
        label: t(locale, 'blog.blogCtaContact'),
        href: u('/contact/'),
      },
    }
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  ogType="article"
  jsonLd={jsonLdData}
  publishedTime={post.data.date}
  modifiedTime={post.data.lastUpdated}
  tags={post.data.tags}
  author={author?.name}
  locale={locale}
  preloadImage={postImage
    ? {
        src: optimizeImage(postImage),
        srcset: generateSrcSet(postImage, [480, 800, 1200, 1600]),
        sizes: '(min-width: 768px) 56rem, calc(100vw - 2rem)',
      }
    : undefined}
>
  <div class="ac-section">
    <div
      class="mx-auto box-border w-full max-w-[78rem] px-5 sm:px-6 lg:grid lg:grid-cols-[minmax(0,1fr)_280px] lg:gap-10 lg:px-8 xl:grid-cols-[220px_minmax(0,48rem)_280px]"
    >
      <aside class="hidden xl:block" aria-label={t(locale, 'blog.toc')}>
        <div class="sticky top-20">
          <TableOfContents headings={tocHeadings} locale={locale} />
        </div>
      </aside>
      <article
        class="min-w-0 w-full max-w-3xl"
        {...isDefaultLocale ? { 'data-pagefind-body': true } : {}}
      >
        {
          isDefaultLocale && (
            <div class="hidden" aria-hidden="true">
              {author && <span data-pagefind-filter="著者">{author.name}</span>}
              <span data-pagefind-filter="年">
                {getDateParts(post.data.date).year}
              </span>
              {post.data.tags?.map((tag: string) => (
                <span data-pagefind-filter="タグ">{tag}</span>
              ))}
            </div>
          )
        }
        <div class="mb-9">
          <Breadcrumb
            items={[
              { label: t(locale, 'blog.title'), href: u('/blog/') },
              { label: post.data.title },
            ]}
            locale={locale}
          />
          <h1
            class="mb-5 max-w-full break-words text-3xl ac-heading sm:text-4xl"
          >
            {post.data.title}
          </h1>
          <div
            class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500"
          >
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date, locale)}
            </time>
            {
              post.data.lastUpdated && (
                <span class="flex items-center gap-1">
                  <Icon name="refresh-cw" class="text-xs" />
                  <time datetime={post.data.lastUpdated.toISOString()}>
                    {formatDate(post.data.lastUpdated, locale)}
                  </time>
                </span>
              )
            }
            {
              author && (
                <a
                  href={u(`/blog/authors/${post.data.author}/`)}
                  class="ac-link"
                >
                  by {author.name}
                </a>
              )
            }
          </div>
          {
            post.data.tags && (
              <div class="mt-5 flex flex-wrap gap-2" data-pagefind-ignore>
                {post.data.tags.map((tag: string) => (
                  <a
                    href={u(`/blog/tags/${tag}/`)}
                    class="ac-chip border-brand-100 bg-brand-50 text-brand-600"
                  >
                    {getLocalizedTagName(tagsData, tag, locale)}
                  </a>
                ))}
              </div>
            )
          }
        </div>
        {
          tocHeadings.length > 0 && (
            <details class="mb-8 ac-card p-5 lg:hidden" data-pagefind-ignore>
              <summary class="flex min-h-11 cursor-pointer items-center gap-2 text-sm font-700 text-slate-700">
                <Icon name="list" class="text-sm" />
                {t(locale, 'blog.toc')}
              </summary>
              <ul class="ml-1 mt-3 space-y-1 border-l-2 border-slate-200 text-sm">
                {tocHeadings.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="block rounded-r-md py-2 text-slate-500 transition-colors hover:bg-brand-50 hover:text-brand-600"
                      style={`padding-left: ${(h.depth - 2) * 12 + 12}px`}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          )
        }
        {
          postImage && (
            <div class="mb-9 overflow-hidden rounded-lg">
              <img
                src={optimizeImage(postImage)}
                srcset={generateSrcSet(postImage, [480, 800, 1200, 1600])}
                sizes="(min-width: 768px) 56rem, calc(100vw - 2rem)"
                alt={post.data.title}
                class="w-full h-auto"
                width="960"
                height="400"
                decoding="async"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          )
        }
        {post.data.callout && <Callout {...post.data.callout} />}
        {post.data.insightGrid && <InsightGrid {...post.data.insightGrid} />}
        <div class="ac-prose max-w-none">
          <Content />
        </div>
        {
          post.data.timeline && (
            <Timeline {...post.data.timeline} locale={locale} />
          )
        }
        {
          post.data.processFigure && (
            <ProcessFigure {...post.data.processFigure} />
          )
        }
        {post.data.compareTable && <CompareTable {...post.data.compareTable} />}
        {post.data.gallery && <Gallery {...post.data.gallery} />}
        {
          post.data.youtube && (
            <YouTubeEmbed {...post.data.youtube} locale={locale} />
          )
        }
        {post.data.checklist && <Checklist {...post.data.checklist} />}
        {
          post.data.testimonials?.map((testimonial) => (
            <Testimonial {...testimonial} />
          ))
        }
        {post.data.pullQuote && <PullQuote {...post.data.pullQuote} />}
        {post.data.linkCards?.map((lc) => <LinkCard {...lc} />)}
        {
          featurePricingItem && (
            <aside class="not-prose my-8 rounded-lg border border-brand-100 bg-brand-50/60 p-5">
              <div class="flex items-start gap-4">
                <span class="ac-icon-box shrink-0">
                  <Icon name={featurePricingItem.icon} class="text-lg" />
                </span>
                <div class="min-w-0">
                  <p class="text-xs font-800 uppercase tracking-wider text-brand-600">
                    {t(locale, 'blog.featurePricingEyebrow')}
                  </p>
                  <h2 class="mt-1 text-xl ac-heading">
                    {t(locale, 'blog.featurePricingTitle', {
                      title: featurePricingItem.title,
                    })}
                  </h2>
                  <p class="mt-2 text-sm leading-relaxed text-slate-600">
                    {featurePricingItem.body}
                  </p>
                </div>
              </div>
              <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:flex-wrap">
                <div class="rounded-lg bg-white px-4 py-3 text-sm">
                  <span class="mr-2 text-slate-500">
                    {t(locale, 'blog.featurePricingPriceLabel')}
                  </span>
                  <strong class="text-base text-slate-900">
                    {featurePricingItem.price}
                  </strong>
                </div>
                <a
                  href={featureServiceUrl}
                  class="ac-btn-outline gap-2 text-sm"
                >
                  <Icon name="globe" class="text-sm" />
                  {t(locale, 'blog.featurePricingServices')}
                </a>
                <a
                  href={featurePricingUrl}
                  class="ac-btn-outline gap-2 text-sm"
                >
                  <Icon name="receipt" class="text-sm" />
                  {t(locale, 'blog.featurePricingPricing')}
                </a>
                <a
                  href={featureContactUrl}
                  class="ac-btn-primary gap-2 text-sm"
                >
                  <Icon name="message-circle" class="text-sm" />
                  {t(locale, 'blog.featurePricingContact')}
                </a>
              </div>
            </aside>
          )
        }
        {post.data.faq && <Faq {...post.data.faq} />}
        <AdUnit containerClass="my-6" />

        <div class="my-10 border-t border-slate-200 py-6">
          <ShareButtons
            url={`https://acecore.net/blog/${baseSlug}/`}
            title={post.data.title}
            locale={locale}
          />
        </div>

        <BlogComments locale={locale} slug={baseSlug} />

        {
          author && (
            <div
              class="mt-12 border-t border-slate-200 pt-8 lg:hidden"
              data-pagefind-ignore
            >
              <div class="flex items-start gap-4">
                {author.avatarImage || author.avatar ? (
                  <img
                    src={author.avatarImage || author.avatar}
                    alt={author.name}
                    class="w-16 h-16 rounded-full object-cover shrink-0"
                    width="64"
                    height="64"
                    decoding="async"
                  />
                ) : (
                  <div class="w-16 h-16 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xl font-700 shrink-0">
                    {author.name.charAt(0)}
                  </div>
                )}
                <div>
                  <h3 class="font-700 text-lg text-slate-900">
                    <a
                      href={u(`/blog/authors/${post.data.author}/`)}
                      class="no-underline text-inherit hover:text-brand-500 transition-colors"
                    >
                      {author.name}
                    </a>
                  </h3>
                  {author.bio && (
                    <p class="text-sm text-slate-600 mt-1 whitespace-pre-line">
                      {author.bio}
                    </p>
                  )}
                  {authorSkills.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {authorSkills.map((skill: string) => (
                        <span class="ac-chip-static">{skill}</span>
                      ))}
                    </div>
                  )}
                  {(author.github || author.twitter) && (
                    <div class="flex items-center gap-3 mt-3">
                      {author.github && (
                        <a
                          href={author.github}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="ac-touch rounded-lg text-slate-400 transition-colors hover:bg-slate-50 hover:text-slate-600"
                          aria-label="GitHub"
                        >
                          <Icon name="github" class="text-lg" />
                        </a>
                      )}
                      {author.twitter && (
                        <a
                          href={author.twitter}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="ac-touch rounded-lg text-slate-400 transition-colors hover:bg-slate-50 hover:text-slate-600"
                          aria-label="X"
                        >
                          <Icon name="twitter" class="text-lg" />
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>
          )
        }

        <div
          class="ac-surface mt-12 bg-brand-50 p-6 text-center sm:p-8"
          data-pagefind-ignore
        >
          <p class="mb-2 text-lg font-700 text-slate-800">
            {ctaHeading.heading}
          </p>
          <p class="mb-5 text-sm leading-relaxed text-slate-600">
            {ctaHeading.body}
          </p>
          <div
            class="flex flex-col items-center justify-center gap-3 sm:flex-row"
          >
            <a
              href={isDefaultLocale
                ? ctaHeading.primary.href
                : u(ctaHeading.primary.href)}
              class="ac-btn-primary">{ctaHeading.primary.label}</a
            >
            <a
              href={isDefaultLocale
                ? ctaHeading.secondary.href
                : u(ctaHeading.secondary.href)}
              class="ac-btn-outline">{ctaHeading.secondary.label}</a
            >
          </div>
        </div>

        {
          relatedPosts.length > 0 && (
            <section
              class="mt-12 border-t border-slate-200 pt-8"
              data-pagefind-ignore
            >
              <h2 class="mb-6 flex items-center gap-2 text-xl font-700 text-slate-800">
                <Icon name="newspaper" class="text-lg text-brand-500" />
                {t(locale, 'blog.relatedPosts')}
              </h2>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                {relatedPosts.map((rp, i) => {
                  const relatedImage = resolveImageSource(
                    rp.data.uploadedImage,
                    rp.data.image,
                  )

                  return (
                    <Fragment>
                      {i === 2 && (
                        <AdUnit containerClass="my-1 sm:col-span-2" />
                      )}
                      <a
                        href={u(`/blog/${rp.id}/`)}
                        class="group flex flex-col rounded-lg border border-slate-200 p-4 no-underline transition-all hover:border-brand-300 hover:shadow-sm"
                      >
                        {relatedImage && (
                          <img
                            src={optimizeImage(relatedImage, {
                              width: 800,
                              height: 400,
                              quality: 80,
                            })}
                            srcset={generateSrcSet(
                              relatedImage,
                              relatedImageWidths,
                              relatedImageOptions,
                            )}
                            sizes="(min-width: 640px) 50vw, 100vw"
                            alt={rp.data.title}
                            class="mb-3 h-32 w-full rounded-md object-cover"
                            width="800"
                            height="400"
                            loading="lazy"
                            decoding="async"
                          />
                        )}
                        <span class="text-sm font-700 text-slate-700 group-hover:text-brand-600 transition-colors line-clamp-2">
                          {rp.data.title}
                        </span>
                        <span class="text-xs text-slate-600 mt-1">
                          {formatDate(rp.data.date, locale)}
                        </span>
                        {rp.data.tags && (
                          <div class="mt-3 flex flex-wrap gap-2">
                            {rp.data.tags.slice(0, 3).map((tag: string) => (
                              <span class="ac-chip-static">
                                {getLocalizedTagName(tagsData, tag, locale)}
                              </span>
                            ))}
                          </div>
                        )}
                      </a>
                    </Fragment>
                  )
                })}
              </div>
            </section>
          )
        }

        {
          (prevPost || nextPost) && (
            <nav
              class="mt-8 grid grid-cols-1 gap-4 border-t border-slate-200 pt-8 sm:grid-cols-2"
              aria-label={t(locale, 'blog.postNavLabel')}
              data-pagefind-ignore
            >
              {prevPost ? (
                <a
                  href={u(`/blog/${prevPost.id}/`)}
                  class="group flex flex-col rounded-lg border border-slate-200 p-5 no-underline transition-colors hover:border-brand-300 hover:bg-brand-50"
                >
                  <span class="text-xs text-slate-600 mb-1">
                    {t(locale, 'blog.prevPost')}
                  </span>
                  <span class="text-sm font-700 text-slate-700 group-hover:text-brand-600 transition-colors">
                    {prevPost.data.title}
                  </span>
                </a>
              ) : (
                <div />
              )}
              {nextPost && (
                <a
                  href={u(`/blog/${nextPost.id}/`)}
                  class="group flex flex-col rounded-lg border border-slate-200 p-5 no-underline transition-colors hover:border-brand-300 hover:bg-brand-50 sm:text-right"
                >
                  <span class="text-xs text-slate-600 mb-1">
                    {t(locale, 'blog.nextPost')}
                  </span>
                  <span class="text-sm font-700 text-slate-700 group-hover:text-brand-600 transition-colors">
                    {nextPost.data.title}
                  </span>
                </a>
              )}
            </nav>
          )
        }
        <CopyCodeButton locale={locale} />
      </article>
      <aside class="hidden lg:block" aria-label={t(locale, 'blog.sidebar')}>
        <div class="sticky top-20 space-y-6">
          {
            tocHeadings.length > 0 && (
              <div class="xl:hidden">
                <TableOfContents headings={tocHeadings} locale={locale} />
              </div>
            )
          }
          {
            author && (
              <div class="ac-card p-5">
                <div class="flex items-center gap-3 mb-3">
                  {author.avatarImage || author.avatar ? (
                    <img
                      src={author.avatarImage || author.avatar}
                      alt={author.name}
                      class="w-12 h-12 rounded-full object-cover shrink-0"
                      width="48"
                      height="48"
                      decoding="async"
                    />
                  ) : (
                    <div class="w-12 h-12 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-lg font-700 shrink-0">
                      {author.name.charAt(0)}
                    </div>
                  )}
                  <div>
                    <p class="font-700 text-sm text-slate-900">
                      <a
                        href={u(`/blog/authors/${post.data.author}/`)}
                        class="no-underline text-inherit hover:text-brand-500 transition-colors"
                      >
                        {author.name}
                      </a>
                    </p>
                  </div>
                </div>
                {author.bio && (
                  <p class="text-xs text-slate-600 leading-relaxed whitespace-pre-line mb-3">
                    {author.bio}
                  </p>
                )}
                {authorSkills.length > 0 && (
                  <div class="flex flex-wrap gap-1 mb-3">
                    {authorSkills.map((skill: string) => (
                      <span class="ac-chip-static">{skill}</span>
                    ))}
                  </div>
                )}
                {(author.github || author.twitter) && (
                  <div class="flex items-center gap-2 pt-2 border-t border-slate-100">
                    {author.github && (
                      <a
                        href={author.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="ac-touch rounded-lg text-slate-400 transition-colors hover:bg-slate-50 hover:text-slate-600"
                        aria-label="GitHub"
                      >
                        <Icon name="github" class="text-base" />
                      </a>
                    )}
                    {author.twitter && (
                      <a
                        href={author.twitter}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="ac-touch rounded-lg text-slate-400 transition-colors hover:bg-slate-50 hover:text-slate-600"
                        aria-label="X"
                      >
                        <Icon name="twitter" class="text-base" />
                      </a>
                    )}
                  </div>
                )}
              </div>
            )
          }
          <AdUnit
            adSlot="4541792182"
            containerClass="ac-card overflow-hidden p-3"
          />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
