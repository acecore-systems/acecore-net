---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import BlogPostCard from '../components/BlogPostCard.astro'
import BlogSidebar from '../components/BlogSidebar.astro'
import { getCollection } from 'astro:content'
import AdUnit from '../components/AdUnit.astro'
import { POSTS_PER_PAGE, buildPageNumbers } from '../utils/pagination'
import { t, getLocalizedUrl, type Locale } from '../i18n'
import { localizePost } from '../utils/blog-i18n'

import type { CollectionEntry } from 'astro:content'

interface Props {
  locale: Locale
  posts: CollectionEntry<'blog'>[]
  currentPage: number
  totalPages: number
  allPosts: CollectionEntry<'blog'>[]
}

const { locale, posts, currentPage, totalPages, allPosts } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const currentPagePath = u(`/blog/page/${currentPage}/`)
const breadcrumbItems = [
  { label: t(locale, 'blog.title'), href: u('/blog/') },
  { label: t(locale, 'blog.pageN', { n: currentPage }), href: currentPagePath },
]

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${t(locale, 'blog.itemListName')} - ${t(locale, 'blog.pageN', { n: currentPage })}`,
  itemListElement: posts.map((post: CollectionEntry<'blog'>, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://acecore.net${u(`/blog/${post.id}/`)}`,
  })),
}

const pageNumbers = buildPageNumbers(currentPage, totalPages)
---

<BaseLayout
  title={`${t(locale, 'blog.title')} ${t(locale, 'blog.pageOf', { current: currentPage, total: totalPages })}`}
  description={t(locale, 'blog.pageDescription', {
    current: currentPage,
    total: totalPages,
  })}
  robots="noindex, follow"
  jsonLd={itemListLd}
  prevPage={currentPage === 2
    ? u('/blog/')
    : u(`/blog/page/${currentPage - 1}/`)}
  nextPage={currentPage < totalPages
    ? u(`/blog/page/${currentPage + 1}/`)
    : undefined}
  locale={locale}
  breadcrumbItems={breadcrumbItems.map((item) => ({
    name: item.label,
    item: item.href,
  }))}
>
  <section class="ac-section">
    <div class="ac-container">
      <Breadcrumb items={breadcrumbItems} locale={locale} />
      <h1 class="mb-8 text-2xl ac-heading sm:text-3xl">
        {t(locale, 'blog.title')}
        <span class="text-base text-slate-400">
          {
            t(locale, 'blog.pageOf', {
              current: currentPage,
              total: totalPages,
            })
          }
        </span>
      </h1>
      <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_280px] lg:gap-10">
        <div>
          <div class="space-y-6">
            {
              posts.map((post, i: number) => (
                <Fragment>
                  {i > 0 && i % 3 === 0 && (
                    <AdUnit containerClass="ac-card overflow-hidden p-6" />
                  )}
                  <BlogPostCard
                    post={localizePost(post, allPosts, locale)}
                    locale={locale}
                  />
                </Fragment>
              ))
            }
          </div>

          <nav
            class="mt-10 flex flex-wrap items-center justify-center gap-2"
            aria-label={t(locale, 'blog.pageNav')}
          >
            <a
              href={currentPage === 2
                ? u('/blog/')
                : u(`/blog/page/${currentPage - 1}/`)}
              class="inline-flex min-h-11 items-center rounded-lg px-3 text-sm font-700 text-slate-600 transition-colors hover:bg-slate-50 hover:text-brand-600"
            >
              {t(locale, 'blog.prev')}
            </a>
            {
              pageNumbers.map((p) =>
                p === '...' ? (
                  <span class="px-2 text-slate-400">…</span>
                ) : p === currentPage ? (
                  <span
                    class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg bg-brand-500 px-4 text-sm font-700 text-white"
                    aria-current="page"
                  >
                    {p}
                  </span>
                ) : (
                  <a
                    href={p === 1 ? u('/blog/') : u(`/blog/page/${p}/`)}
                    class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg border border-slate-300 px-4 text-sm font-700 text-slate-600 transition-colors hover:border-brand-300 hover:bg-brand-50 hover:text-brand-600"
                  >
                    {p}
                  </a>
                ),
              )
            }
            {
              currentPage < totalPages ? (
                <a
                  href={u(`/blog/page/${currentPage + 1}/`)}
                  class="inline-flex min-h-11 items-center rounded-lg px-3 text-sm font-700 text-slate-600 transition-colors hover:bg-slate-50 hover:text-brand-600"
                >
                  {t(locale, 'blog.next')}
                </a>
              ) : (
                <span
                  class="inline-flex min-h-11 items-center px-3 text-sm text-slate-300"
                  aria-disabled="true"
                >
                  {t(locale, 'blog.next')}
                </span>
              )
            }
          </nav>
        </div>
        <BlogSidebar allPosts={allPosts} locale={locale} />
      </div>
    </div>
  </section>
</BaseLayout>
