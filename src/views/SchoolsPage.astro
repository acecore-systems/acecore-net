---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import Icon from '../components/Icon.astro'
import ProcessFigure from '../components/ProcessFigure.astro'
import CompareTable from '../components/CompareTable.astro'
import CampaignNotice from '../components/CampaignNotice.astro'
import { optimizeImage, generateSrcSet } from '../utils/image'
import { SITE } from '../data/site'
import { t, getTranslationValue, getLocalizedUrl, type Locale } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)

interface SchoolPricingItem {
  icon: string
  label: string
  price: string
  note: string
}

interface LearningStep {
  title: string
  description: string
  icon: string
  accent: string
}

interface RobotProgrammingCourse {
  title: string
  description: string
}

interface SchoolCourseDetail {
  id: string
  icon: string
  title: string
  target: string
  recommendedAge: string
  frequency: string
  schedule: string
}

interface GuardianFaq {
  question: string
  answer: string
}

const getList = <T,>(key: string): T[] =>
  getTranslationValue<T[]>(locale, key) ?? []

const learningSteps = getList<LearningStep>('pages.schools.learningSteps')

const learningCompare = {
  title: t(locale, 'pages.schools.compareTitle'),
  before: {
    label: t(locale, 'pages.schools.compareBefore'),
    items: getList<string>('pages.schools.compareBeforeItems'),
  },
  after: {
    label: t(locale, 'pages.schools.compareAfter'),
    items: getList<string>('pages.schools.compareAfterItems'),
  },
}

const jukuFeatures = getList<string>('pages.schools.juku.features')
const robotProgrammingCourses = getList<RobotProgrammingCourse>(
  'pages.schools.robotProgramming.courses',
)
const practicalProgrammingContents = getList<string>(
  'pages.schools.practicalProgramming.contents',
)
const pcSmartphoneLevels = getList<string>('pages.schools.pcSmartphone.levels')
const gedSupports = getList<string>('pages.schools.ged.supports')
const schoolPricingItems = getList<SchoolPricingItem>(
  'pages.schools.pricing.items',
)
const courseDetails = getList<SchoolCourseDetail>('pages.schools.courseDetails')
const guardianFaqs = getList<GuardianFaq>('pages.schools.guardianFaqs')
const bookingUrl = u('/schools/book/')
const portalUrl = u('/schools/portal/')

const schoolsLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'EducationalOrganization',
      name: 'Acecore Schools',
      description: t(locale, 'pages.schools.description'),
      url: 'https://acecore.net/schools/',
      parentOrganization: {
        '@type': 'Organization',
        name: 'Acecore',
        url: 'https://acecore.net',
      },
    },
    {
      '@type': 'Course',
      name: t(locale, 'pages.schools.juku.title'),
      description: t(locale, 'pages.schools.juku.desc'),
      provider: { '@type': 'EducationalOrganization', name: 'Acecore Schools' },
      url: 'https://acecore.net/schools/#juku',
    },
    {
      '@type': 'Course',
      name: t(locale, 'pages.schools.robotProgramming.title'),
      description: t(locale, 'pages.schools.robotProgramming.desc'),
      provider: { '@type': 'EducationalOrganization', name: 'Acecore Schools' },
      url: 'https://acecore.net/schools/#robot-programming',
    },
    {
      '@type': 'Course',
      name: t(locale, 'pages.schools.practicalProgramming.title'),
      description: t(locale, 'pages.schools.practicalProgramming.desc'),
      provider: { '@type': 'EducationalOrganization', name: 'Acecore Schools' },
      url: 'https://acecore.net/schools/#practical-programming',
    },
    {
      '@type': 'Course',
      name: t(locale, 'pages.schools.pcSmartphone.title'),
      description: t(locale, 'pages.schools.pcSmartphone.desc'),
      provider: { '@type': 'EducationalOrganization', name: 'Acecore Schools' },
      url: 'https://acecore.net/schools/#pc-smartphone',
    },
    {
      '@type': 'Course',
      name: t(locale, 'pages.schools.ged.title'),
      description: t(locale, 'pages.schools.ged.desc'),
      provider: { '@type': 'EducationalOrganization', name: 'Acecore Schools' },
      url: 'https://acecore.net/schools/#ged',
    },
  ],
}
---

<BaseLayout
  title={t(locale, 'pages.schools.title')}
  description={t(locale, 'pages.schools.description')}
  jsonLd={schoolsLd}
  locale={locale}
>
  <Hero
    title={t(locale, 'pages.schools.heroTitle')}
    subtitle={t(locale, 'pages.schools.heroSubtitle')}
    images={[
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: t(locale, 'pages.schools.heroImgAlt'),
      },
    ]}
  />

  <CampaignNotice locale={locale} page="schools" />

  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      <Breadcrumb
        items={[{ label: t(locale, 'pages.schools.title') }]}
        locale={locale}
      />

      <section
        class="mb-12 rounded-lg border border-brand-100 bg-brand-50 p-6 sm:p-8"
        aria-labelledby="schools-trial-heading"
      >
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p
              class="mb-2 text-sm font-800 uppercase tracking-wide text-brand-600"
            >
              {t(locale, 'pages.schools.trialEyebrow')}
            </p>
            <h2 id="schools-trial-heading" class="mb-3 text-2xl ac-heading">
              {t(locale, 'pages.schools.trialTitle')}
            </h2>
            <p class="m-0 leading-relaxed text-slate-600">
              {t(locale, 'pages.schools.trialBody')}
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a
              href={bookingUrl}
              class="ac-btn-primary"
              data-ga-event="schools_booking_click"
              data-ga-label="free_trial"
              data-ga-location="schools_first_view"
            >
              <Icon name="calendar-check" class="text-base" />
              {t(locale, 'pages.schools.trialCta')}
            </a>
            <a href={portalUrl} class="ac-btn-outline">
              <Icon name="user-check" class="text-base" />
              {t(locale, 'pages.schools.portalCta')}
            </a>
          </div>
        </div>
        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-white p-4">
            <p class="mb-1 text-sm font-800 text-slate-900">
              {t(locale, 'pages.schools.trialPoint1Title')}
            </p>
            <p class="m-0 text-sm text-slate-600">
              {t(locale, 'pages.schools.trialPoint1Body')}
            </p>
          </div>
          <div class="rounded-lg bg-white p-4">
            <p class="mb-1 text-sm font-800 text-slate-900">
              {t(locale, 'pages.schools.trialPoint2Title')}
            </p>
            <p class="m-0 text-sm text-slate-600">
              {t(locale, 'pages.schools.trialPoint2Body')}
            </p>
          </div>
          <div class="rounded-lg bg-white p-4">
            <p class="mb-1 text-sm font-800 text-slate-900">
              {t(locale, 'pages.schools.trialPoint3Title')}
            </p>
            <p class="m-0 text-sm text-slate-600">
              {t(locale, 'pages.schools.trialPoint3Body')}
            </p>
          </div>
        </div>
      </section>

      <div class="mb-12">
        <ProcessFigure
          variant="card"
          eyebrow={t(locale, 'pages.schools.learningFlowEyebrow')}
          title={t(locale, 'pages.schools.learningFlowTitle')}
          description={t(locale, 'pages.schools.learningFlowDesc')}
          steps={learningSteps}
        />
      </div>

      <p class="text-lg text-slate-600 leading-relaxed mb-12">
        {t(locale, 'pages.schools.intro')}
      </p>

      <section class="mb-16" aria-labelledby="schools-course-detail-heading">
        <div class="mb-6">
          <p
            class="mb-2 text-sm font-800 uppercase tracking-wide text-brand-600"
          >
            {t(locale, 'pages.schools.courseDetailEyebrow')}
          </p>
          <h2 id="schools-course-detail-heading" class="text-2xl ac-heading">
            {t(locale, 'pages.schools.courseDetailTitle')}
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {
            courseDetails.map((course) => (
              <article class="ac-surface p-5" id={`course-${course.id}`}>
                <div class="mb-3 flex items-center gap-3">
                  <span class="ac-icon-box">
                    <Icon name={course.icon} class="text-lg" />
                  </span>
                  <h3 class="text-lg ac-heading">{course.title}</h3>
                </div>
                <dl class="m-0 grid gap-3 text-sm">
                  <div>
                    <dt class="font-800 text-slate-900">
                      {t(locale, 'pages.schools.courseTargetLabel')}
                    </dt>
                    <dd class="m-0 text-slate-600">{course.target}</dd>
                  </div>
                  <div>
                    <dt class="font-800 text-slate-900">
                      {t(locale, 'pages.schools.courseAgeLabel')}
                    </dt>
                    <dd class="m-0 text-slate-600">{course.recommendedAge}</dd>
                  </div>
                  <div>
                    <dt class="font-800 text-slate-900">
                      {t(locale, 'pages.schools.courseFrequencyLabel')}
                    </dt>
                    <dd class="m-0 text-slate-600">{course.frequency}</dd>
                  </div>
                  <div>
                    <dt class="font-800 text-slate-900">
                      {t(locale, 'pages.schools.courseScheduleLabel')}
                    </dt>
                    <dd class="m-0 text-slate-600">{course.schedule}</dd>
                  </div>
                </dl>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Juku -->
      <div class="mb-16" id="juku">
        <div class="flex items-center gap-3 mb-4">
          <Icon name="book-open" class="text-3xl text-brand-500" />
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.schools.juku.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.schools.juku.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.schools.juku.featuresLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              jukuFeatures.map((feature) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {feature}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage(
            'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&h=450&fit=crop&q=80&fm=webp',
          )}
          srcset={generateSrcSet(
            optimizeImage(
              'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&h=450&fit=crop&q=80&fm=webp',
            ),
          )}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt={t(locale, 'pages.schools.juku.imgAlt')}
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- Robot Programming -->
      <div class="mb-16" id="robot-programming">
        <div class="flex items-center gap-3 mb-4">
          <Icon name="bot" class="text-3xl text-brand-500" />
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.schools.robotProgramming.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.schools.robotProgramming.desc')}
        </p>
        <div class="space-y-4">
          {
            robotProgrammingCourses.map((course) => (
              <div class="ac-surface bg-slate-50 p-6">
                <h3 class="font-600 text-slate-900 mb-2">{course.title}</h3>
                <p class="text-sm text-slate-600">{course.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mb-16">
        <CompareTable
          title={learningCompare.title}
          before={learningCompare.before}
          after={learningCompare.after}
        />
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage(
            'https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?w=800&h=450&fit=crop&q=80&fm=webp',
          )}
          srcset={generateSrcSet(
            optimizeImage(
              'https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?w=800&h=450&fit=crop&q=80&fm=webp',
            ),
          )}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt={t(locale, 'pages.schools.robotProgramming.progImgAlt')}
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- Practical Programming -->
      <div class="mb-16" id="practical-programming">
        <div class="flex items-center gap-3 mb-4">
          <Icon name="code-xml" class="text-3xl text-brand-500" />
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.schools.practicalProgramming.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.schools.practicalProgramming.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.schools.practicalProgramming.contentsLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              practicalProgrammingContents.map((content) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {content}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- PC / Smartphone -->
      <div class="mb-16" id="pc-smartphone">
        <div class="flex items-center gap-3 mb-4">
          <Icon name="monitor-smartphone" class="text-3xl text-brand-500" />
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.schools.pcSmartphone.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.schools.pcSmartphone.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.schools.pcSmartphone.levelsLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              pcSmartphoneLevels.map((level) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {level}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage(
            'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&h=450&fit=crop&q=80&fm=webp',
          )}
          srcset={generateSrcSet(
            optimizeImage(
              'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&h=450&fit=crop&q=80&fm=webp',
            ),
          )}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt={t(locale, 'pages.schools.pcSmartphone.imgAlt')}
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- GED -->
      <div class="mb-16" id="ged">
        <div class="flex items-center gap-3 mb-4">
          <Icon name="file-badge" class="text-3xl text-brand-500" />
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.schools.ged.title')}
          </h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          {t(locale, 'pages.schools.ged.desc')}
        </p>
        <div class="ac-surface bg-slate-50 p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">
            {t(locale, 'pages.schools.ged.supportLabel')}
          </h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            {
              gedSupports.map((support) => (
                <li class="flex items-center gap-2">
                  <Icon name="check" class="text-brand-500 shrink-0" />
                  {support}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Pricing -->
      <div class="mb-16 scroll-mt-24" id="pricing">
        <div class="mb-4 flex items-center gap-3">
          <Icon name="receipt" class="text-3xl text-brand-500" />
          <h2 class="text-2xl ac-heading">
            {t(locale, 'pages.schools.pricing.title')}
          </h2>
        </div>
        <p class="mb-6 leading-relaxed text-slate-600">
          {t(locale, 'pages.schools.pricing.body')}
        </p>
        <div class="grid gap-4 md:grid-cols-3">
          {
            schoolPricingItems.map((item) => (
              <div class="ac-surface p-5">
                <div class="mb-3 flex items-center gap-3">
                  <span class="ac-icon-box">
                    <Icon name={item.icon} class="text-lg" />
                  </span>
                  <h3 class="text-base ac-heading">{item.label}</h3>
                </div>
                <p class="mb-2 text-xl font-800 text-slate-900">{item.price}</p>
                <p class="text-sm leading-relaxed text-slate-600">
                  {item.note}
                </p>
              </div>
            ))
          }
        </div>
        <div class="ac-surface mt-6 bg-brand-50 p-6">
          <p class="mb-2 font-700 text-slate-900">
            {t(locale, 'pages.schools.pricing.ctaHeading')}
          </p>
          <p class="mb-5 text-sm leading-relaxed text-slate-600">
            {t(locale, 'pages.schools.pricing.ctaBody')}
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a href={u('/pricing/')} class="ac-btn-outline">
              {t(locale, 'pages.schools.pricing.ctaPricing')}
            </a>
            <a href={u('/contact/')} class="ac-btn-primary">
              {t(locale, 'pages.schools.pricing.ctaContact')}
            </a>
          </div>
        </div>
      </div>

      <section class="mb-16" aria-labelledby="schools-faq-heading">
        <div class="mb-6">
          <p
            class="mb-2 text-sm font-800 uppercase tracking-wide text-brand-600"
          >
            FAQ
          </p>
          <h2 id="schools-faq-heading" class="text-2xl ac-heading">
            {t(locale, 'pages.schools.guardianFaqTitle')}
          </h2>
        </div>
        <div class="space-y-3">
          {
            guardianFaqs.map((faq) => (
              <details class="rounded-lg border border-slate-200 bg-white p-5">
                <summary class="cursor-pointer font-800 text-slate-900">
                  {faq.question}
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">
                  {faq.answer}
                </p>
              </details>
            ))
          }
        </div>
      </section>

      <!-- CTA -->
      <div class="ac-surface bg-brand-50 p-8 text-center">
        <h2 class="text-xl ac-heading mb-4">
          {t(locale, 'pages.schools.ctaHeading')}
        </h2>
        <p class="text-slate-600 mb-6">
          {t(locale, 'pages.schools.ctaBody')}
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a href={bookingUrl} class="ac-btn-primary"
            >{t(locale, 'pages.schools.ctaBook')}</a
          >
          <a href={portalUrl} class="ac-btn-outline"
            >{t(locale, 'pages.schools.ctaPortal')}</a
          >
          <a
            href={SITE.line}
            target="_blank"
            rel="noopener noreferrer"
            class="ac-btn-outline"
          >
            {t(locale, 'pages.schools.ctaLine')}<span class="sr-only"
              >{t(locale, 'common.opensInNewTab')}</span
            >
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
