---
interface Props {
  headings: { depth: number; slug: string; text: string }[]
}

const { headings } = Astro.props
---

{headings.length > 0 && (
  <nav aria-label="目次">
    <p class="text-xs font-700 text-slate-400 uppercase tracking-wider mb-3">目次</p>
    <ul class="space-y-1 text-sm">
      {headings.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            class="toc-link block py-1 text-slate-500 hover:text-brand-500 transition-colors border-l-2 border-transparent hover:border-brand-300 leading-snug"
            style={`padding-left: ${(h.depth - 2) * 12 + 12}px`}
            data-slug={h.slug}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
