---
import { t, getLocaleFromUrl, type Locale } from '../i18n'

interface Props {
  headings: { depth: number; slug: string; text: string }[]
  locale?: Locale
}

const { headings } = Astro.props
const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
---

{
  headings.length > 0 && (
    <nav aria-label={t(locale, 'blog.tocLabel')} class="max-h-[calc(100vh-6rem)] overflow-y-auto">
      <p class="text-xs font-700 text-slate-400 uppercase tracking-wider mb-3">
        {t(locale, 'blog.toc')}
      </p>
      <ul class="space-y-1 text-sm">
        {headings.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class="toc-link block py-1 text-slate-500 hover:text-brand-500 transition-colors border-l-2 border-transparent hover:border-brand-300 leading-snug"
              style={`padding-left: ${(h.depth - 2) * 12 + 12}px`}
              data-slug={h.slug}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  function initTocHighlight() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
    if (!links.length) return

    const slugs = [...links].map((l) => l.dataset.slug!)
    const headingEls = slugs
      .map((s) => document.getElementById(s))
      .filter(Boolean) as HTMLElement[]
    if (!headingEls.length) return

    let activeSlug = ''

    function setActive(slug: string) {
      if (slug === activeSlug) return
      activeSlug = slug
      links.forEach((l) => {
        const isActive = l.dataset.slug === slug
        l.classList.toggle('text-brand-600', isActive)
        l.classList.toggle('border-brand-500', isActive)
        l.classList.toggle('font-600', isActive)
        l.classList.toggle('text-slate-500', !isActive)
        l.classList.toggle('border-transparent', !isActive)
        if (isActive) {
          l.scrollIntoView({ block: 'nearest', behavior: 'smooth' })
        }
      })
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id)
            break
          }
        }
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0 },
    )

    headingEls.forEach((el) => observer.observe(el))
  }

  initTocHighlight()
  document.addEventListener('astro:after-swap', initTocHighlight)
</script>
