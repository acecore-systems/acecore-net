---
interface Props {
  quote: string
  name: string
  role?: string
}

const { quote, name, role } = Astro.props
---

<figure class="not-prose my-8">
  <blockquote class="pl-4 border-l-4 border-brand-300">
    <p class="text-sm leading-relaxed text-slate-700 italic">{quote}</p>
  </blockquote>
  <figcaption class="mt-3 flex items-center gap-2.5">
    <div class="w-8 h-8 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xs font-700 shrink-0">
      {name.charAt(0)}
    </div>
    <div>
      <p class="text-sm font-600 text-slate-800">{name}</p>
      {role && <p class="text-xs text-slate-500">{role}</p>}
    </div>
  </figcaption>
</figure>
