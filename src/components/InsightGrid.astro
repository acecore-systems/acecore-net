---
interface GridItem {
  title: string
  description: string
  icon: string
  tone?: 'brand' | 'emerald' | 'amber' | 'slate'
}

interface Props {
  eyebrow?: string
  title: string
  description?: string
  items: readonly GridItem[]
  variant?: 'card' | 'inline'
}

const { eyebrow, title, description, items, variant = 'inline' } = Astro.props

const tones = {
  brand: 'text-brand-600',
  emerald: 'text-emerald-600',
  amber: 'text-amber-600',
  slate: 'text-slate-500',
} satisfies Record<NonNullable<GridItem['tone']>, string>

const cardTones = {
  brand: 'border-brand-100 bg-brand-50/60 text-brand-700',
  emerald: 'border-emerald-100 bg-emerald-50/60 text-emerald-700',
  amber: 'border-amber-100 bg-amber-50/60 text-amber-700',
  slate: 'border-slate-200 bg-slate-50/60 text-slate-600',
} satisfies Record<NonNullable<GridItem['tone']>, string>

const isCard = variant === 'card'
---

{isCard ? (
  <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
    <div class="grid gap-0 lg:grid-cols-[1.1fr_1fr]">
      <div class="px-6 py-5 sm:px-8">
        {eyebrow && <p class="text-[11px] font-700 tracking-[0.18em] text-brand-500 uppercase mb-2">{eyebrow}</p>}
        <h2 class="text-xl sm:text-2xl ac-heading mb-2">{title}</h2>
        {description && <p class="text-sm ac-muted leading-relaxed max-w-2xl">{description}</p>}
      </div>
      <div class="border-t border-slate-200 bg-slate-50/40 px-6 py-5 sm:px-8 lg:border-l lg:border-t-0">
        <div class="grid gap-3 sm:grid-cols-2">
          {items.map((item) => (
            <div class="rounded-lg border bg-white/80 px-3.5 py-3 shadow-sm">
              <div class="flex items-center gap-3 mb-1">
                <div class:list={['flex h-7 w-7 items-center justify-center rounded-lg border text-sm shrink-0', cardTones[item.tone ?? 'brand']]}>
                  <div class={item.icon}></div>
                </div>
                <p class="text-sm font-700 text-slate-900">{item.title}</p>
              </div>
              <p class="text-xs leading-relaxed text-slate-600 pl-10">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
) : (
  <figure class="not-prose my-8" role="group" aria-label={title}>
    {(eyebrow || title) && (
      <figcaption class="mb-4">
        {eyebrow && <p class="text-[11px] font-700 tracking-[0.18em] text-brand-500 uppercase mb-1">{eyebrow}</p>}
        <p class="text-base font-700 text-slate-800">{title}</p>
        {description && <p class="text-sm text-slate-500 mt-1">{description}</p>}
      </figcaption>
    )}
    <div class="grid gap-x-6 gap-y-4 sm:grid-cols-2">
      {items.map((item) => (
        <div class="flex gap-3">
          <div class:list={['text-lg mt-0.5 shrink-0', tones[item.tone ?? 'brand']]}>
            <div class={item.icon}></div>
          </div>
          <div>
            <p class="text-sm font-600 text-slate-800">{item.title}</p>
            <p class="text-[13px] leading-relaxed text-slate-500">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </figure>
)}