---
import Icon from './Icon.astro'

interface GridItem {
  title: string
  description: string
  icon: string
  href?: string
  tone?: 'brand' | 'emerald' | 'amber' | 'slate'
}

interface Props {
  eyebrow?: string
  title: string
  description?: string
  items: readonly GridItem[]
  variant?: 'card' | 'inline'
}

const { eyebrow, title, description, items, variant = 'inline' } = Astro.props

const tones = {
  brand: 'text-brand-600',
  emerald: 'text-emerald-600',
  amber: 'text-amber-600',
  slate: 'text-slate-500',
} satisfies Record<NonNullable<GridItem['tone']>, string>

const cardTones = {
  brand: 'border-brand-100 bg-brand-50/60 text-brand-700',
  emerald: 'border-emerald-100 bg-emerald-50/60 text-emerald-700',
  amber: 'border-amber-100 bg-amber-50/60 text-amber-700',
  slate: 'border-slate-200 bg-slate-50/60 text-slate-600',
} satisfies Record<NonNullable<GridItem['tone']>, string>

const isCard = variant === 'card'
---

{
  isCard ? (
    <div class="insight-grid-card ac-surface overflow-hidden">
      <div class="grid gap-0 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)]">
        <div class="flex flex-col justify-between px-6 py-6 sm:px-8 sm:py-7">
          <div>
            {eyebrow && <p class="ac-eyebrow">{eyebrow}</p>}
            <h2 class="mb-3 text-xl ac-heading sm:text-2xl">{title}</h2>
            {description && (
              <p class="text-sm ac-muted leading-relaxed max-w-2xl">
                {description}
              </p>
            )}
          </div>
          <div class="mt-8 hidden grid-cols-4 gap-2 sm:grid" aria-hidden="true">
            {items.map((item) => (
              <div
                class:list={[
                  'flex h-12 items-center justify-center rounded-lg border text-base',
                  cardTones[item.tone ?? 'brand'],
                ]}
              >
                <Icon name={item.icon} />
              </div>
            ))}
          </div>
        </div>
        <div class="border-t border-slate-200 bg-slate-50/60 px-6 py-6 sm:px-8 sm:py-7 lg:border-l lg:border-t-0">
          <div class="insight-grid-card__items grid gap-4">
            {items.map((item) => (
              <div class="border-b border-slate-200/80 pb-4 last:border-b-0 last:pb-0">
                {item.href ? (
                  <a
                    href={item.href}
                    class="group -m-3 block rounded-lg p-3 no-underline transition-colors hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
                  >
                    <div class="mb-2 flex items-start gap-3">
                      <div
                        class:list={[
                          'flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border text-sm',
                          cardTones[item.tone ?? 'brand'],
                        ]}
                      >
                        <Icon name={item.icon} />
                      </div>
                      <p class="min-w-0 flex-1 pt-0.5 text-sm font-700 leading-snug text-slate-900 transition-colors group-hover:text-brand-600">
                        {item.title}
                      </p>
                      <Icon
                        name="arrow-right"
                        class="mt-1 shrink-0 text-sm text-slate-400 transition-transform group-hover:translate-x-0.5 group-hover:text-brand-500"
                      />
                    </div>
                    <p class="text-sm leading-relaxed text-slate-600">
                      {item.description}
                    </p>
                  </a>
                ) : (
                  <>
                    <div class="mb-2 flex items-start gap-3">
                      <div
                        class:list={[
                          'flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border text-sm',
                          cardTones[item.tone ?? 'brand'],
                        ]}
                      >
                        <Icon name={item.icon} />
                      </div>
                      <p class="min-w-0 pt-0.5 text-sm font-700 leading-snug text-slate-900">
                        {item.title}
                      </p>
                    </div>
                    <p class="text-sm leading-relaxed text-slate-600">
                      {item.description}
                    </p>
                  </>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  ) : (
    <figure class="not-prose my-8" role="group" aria-label={title}>
      {(eyebrow || title) && (
        <figcaption class="mb-4">
          {eyebrow && <p class="ac-eyebrow mb-1">{eyebrow}</p>}
          <p class="text-base font-700 text-slate-800">{title}</p>
          {description && (
            <p class="text-sm text-slate-500 mt-1">{description}</p>
          )}
        </figcaption>
      )}
      <div class="grid gap-x-6 gap-y-4 sm:grid-cols-2">
        {items.map((item) => (
          <div class="flex gap-3">
            <div
              class:list={[
                'text-lg mt-0.5 shrink-0',
                tones[item.tone ?? 'brand'],
              ]}
            >
              <Icon name={item.icon} />
            </div>
            <div>
              <p class="text-sm font-600 text-slate-800">{item.title}</p>
              <p class="text-sm leading-relaxed text-slate-500">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </figure>
  )
}

<style>
  .insight-grid-card {
    container-type: inline-size;
  }

  @container (min-width: 72rem) {
    .insight-grid-card__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
