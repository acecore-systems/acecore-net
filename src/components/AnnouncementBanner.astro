---
import Icon from './Icon.astro'
import { getLocalizedUrl, getTranslationValue, type Locale } from '../i18n'
import { isWithinPublicationWindow } from '../utils/publication-window'

interface Props {
  locale: Locale
}

type AnnouncementTone = 'brand' | 'amber' | 'emerald' | 'slate'

type AnnouncementSettings = {
  enabled?: boolean
  eyebrow?: string
  message?: string
  href?: string
  ctaLabel?: string
  startsAt?: string
  endsAt?: string
  tone?: AnnouncementTone
}

const { locale } = Astro.props
const announcement = getTranslationValue<AnnouncementSettings>(
  locale,
  'announcement',
)
const message = announcement?.message?.trim() ?? ''
const href = announcement?.href?.trim() ?? ''
const ctaLabel = announcement?.ctaLabel?.trim() ?? ''
const eyebrow = announcement?.eyebrow?.trim() ?? ''
const tone = announcement?.tone ?? 'amber'
const isVisible =
  announcement?.enabled === true &&
  message.length > 0 &&
  isWithinPublicationWindow(announcement.startsAt, announcement.endsAt)
const destination =
  href && href.startsWith('/') ? getLocalizedUrl(href, locale) : href

const toneClasses: Record<
  AnnouncementTone,
  { wrap: string; icon: string; eyebrow: string; cta: string }
> = {
  brand: {
    wrap: 'border-brand-200 bg-brand-50 text-slate-900',
    icon: 'text-brand-600',
    eyebrow: 'text-brand-700',
    cta: 'bg-brand-600 text-white hover:bg-brand-700',
  },
  amber: {
    wrap: 'border-amber-200 bg-amber-50 text-slate-900',
    icon: 'text-amber-600',
    eyebrow: 'text-amber-800',
    cta: 'bg-amber-500 text-slate-950 hover:bg-amber-400',
  },
  emerald: {
    wrap: 'border-emerald-200 bg-emerald-50 text-slate-900',
    icon: 'text-emerald-600',
    eyebrow: 'text-emerald-700',
    cta: 'bg-emerald-600 text-white hover:bg-emerald-700',
  },
  slate: {
    wrap: 'border-slate-200 bg-slate-50 text-slate-900',
    icon: 'text-slate-600',
    eyebrow: 'text-slate-700',
    cta: 'bg-slate-800 text-white hover:bg-slate-900',
  },
}

const classes = toneClasses[tone] ?? toneClasses.amber
---

{
  isVisible && (
    <aside
      class:list={['border-b text-sm', classes.wrap]}
      aria-label={eyebrow || 'Announcement'}
    >
      <div class="ac-container flex flex-col gap-3 py-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex min-w-0 items-start gap-3">
          <Icon
            name="megaphone"
            class:list={['mt-0.5 shrink-0 text-lg', classes.icon]}
          />
          <div class="min-w-0">
            {eyebrow && (
              <p
                class:list={[
                  'mb-0.5 text-xs font-800 uppercase leading-tight',
                  classes.eyebrow,
                ]}
              >
                {eyebrow}
              </p>
            )}
            <p class="m-0 text-sm font-700 leading-relaxed">{message}</p>
          </div>
        </div>
        {destination && ctaLabel && (
          <a
            href={destination}
            class:list={[
              'inline-flex min-h-10 shrink-0 items-center justify-center rounded-lg px-4 text-xs font-800 no-underline transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2',
              classes.cta,
            ]}
            data-ga-event="announcement_click"
            data-ga-label={ctaLabel}
            data-ga-location="announcement_banner"
          >
            {ctaLabel}
          </a>
        )}
      </div>
    </aside>
  )
}
