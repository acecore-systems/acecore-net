---
import { generateSrcSet } from '../utils/image'
import { t, getLocalizedUrl, getLocaleFromUrl, type Locale } from '../i18n'

interface Props {
  title: string
  subtitle?: string
  showCTA?: boolean
  images?: {src: string, alt: string}[]
  locale?: Locale
}

const { title, subtitle, showCTA = false, images } = Astro.props
const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const u = (path: string) => getLocalizedUrl(path, locale)
const hasSlider = images && images.length > 0
---

<section
  class:list={[
    'relative text-white overflow-hidden',
    hasSlider ? 'py-24 sm:py-32 lg:py-40' : 'py-20 sm:py-28 lg:py-36',
    !hasSlider && 'bg-gradient-to-br from-brand-700 via-brand-500 to-brand-400',
  ]}
>
  {
    hasSlider && (
      <div class="absolute inset-0" id="hero-slider" role="region" aria-roledescription="carousel" aria-label={t(locale, 'hero.sliderLabel')}>
        {images.map(({src, alt}, i) => (
          <div
            class:list={[
              'hero-slide absolute inset-0 transition-opacity duration-1000',
              i === 0 ? 'opacity-100' : 'opacity-0',
            ]}
            data-index={i}
          >
            <img
              src={src}
              srcset={generateSrcSet(src)}
              sizes="100vw"
              alt={alt}
              class="w-full h-full object-cover"
              width="1400"
              height="600"
              decoding="async"
              fetchpriority={i === 0 ? 'high' : 'low'}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
        <div class="absolute inset-0 bg-brand-900/60" />
        <div id="hero-slide-announce" class="sr-only" aria-live="polite" aria-atomic="true"></div>
      </div>
    )
  }

  {
    hasSlider && images.length > 1 && (
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-0 z-20">
        {images.map((_, i) => (
          <button
            class:list={[
              'hero-dot rounded-full transition-all cursor-pointer min-w-11 min-h-11 flex items-center justify-center',
              i === 0 ? 'bg-transparent' : 'bg-transparent',
            ]}
            data-index={i}
            aria-label={`${t(locale, 'hero.slide')} ${i + 1}`}
            aria-current={i === 0 ? 'true' : undefined}
          >
            <span class:list={[
              'block w-2.5 h-2.5 rounded-full transition-all',
              i === 0 ? 'bg-white scale-125' : 'bg-white/50',
            ]} />
          </button>
        ))}
        <button
          id="hero-pause"
          class="ml-1 rounded-full cursor-pointer min-w-11 min-h-11 flex items-center justify-center bg-transparent text-white/70 hover:text-white transition-colors"
          aria-label={t(locale, 'hero.pauseAutoplay')}
          data-label-pause={t(locale, 'hero.pauseAutoplay')}
          data-label-resume={t(locale, 'hero.resumeAutoplay')}
        >
            <div class="i-lucide-pause text-base" id="hero-pause-icon" aria-hidden="true"></div>
        </button>
      </div>
    )
  }

  <div class="ac-container text-center relative z-10">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-700 tracking-tight mb-6">
      {title}
    </h1>
    {
      subtitle && (
        <p class="text-lg sm:text-xl text-white/85 max-w-2xl mx-auto mb-8">
          {subtitle}
        </p>
      )
    }
    {
      showCTA && (
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href={u('/services/')}
            class="ac-btn bg-white text-brand-600 hover:bg-brand-50"
            data-ga-event="cta_click"
            data-ga-label="hero_services"
            data-ga-location="hero"
            data-ga-destination={u('/services/')}
          >
            {t(locale, 'hero.ctaServices')}
          </a>
          <a
            href={u('/contact/')}
            class="ac-btn border-2 border-white text-white hover:bg-white/10"
            data-ga-event="cta_click"
            data-ga-label="hero_contact"
            data-ga-location="hero"
            data-ga-destination={u('/contact/')}
          >
            {t(locale, 'hero.ctaContact')}
          </a>
        </div>
      )
    }
  </div>
</section>

<script>
  const SLIDE_INTERVAL = 5000
  const SWIPE_THRESHOLD = 50
  let heroTimer: ReturnType<typeof setInterval> | null = null

  function initHeroSlider() {
    if (heroTimer) { clearInterval(heroTimer); heroTimer = null }

    const slider = document.getElementById('hero-slider')
    if (!slider) return

    const slides = slider.querySelectorAll<HTMLDivElement>('.hero-slide')
    const dots = document.querySelectorAll<HTMLButtonElement>('.hero-dot')
    const pauseBtn = document.getElementById('hero-pause') as HTMLButtonElement | null
    const pauseIcon = document.getElementById('hero-pause-icon') as HTMLDivElement | null
    const total = slides.length
    if (total <= 1) return

    let current = 0
    let paused = false
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const announceEl = document.getElementById('hero-slide-announce')

    function goTo(index: number) {
      dots[current]?.removeAttribute('aria-current')
      slides[current].classList.replace('opacity-100', 'opacity-0')
      const prevSpan = dots[current]?.querySelector('span')
      prevSpan?.classList.replace('bg-white', 'bg-white/50')
      prevSpan?.classList.remove('scale-125')
      current = index
      dots[current]?.setAttribute('aria-current', 'true')
      slides[current].classList.replace('opacity-0', 'opacity-100')
      const nextSpan = dots[current]?.querySelector('span')
      nextSpan?.classList.replace('bg-white/50', 'bg-white')
      nextSpan?.classList.add('scale-125')
      if (announceEl) {
        const alt = slides[current].querySelector('img')?.alt || ''
        announceEl.textContent = `${current + 1} / ${total}${alt ? `: ${alt}` : ''}`
      }
    }

    function next() {
      goTo((current + 1) % total)
    }

    function startAutoPlay() {
      if (paused || prefersReducedMotion) return
      stopAutoPlay()
      heroTimer = setInterval(next, SLIDE_INTERVAL)
    }

    function stopAutoPlay() {
      if (heroTimer) { clearInterval(heroTimer); heroTimer = null }
    }

    function setPaused(value: boolean) {
      paused = value
      if (paused) {
        stopAutoPlay()
        pauseIcon?.classList.replace('i-lucide-pause', 'i-lucide-play')
        pauseBtn?.setAttribute('aria-label', pauseBtn?.dataset.labelResume ?? '')
      } else {
        pauseIcon?.classList.replace('i-lucide-play', 'i-lucide-pause')
        pauseBtn?.setAttribute('aria-label', pauseBtn?.dataset.labelPause ?? '')
        startAutoPlay()
      }
    }

    pauseBtn?.addEventListener('click', () => setPaused(!paused))

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        stopAutoPlay()
        goTo(Number(dot.dataset.index))
        startAutoPlay()
      })
    })

    // Swipe support
    let startX = 0
    const section = slider.closest('section')!
    section.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX
      stopAutoPlay()
    }, { passive: true })
    section.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX
      if (Math.abs(diff) > SWIPE_THRESHOLD) {
        goTo(diff > 0 ? (current + 1) % total : (current - 1 + total) % total)
      }
      startAutoPlay()
    }, { passive: true })

    startAutoPlay()
  }

  initHeroSlider()
  document.addEventListener('astro:after-swap', initHeroSlider)
</script>
