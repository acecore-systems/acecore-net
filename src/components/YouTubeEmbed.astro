---
interface Props {
  videoId: string
  title?: string
  caption?: string
}

const { videoId, title = 'YouTube動画', caption } = Astro.props
const safeId = videoId.replace(/[^a-zA-Z0-9_-]/g, '')
---

<figure class="not-prose my-8">
  <div class="relative w-full rounded-lg overflow-hidden" style="padding-bottom:56.25%">
    <iframe
      class="absolute inset-0 w-full h-full"
      src={`https://www.youtube-nocookie.com/embed/${safeId}`}
      title={title}
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
  {caption && <figcaption class="text-sm text-slate-500 mt-2">{caption}</figcaption>}
</figure>
