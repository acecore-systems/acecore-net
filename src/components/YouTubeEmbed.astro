---
import { t } from '../i18n/utils'
import type { Locale } from '../i18n'

interface Props {
  videoId: string
  title?: string
  caption?: string
  locale?: Locale
}

const { videoId, title, caption, locale = 'ja' } = Astro.props
const displayTitle = title || t(locale, 'common.youtubeDefaultTitle')
const safeId = videoId.replace(/[^a-zA-Z0-9_-]/g, '')
const thumbnailUrl = `https://i.ytimg.com/vi/${safeId}/hqdefault.jpg`
const ariaLabel = t(locale, 'common.playVideo').replace('{title}', displayTitle)
---

<figure class="not-prose my-8">
  <div
    class="yt-facade relative w-full rounded-lg overflow-hidden cursor-pointer group"
    style="padding-bottom:56.25%"
    data-video-id={safeId}
    data-video-title={displayTitle}
  >
    <img
      src={thumbnailUrl}
      alt={displayTitle}
      class="absolute inset-0 w-full h-full object-cover"
      width="480"
      height="360"
      loading="lazy"
      decoding="async"
    />
    <button
      class="absolute inset-0 w-full h-full flex items-center justify-center bg-black/30 group-hover:bg-black/40 transition-colors"
      aria-label={ariaLabel}
    >
      <svg viewBox="0 0 68 48" width="68" height="48" aria-hidden="true">
        <path
          d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
          fill="red"></path>
        <path d="M45 24 27 14v20" fill="white"></path>
      </svg>
    </button>
  </div>
  {
    caption && (
      <figcaption class="text-sm text-slate-500 mt-2">{caption}</figcaption>
    )
  }
</figure>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLDivElement>('.yt-facade').forEach((el) => {
      el.addEventListener(
        'click',
        () => {
          const id = el.dataset.videoId
          const t = el.dataset.videoTitle ?? 'YouTube video'
          const iframe = document.createElement('iframe')
          iframe.className = 'absolute inset-0 w-full h-full'
          iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`
          iframe.title = t
          iframe.allow =
            'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
          iframe.allowFullscreen = true
          el.replaceChildren(iframe)
          el.classList.remove('cursor-pointer')
        },
        { once: true },
      )
    })
  })
</script>
