---
import Icon from './Icon.astro'
import { getLocalizedUrl, getTranslationValue, type Locale } from '../i18n'
import { isWithinPublicationWindow } from '../utils/publication-window'

interface Props {
  locale: Locale
}

type EnrollmentSettings = {
  enabled?: boolean
  termLabel?: string
  badgeLabel?: string
  remainingLabel?: string
  remainingSeats?: number | string
  remainingUnit?: string
  capacityNote?: string
  ctaLabel?: string
  startsAt?: string
  endsAt?: string
}

const { locale } = Astro.props
const enrollment = getTranslationValue<EnrollmentSettings>(
  locale,
  'pages.schools.enrollment',
)
const termLabel = enrollment?.termLabel?.trim() ?? ''
const badgeLabel = enrollment?.badgeLabel?.trim() ?? ''
const remainingLabel = enrollment?.remainingLabel?.trim() ?? ''
const remainingUnit = enrollment?.remainingUnit?.trim() ?? ''
const capacityNote = enrollment?.capacityNote?.trim() ?? ''
const ctaLabel = enrollment?.ctaLabel?.trim() ?? ''
const remainingSeats =
  enrollment?.remainingSeats === undefined ||
  enrollment?.remainingSeats === null ||
  String(enrollment.remainingSeats).trim() === ''
    ? ''
    : String(enrollment.remainingSeats).trim()
const isVisible =
  enrollment?.enabled === true &&
  termLabel.length > 0 &&
  isWithinPublicationWindow(enrollment.startsAt, enrollment.endsAt)
const contactUrl = getLocalizedUrl(
  '/contact/?category=service-education',
  locale,
)
---

{
  isVisible && (
    <section
      class="border-y border-brand-100 bg-brand-50/80 py-5"
      aria-label={termLabel}
    >
      <div class="ac-container flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex min-w-0 items-start gap-3">
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-white text-brand-600 shadow-sm">
            <Icon name="calendar-check" class="text-xl" />
          </span>
          <div class="min-w-0">
            <div class="mb-1 flex flex-wrap items-center gap-2">
              {badgeLabel && (
                <span class="rounded-full bg-brand-600 px-3 py-1 text-xs font-800 text-white">
                  {badgeLabel}
                </span>
              )}
              {remainingSeats && (
                <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-800 text-amber-900">
                  {remainingLabel}
                  {remainingSeats}
                  {remainingUnit}
                </span>
              )}
            </div>
            <h2 class="m-0 text-lg font-800 leading-snug text-slate-900">
              {termLabel}
            </h2>
            {capacityNote && (
              <p class="m-0 mt-1 text-sm font-600 leading-relaxed text-slate-600">
                {capacityNote}
              </p>
            )}
          </div>
        </div>
        {ctaLabel && (
          <a
            href={contactUrl}
            class="ac-btn-primary shrink-0 text-sm"
            data-ga-event="schools_enrollment_click"
            data-ga-label={ctaLabel}
            data-ga-location="schools_enrollment_notice"
          >
            {ctaLabel}
          </a>
        )}
      </div>
    </section>
  )
}
