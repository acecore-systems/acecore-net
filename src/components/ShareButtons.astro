---
import Icon from './Icon.astro'
import { t, getLocaleFromUrl, type Locale } from '../i18n'

interface Props {
  url: string
  title: string
  locale?: Locale
}
const { url, title } = Astro.props
const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const encodedUrl = encodeURIComponent(url)
const encodedTitle = encodeURIComponent(title)
---

<div class="flex flex-wrap items-center gap-3" data-pagefind-ignore>
  <span class="text-sm font-600 text-slate-600">{t(locale, 'blog.share')}</span>
  <a
    href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
    target="_blank"
    rel="noopener noreferrer"
    class="ac-touch gap-1.5 rounded-full bg-slate-100 px-4 text-sm text-slate-700 transition-colors hover:bg-[#1d9bf0] hover:text-white"
    aria-label={t(locale, 'blog.shareOnX')}
  >
    <Icon name="twitter" class="text-sm" />
    <span>X</span>
    <span class="sr-only">{t(locale, 'common.opensInNewTab')}</span>
  </a>
  <a
    href={`https://b.hatena.ne.jp/add?mode=confirm&url=${encodedUrl}&title=${encodedTitle}`}
    target="_blank"
    rel="noopener noreferrer"
    class="ac-touch gap-1.5 rounded-full bg-slate-100 px-4 text-sm text-slate-700 transition-colors hover:bg-[#00a4de] hover:text-white"
    aria-label={t(locale, 'blog.addToHatena')}
  >
    <span class="font-700 text-xs">B!</span>
    <span>{t(locale, 'blog.addToHatena')}</span>
    <span class="sr-only">{t(locale, 'common.opensInNewTab')}</span>
  </a>
  <button
    class="ac-touch cursor-pointer gap-1.5 rounded-full bg-slate-100 px-4 text-sm text-slate-700 transition-colors hover:bg-slate-200"
    aria-label={t(locale, 'blog.copyLink')}
    data-share-url={url}
    data-label-default={t(locale, 'blog.copyLink')}
    data-label-copied={t(locale, 'blog.linkCopied')}
    data-label-failed={t(locale, 'blog.linkCopyFailed')}
  >
    <Icon name="link" class="text-sm" />
    <span>{t(locale, 'blog.copyLink')}</span>
  </button>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    document
      .querySelectorAll<HTMLButtonElement>('[data-share-url]')
      .forEach((btn) => {
        btn.addEventListener('click', async () => {
          const url = btn.dataset.shareUrl!
          const span = btn.querySelector('span')
          const defaultLabel = btn.dataset.labelDefault ?? 'Link'
          const copiedLabel = btn.dataset.labelCopied ?? 'Copied!'
          const failedLabel = btn.dataset.labelFailed ?? 'Copy failed'
          try {
            await navigator.clipboard.writeText(url)
            if (span) span.textContent = copiedLabel
          } catch {
            if (span) span.textContent = failedLabel
          }
          setTimeout(() => {
            if (span) span.textContent = defaultLabel
          }, 2000)
        })
      })
  })
</script>
