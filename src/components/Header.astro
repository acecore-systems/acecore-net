---
import { t, getLocalizedUrl, getLocaleFromUrl, type Locale } from '../i18n'
import LanguageSwitcher from './LanguageSwitcher.astro'

interface Props {
  locale?: Locale
}

const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const navLinks = [
  { href: getLocalizedUrl('/', locale), label: t(locale, 'nav.home') },
  { href: getLocalizedUrl('/services/', locale), label: t(locale, 'nav.services') },
  { href: getLocalizedUrl('/about/', locale), label: t(locale, 'nav.about') },
  { href: getLocalizedUrl('/blog/', locale), label: t(locale, 'nav.blog') },
  { href: getLocalizedUrl('/contact/', locale), label: t(locale, 'nav.contact') },
]
const currentPath = Astro.url.pathname
---

<header
  class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200"
>
  <div class="ac-container flex items-center justify-between h-16">
    <a
      href={getLocalizedUrl('/', locale)}
      class="flex items-center gap-2 font-700 text-xl text-brand-500 no-underline min-h-11"
    >
      <img src="/favicon.svg" alt="" class="h-8 w-8" />
      Acecore
    </a>
    <nav
      class="hidden md:flex items-center gap-6"
      aria-label={t(locale, 'common.mainNav')}
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-600 no-underline transition-colors py-3 min-w-11 text-center',
              currentPath === link.href
                ? 'text-brand-500'
                : 'text-slate-600 hover:text-brand-500',
            ]}
            {...(currentPath === link.href ? { 'aria-current': 'page' } : {})}
          >
            {link.label}
          </a>
        ))
      }
      <button
        data-search-trigger
        class="p-2 text-slate-500 hover:text-brand-500 transition-colors"
        aria-label={t(locale, 'common.search')}
        title={t(locale, 'common.searchShortcut')}
      >
        <div class="i-lucide-search text-lg" aria-hidden="true"></div>
      </button>
      <LanguageSwitcher locale={locale} />
    </nav>
    <div class="flex items-center gap-1 md:hidden">
      <button
        data-search-trigger
        class="p-2 text-slate-500"
        aria-label={t(locale, 'common.search')}
      >
        <div class="i-lucide-search text-lg" aria-hidden="true"></div>
      </button>
      <button
        id="mobile-menu-btn"
        class="p-2 text-slate-600"
        aria-label={t(locale, 'common.openMenu')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-label-open={t(locale, 'common.openMenu')}
        data-label-close={t(locale, 'common.closeMenu')}
      >
        <div class="i-lucide-menu text-xl" aria-hidden="true"></div>
      </button>
    </div>
  </div>
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-slate-200 bg-white"
    aria-label={t(locale, 'common.mobileNav')}
  >
    <div class="ac-container py-4 flex flex-col gap-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-600 no-underline py-3 min-h-11',
              currentPath === link.href ? 'text-brand-500' : 'text-slate-600',
            ]}
            {...(currentPath === link.href ? { 'aria-current': 'page' } : {})}
          >
            {link.label}
          </a>
        ))
      }
      <div class="border-t border-slate-100 pt-3">
        <LanguageSwitcher locale={locale} />
      </div>
    </div>
  </nav>
</header>

<script>
  function initHeader() {
    const menuBtn = document.getElementById('mobile-menu-btn')
    const menu = document.getElementById('mobile-menu')
    if (!menuBtn || !menu) return

    // Reset state after VT swap
    menu.classList.add('hidden')
    menuBtn.setAttribute('aria-expanded', 'false')
    menuBtn.setAttribute('aria-label', menuBtn.dataset.labelOpen || 'Open menu')
    const icon = menuBtn.querySelector('div')
    if (icon) {
      icon.classList.add('i-lucide-menu')
      icon.classList.remove('i-lucide-x')
    }

    menuBtn.addEventListener('click', () => {
      const expanded = menu.classList.toggle('hidden') === false
      menuBtn.setAttribute('aria-expanded', String(expanded))
      menuBtn.setAttribute(
        'aria-label',
        expanded ? (menuBtn.dataset.labelClose || 'Close menu') : (menuBtn.dataset.labelOpen || 'Open menu'),
      )
      const icon = menuBtn.querySelector('div')
      if (icon) {
        icon.classList.toggle('i-lucide-menu', !expanded)
        icon.classList.toggle('i-lucide-x', expanded)
      }
      if (expanded) {
        const first = menu.querySelector<HTMLElement>('a')
        first?.focus()
      }
    })
  }

  function initHeaderKeyboard() {
    document.addEventListener('keydown', (e) => {
      const menu = document.getElementById('mobile-menu')
      const menuBtn = document.getElementById('mobile-menu-btn')
      if (!menu || !menuBtn) return
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden')
        menuBtn.setAttribute('aria-expanded', 'false')
        menuBtn.setAttribute('aria-label', menuBtn.dataset.labelOpen || 'Open menu')
        menuBtn.focus()
      }
      if (e.key === 'Tab' && !menu.classList.contains('hidden')) {
        const focusable = menu.querySelectorAll<HTMLElement>('a, button')
        if (focusable.length === 0) return
        const first = focusable[0]
        const last = focusable[focusable.length - 1]
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault()
          menuBtn.focus()
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault()
          first.focus()
        } else if (e.shiftKey && document.activeElement === menuBtn) {
          e.preventDefault()
          last.focus()
        }
      }
    })
  }

  function initSearchTriggers() {
    document
      .querySelectorAll<HTMLElement>('[data-search-trigger]')
      .forEach((btn) => {
        btn.addEventListener('click', () => (window as any).openSearch?.())
      })
  }

  initHeader()
  initHeaderKeyboard()
  initSearchTriggers()
  document.addEventListener('astro:after-swap', () => {
    initHeader()
    initSearchTriggers()
  })
</script>
