---
import Icon from './Icon.astro'
import { t, getLocalizedUrl, getLocaleFromUrl, type Locale } from '../i18n'
import LanguageSwitcher from './LanguageSwitcher.astro'

interface Props {
  locale?: Locale
  languageSwitcherPath?: string
}

const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const languageSwitcherPath = Astro.props.languageSwitcherPath
const navLinks = [
  { href: getLocalizedUrl('/', locale), label: t(locale, 'nav.home') },
  {
    href: getLocalizedUrl('/services/', locale),
    label: t(locale, 'nav.services'),
  },
  {
    href: getLocalizedUrl('/pricing/', locale),
    label: t(locale, 'nav.pricing'),
  },
  { href: getLocalizedUrl('/works/', locale), label: t(locale, 'nav.works') },
  { href: getLocalizedUrl('/about/', locale), label: t(locale, 'nav.about') },
  { href: getLocalizedUrl('/blog/', locale), label: t(locale, 'nav.blog') },
  {
    href: getLocalizedUrl('/contact/', locale),
    label: t(locale, 'nav.contact'),
  },
]
const currentPath = Astro.url.pathname
---

<header
  class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur"
>
  <div class="ac-container flex h-16 items-center justify-between">
    <a
      href={getLocalizedUrl('/', locale)}
      class="ac-touch gap-2 rounded-lg pr-3 font-700 text-xl text-brand-600 no-underline transition-colors hover:text-brand-700"
    >
      <img src="/favicon.svg" alt="" class="h-8 w-8" />
      Acecore
    </a>
    <nav
      class="hidden items-center gap-1 md:flex"
      aria-label={t(locale, 'common.mainNav')}
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'inline-flex min-h-11 items-center rounded-lg px-3 text-sm font-700 no-underline transition-colors',
              currentPath === link.href
                ? 'bg-brand-50 text-brand-700'
                : 'text-slate-600 hover:bg-slate-50 hover:text-brand-600',
            ]}
            {...(currentPath === link.href ? { 'aria-current': 'page' } : {})}
          >
            {link.label}
          </a>
        ))
      }
      <button
        data-search-trigger
        class="ac-touch rounded-lg text-slate-500 transition-colors hover:bg-slate-50 hover:text-brand-600"
        aria-label={t(locale, 'common.search')}
        title={t(locale, 'common.searchShortcut')}
      >
        <Icon name="search" class="text-lg" />
      </button>
      <LanguageSwitcher locale={locale} path={languageSwitcherPath} />
    </nav>
    <div class="flex items-center gap-1 md:hidden">
      <button
        data-search-trigger
        class="ac-touch rounded-lg text-slate-500 hover:bg-slate-50 hover:text-brand-600"
        aria-label={t(locale, 'common.search')}
      >
        <Icon name="search" class="text-lg" />
      </button>
      <button
        id="mobile-menu-btn"
        class="ac-touch rounded-lg text-slate-600 hover:bg-slate-50 hover:text-brand-600"
        aria-label={t(locale, 'common.openMenu')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-label-open={t(locale, 'common.openMenu')}
        data-label-close={t(locale, 'common.closeMenu')}
      >
        <span data-menu-icon="menu">
          <Icon name="menu" class="text-xl" />
        </span>
        <span data-menu-icon="close" class="hidden">
          <Icon name="x" class="text-xl" />
        </span>
      </button>
    </div>
  </div>
  <nav
    id="mobile-menu"
    class="hidden border-t border-slate-200 bg-white md:hidden"
    aria-label={t(locale, 'common.mobileNav')}
  >
    <div class="ac-container flex flex-col gap-2 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'flex min-h-11 items-center rounded-lg px-3 text-sm font-700 no-underline transition-colors',
              currentPath === link.href
                ? 'bg-brand-50 text-brand-700'
                : 'text-slate-600 hover:bg-slate-50 hover:text-brand-600',
            ]}
            {...(currentPath === link.href ? { 'aria-current': 'page' } : {})}
          >
            {link.label}
          </a>
        ))
      }
      <div class="border-t border-slate-100 pt-3">
        <LanguageSwitcher
          locale={locale}
          path={languageSwitcherPath}
          showLabel={true}
        />
      </div>
    </div>
  </nav>
</header>

<script>
  function syncMenuIcon(menuBtn: HTMLElement, expanded: boolean) {
    const menuIcon = menuBtn.querySelector<HTMLElement>(
      '[data-menu-icon="menu"]',
    )
    const closeIcon = menuBtn.querySelector<HTMLElement>(
      '[data-menu-icon="close"]',
    )

    menuIcon?.classList.toggle('hidden', expanded)
    closeIcon?.classList.toggle('hidden', !expanded)
  }

  function initHeader() {
    const menuBtn = document.getElementById('mobile-menu-btn')
    const menu = document.getElementById('mobile-menu')
    if (!menuBtn || !menu) return

    // Reset state after VT swap
    menu.classList.add('hidden')
    menuBtn.setAttribute('aria-expanded', 'false')
    menuBtn.setAttribute('aria-label', menuBtn.dataset.labelOpen || 'Open menu')
    syncMenuIcon(menuBtn, false)

    menuBtn.addEventListener('click', () => {
      const expanded = menu.classList.toggle('hidden') === false
      menuBtn.setAttribute('aria-expanded', String(expanded))
      menuBtn.setAttribute(
        'aria-label',
        expanded
          ? menuBtn.dataset.labelClose || 'Close menu'
          : menuBtn.dataset.labelOpen || 'Open menu',
      )
      syncMenuIcon(menuBtn, expanded)
      if (expanded) {
        const first = menu.querySelector<HTMLElement>('a')
        first?.focus()
      }
    })
  }

  function initHeaderKeyboard() {
    document.addEventListener('keydown', (e) => {
      const menu = document.getElementById('mobile-menu')
      const menuBtn = document.getElementById('mobile-menu-btn')
      if (!menu || !menuBtn) return
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden')
        menuBtn.setAttribute('aria-expanded', 'false')
        menuBtn.setAttribute(
          'aria-label',
          menuBtn.dataset.labelOpen || 'Open menu',
        )
        syncMenuIcon(menuBtn, false)
        menuBtn.focus()
      }
      if (e.key === 'Tab' && !menu.classList.contains('hidden')) {
        const focusable = menu.querySelectorAll<HTMLElement>('a, button')
        if (focusable.length === 0) return
        const first = focusable[0]
        const last = focusable[focusable.length - 1]
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault()
          menuBtn.focus()
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault()
          first.focus()
        } else if (e.shiftKey && document.activeElement === menuBtn) {
          e.preventDefault()
          last.focus()
        }
      }
    })
  }

  function initSearchTriggers() {
    document
      .querySelectorAll<HTMLElement>('[data-search-trigger]')
      .forEach((btn) => {
        btn.addEventListener('click', () => (window as any).openSearch?.())
      })
  }

  initHeader()
  initHeaderKeyboard()
  initSearchTriggers()
  document.addEventListener('astro:after-swap', () => {
    initHeader()
    initSearchTriggers()
  })
</script>
