---
import { SITE } from '../data/site'
import { t, type Locale } from '../i18n'

interface Props {
  locale: Locale
  slug: string
}

const { locale, slug } = Astro.props

const labels = {
  count: t(locale, 'blog.commentsCount'),
  loading: t(locale, 'blog.commentsLoading'),
  empty: t(locale, 'blog.commentsEmpty'),
  unavailable: t(locale, 'blog.commentsUnavailable'),
  posted: t(locale, 'blog.commentsPosted'),
  error: t(locale, 'blog.commentsError'),
  validationName: t(locale, 'blog.commentsValidationName'),
  validationBody: t(locale, 'blog.commentsValidationBody'),
  validationTurnstile: t(locale, 'blog.commentsValidationTurnstile'),
  sending: t(locale, 'blog.commentsSending'),
}
const labelsJson = JSON.stringify(labels).replace(/</g, '\\u003c')
---

<section
  class="my-10 border-t border-slate-200 pt-8"
  data-comments-root
  data-comments-slug={slug}
  data-comments-locale={locale}
  data-comments-sitekey={SITE.turnstileSiteKey}
  data-comments-labels={labelsJson}
  data-pagefind-ignore
>
  <div class="flex flex-wrap items-baseline justify-between gap-3">
    <h2 class="text-xl font-800 text-slate-900">
      {t(locale, 'blog.commentsTitle')}
    </h2>
    <p class="text-sm text-slate-500" data-comments-count></p>
  </div>

  <div class="mt-4" data-comments-status role="status" aria-live="polite">
    <span class="text-sm text-slate-500"
      >{t(locale, 'blog.commentsLoading')}</span
    >
  </div>

  <div class="mt-5 space-y-3" data-comments-list></div>

  <form class="mt-6 rounded-lg border border-slate-200 p-5" data-comments-form>
    <div class="grid gap-4 sm:grid-cols-[minmax(0,14rem)_1fr]">
      <div>
        <label
          for={`comment-author-${slug}`}
          class="mb-2 block text-sm font-700 text-slate-700"
        >
          {t(locale, 'blog.commentsNameLabel')}
        </label>
        <input
          id={`comment-author-${slug}`}
          name="authorName"
          type="text"
          maxlength="24"
          autocomplete="name"
          class="ac-input"
          placeholder={t(locale, 'blog.commentsNamePlaceholder')}
          required
        />
      </div>
      <div>
        <label
          for={`comment-body-${slug}`}
          class="mb-2 block text-sm font-700 text-slate-700"
        >
          {t(locale, 'blog.commentsBodyLabel')}
        </label>
        <textarea
          id={`comment-body-${slug}`}
          name="body"
          rows="4"
          maxlength="600"
          class="ac-input resize-y"
          placeholder={t(locale, 'blog.commentsBodyPlaceholder')}
          required></textarea>
      </div>
    </div>

    <input
      type="text"
      name="website"
      value=""
      autocomplete="off"
      tabindex="-1"
      aria-hidden="true"
      hidden
    />

    <div class="cf-turnstile mt-4" data-comments-turnstile data-theme="light">
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <button
        type="submit"
        class="ac-btn-primary disabled:cursor-not-allowed disabled:opacity-60"
        data-comments-submit
      >
        {t(locale, 'blog.commentsSubmit')}
      </button>
      <p class="text-xs leading-relaxed text-slate-500">
        {t(locale, 'blog.commentsRule')}
      </p>
    </div>
    <p class="mt-3 text-sm" data-comments-feedback role="alert"></p>
  </form>
</section>

<script is:inline>
  ;(() => {
    const roots = document.querySelectorAll('[data-comments-root]')
    const blockedPattern =
      /(https?:\/\/|www\.|[a-z0-9][a-z0-9.-]*\.(com|net|org|info|biz|xyz|top|site|online|shop|click|link|ru|cn|jp)\b|[^\s@]+@[^\s@]+\.[^\s@]+|<[^>]{2,}>|\[[^\]]+\]\([^)]+\))/i

    roots.forEach((root) => {
      if (root.dataset.commentsReady) return
      root.dataset.commentsReady = 'true'

      const slug = root.dataset.commentsSlug || ''
      const locale = root.dataset.commentsLocale || 'ja'
      const sitekey = root.dataset.commentsSitekey || ''
      const list = root.querySelector('[data-comments-list]')
      const status = root.querySelector('[data-comments-status]')
      const count = root.querySelector('[data-comments-count]')
      const form = root.querySelector('[data-comments-form]')
      const submit = root.querySelector('[data-comments-submit]')
      const feedback = root.querySelector('[data-comments-feedback]')
      const turnstileEl = root.querySelector('[data-comments-turnstile]')
      const labels = readLabels(root.dataset.commentsLabels)
      const intlLocale = locale === 'zh-cn' ? 'zh-CN' : locale

      function label(key, fallback, params) {
        let text = labels[key] || fallback
        for (const [name, value] of Object.entries(params || {})) {
          text = text.replaceAll(`{${name}}`, String(value))
        }
        return text
      }

      function setStatus(text, type) {
        if (!status) return
        status.textContent = text
        status.className = text
          ? type === 'error'
            ? 'mt-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700'
            : 'mt-4 text-sm text-slate-500'
          : 'hidden'
      }

      function setFeedback(text, type) {
        if (!feedback) return
        feedback.textContent = text
        feedback.className = text
          ? type === 'success'
            ? 'mt-3 text-sm text-emerald-700'
            : 'mt-3 text-sm text-red-700'
          : 'mt-3 text-sm'
      }

      function renderComments(comments) {
        if (!list) return
        list.textContent = ''

        if (count) {
          count.textContent = label('count', '{count} comments', {
            count: comments.length,
          })
        }

        if (comments.length === 0) {
          const empty = document.createElement('p')
          empty.className =
            'rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600'
          empty.textContent = label('empty', 'No comments yet.')
          list.append(empty)
          return
        }

        for (const comment of comments) {
          const article = document.createElement('article')
          article.className = 'rounded-lg border border-slate-200 bg-white p-4'

          const header = document.createElement('div')
          header.className = 'flex flex-wrap items-center gap-x-3 gap-y-1'

          const author = document.createElement('strong')
          author.className = 'text-sm font-800 text-slate-900'
          author.textContent = comment.authorName || 'Guest'

          const time = document.createElement('time')
          time.className = 'text-xs text-slate-500'
          time.dateTime = comment.createdAt
          time.textContent = formatDate(comment.createdAt)

          const body = document.createElement('p')
          body.className =
            'mt-3 whitespace-pre-wrap text-sm leading-relaxed text-slate-700'
          body.textContent = comment.body || ''

          header.append(author, time)
          article.append(header, body)
          list.append(article)
        }
      }

      async function loadComments() {
        if (!slug) return
        setStatus(label('loading', 'Loading comments...'))

        try {
          const response = await fetch(
            `/api/comments?slug=${encodeURIComponent(
              slug,
            )}&locale=${encodeURIComponent(locale)}`,
            { headers: { Accept: 'application/json' } },
          )
          const data = await response.json()

          if (!response.ok || !data.ok || !Array.isArray(data.comments)) {
            throw new Error(data.message || 'Comments unavailable')
          }

          renderComments(data.comments)
          setStatus('')
        } catch {
          renderComments([])
          setStatus(
            label('unavailable', 'Comments are temporarily unavailable.'),
            'error',
          )
        }
      }

      function renderTurnstile() {
        if (
          !turnstileEl ||
          !sitekey ||
          typeof window.turnstile === 'undefined' ||
          turnstileEl.dataset.widgetId
        ) {
          return
        }

        const widgetId = window.turnstile.render(turnstileEl, {
          sitekey,
          language: locale,
          theme: turnstileEl.dataset.theme || 'light',
        })
        turnstileEl.dataset.widgetId = String(widgetId)
      }

      function loadTurnstile() {
        if (!sitekey || isLocalHostname(window.location.hostname)) return
        if (typeof window.turnstile !== 'undefined') {
          renderTurnstile()
          return
        }

        const existingScript = document.querySelector(
          'script[data-ace-turnstile-script]',
        )
        if (existingScript) {
          waitForTurnstile(renderTurnstile)
          return
        }

        const script = document.createElement('script')
        script.src =
          'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit'
        script.async = true
        script.defer = true
        script.dataset.aceTurnstileScript = 'true'
        script.addEventListener('load', renderTurnstile)
        document.head.append(script)
      }

      function waitForTurnstile(callback) {
        let attempts = 0
        const timer = window.setInterval(() => {
          attempts += 1
          if (typeof window.turnstile !== 'undefined') {
            window.clearInterval(timer)
            callback()
          } else if (attempts > 30) {
            window.clearInterval(timer)
          }
        }, 100)
      }

      function getTurnstileToken() {
        const widgetId = turnstileEl?.dataset.widgetId
        if (typeof window.turnstile !== 'undefined' && widgetId) {
          return window.turnstile.getResponse(widgetId)
        }

        return String(
          form?.querySelector('[name="cf-turnstile-response"]')?.value || '',
        )
      }

      function resetTurnstile() {
        const widgetId = turnstileEl?.dataset.widgetId
        if (typeof window.turnstile !== 'undefined' && widgetId) {
          window.turnstile.reset(widgetId)
        }
      }

      form?.addEventListener('submit', async (event) => {
        event.preventDefault()
        setFeedback('')

        const formData = new FormData(form)
        const authorName = String(formData.get('authorName') || '').trim()
        const body = String(formData.get('body') || '').trim()
        const website = String(formData.get('website') || '').trim()
        const meaningfulLength = Array.from(
          body.replace(/[^\p{L}\p{N}]/gu, ''),
        ).length

        if (!authorName) {
          setFeedback(label('validationName', 'Enter your name.'), 'error')
          return
        }

        if (
          meaningfulLength < 8 ||
          body.length > 600 ||
          blockedPattern.test(`${authorName}\n${body}`)
        ) {
          setFeedback(
            label(
              'validationBody',
              'Enter at least 8 characters without links.',
            ),
            'error',
          )
          return
        }

        const turnstileToken = getTurnstileToken()
        if (!turnstileToken) {
          setFeedback(
            label(
              'validationTurnstile',
              'Complete verification before sending.',
            ),
            'error',
          )
          return
        }

        if (submit) submit.disabled = true
        setFeedback(label('sending', 'Sending...'))

        try {
          const response = await fetch('/api/comments', {
            method: 'POST',
            headers: {
              Accept: 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              slug,
              locale,
              authorName,
              body,
              website,
              turnstileToken,
            }),
          })
          const data = await response.json().catch(() => ({}))

          if (!response.ok || !data.ok) {
            throw new Error(data.message || label('error', 'Could not post.'))
          }

          form.reset()
          resetTurnstile()
          setFeedback(label('posted', 'Comment posted.'), 'success')
          await loadComments()
        } catch (error) {
          setFeedback(
            error instanceof Error
              ? error.message
              : label('error', 'Could not post.'),
            'error',
          )
          resetTurnstile()
        } finally {
          if (submit) submit.disabled = false
        }
      })

      function formatDate(value) {
        const date = new Date(value)
        if (Number.isNaN(date.getTime())) return ''

        return new Intl.DateTimeFormat(intlLocale, {
          timeZone: 'Asia/Tokyo',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        }).format(date)
      }

      loadComments()
      loadTurnstile()
    })

    function isLocalHostname(hostname) {
      return hostname === 'localhost' || hostname === '127.0.0.1'
    }

    function readLabels(value) {
      try {
        return JSON.parse(value || '{}')
      } catch {
        return {}
      }
    }
  })()
</script>
