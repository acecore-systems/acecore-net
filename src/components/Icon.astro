---
import { icons as lucideIcons } from '@iconify-json/lucide'

interface Props {
  name: string
  class?: string
  label?: string
}

const { name, class: className = '', label } = Astro.props

const tokens = String(name ?? '')
  .trim()
  .split(/\s+/)
  .filter(Boolean)

const iconToken =
  tokens.find((token) => token.startsWith('i-lucide-') || token.startsWith('lucide:')) ??
  tokens[0] ??
  ''

const iconName = iconToken.startsWith('i-lucide-')
  ? iconToken.slice('i-lucide-'.length)
  : iconToken.startsWith('lucide:')
    ? iconToken.slice('lucide:'.length)
    : iconToken

const iconAliases: Record<string, string> = {
  'check-circle': 'circle-check',
}

const mergedClassName = [
  tokens.filter((token) => token !== iconToken).join(' '),
  className,
]
  .filter(Boolean)
  .join(' ')

const iconData = lucideIcons.icons[iconAliases[iconName] ?? iconName]
---

{
  iconData && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="1em"
      height="1em"
      viewBox={`0 0 ${iconData.width ?? 24} ${iconData.height ?? 24}`}
      class={mergedClassName}
      role={label ? 'img' : undefined}
      aria-label={label}
      aria-hidden={label ? undefined : 'true'}
      focusable="false"
    >
      <Fragment set:html={iconData.body} />
    </svg>
  )
}