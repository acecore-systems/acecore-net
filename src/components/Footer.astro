---
import { SITE } from '../data/site'
import { t, getLocalizedUrl, getLocaleFromUrl, type Locale } from '../i18n'
import { getSchoolsUrl } from '../utils/schools-url'

interface Props {
  locale?: Locale
}

const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const currentYear = new Date().getFullYear()
const u = (path: string) => getLocalizedUrl(path, locale)
---

<footer class="bg-slate-900 text-slate-300">
  <div class="ac-container py-14">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-[1.2fr_1fr_1fr]">
      <div>
        <h3 class="mb-3 text-lg font-700 text-white">Acecore</h3>
        <p class="text-sm leading-relaxed">
          {t(locale, 'footer.tagline')}<br />
          {t(locale, 'footer.description')}
        </p>
      </div>
      <div>
        <h3 class="mb-3 text-lg font-700 text-white">
          {t(locale, 'footer.sitemap')}
        </h3>
        <ul class="m-0 list-none p-0 text-sm" role="list">
          <li>
            <a
              href={u('/')}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >{t(locale, 'nav.home')}</a
            >
          </li>
          <li>
            <a
              href={u('/services/')}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >{t(locale, 'nav.services')}</a
            >
          </li>
          <li>
            <a
              href={getSchoolsUrl(locale)}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >{t(locale, 'footer.schools')}</a
            >
          </li>
          <li>
            <a
              href={SITE.social.systems}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >Acecore Systems</a
            >
          </li>
          <li>
            <a
              href={u('/acestudio/')}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >AceStudio</a
            >
          </li>
          <li>
            <a
              href={u('/about/')}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >{t(locale, 'nav.about')}</a
            >
          </li>
          <li>
            <a
              href={u('/blog/')}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >{t(locale, 'nav.blog')}</a
            >
          </li>
          <li>
            <a
              href={u('/contact/')}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              data-ga-event="cta_click"
              data-ga-label="footer_contact"
              data-ga-location="footer"
              data-ga-destination={u('/contact/')}>{t(locale, 'nav.contact')}</a
            >
          </li>
          <li>
            <a
              href={u('/privacy/')}
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              >{t(locale, 'footer.privacy')}</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-lg font-700 text-white">
          {t(locale, 'footer.relatedLinks')}
        </h3>
        <ul class="m-0 list-none p-0 text-sm" role="list">
          <li>
            <a
              href={SITE.social.aceserver}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              data-ga-event="external_link_click"
              data-ga-label="footer_aceserver"
              data-ga-location="footer"
              data-ga-destination={SITE.social.aceserver}
              >Aceserver<span class="sr-only"
                >{t(locale, 'common.opensInNewTab')}</span
              ></a
            >
          </li>
          <li>
            <a
              href={SITE.social.x}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              data-ga-event="external_link_click"
              data-ga-label="footer_x"
              data-ga-location="footer"
              data-ga-destination={SITE.social.x}
              >X<span class="sr-only">{t(locale, 'common.opensInNewTab')}</span
              ></a
            >
          </li>
          <li>
            <a
              href={SITE.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-10 items-center rounded-md px-2 -mx-2 text-slate-300 no-underline transition-colors hover:bg-white/5 hover:text-white"
              data-ga-event="external_link_click"
              data-ga-label="footer_github"
              data-ga-location="footer"
              data-ga-destination={SITE.social.github}
              >GitHub<span class="sr-only"
                >{t(locale, 'common.opensInNewTab')}</span
              ></a
            >
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-slate-700 pt-8 text-center text-sm">
      <p>&copy;{currentYear} Acecore</p>
    </div>
  </div>
</footer>
