---
import { SITE } from '../data/site'
const currentYear = new Date().getFullYear()
---

<footer class="bg-slate-900 text-slate-300">
  <div class="ac-container py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-700 text-white text-lg mb-4">Acecore</h3>
        <p class="text-sm leading-relaxed">
          技術でつながる、クリエイティブで広がる。<br />
          多様な価値を創出するテクノロジー集団です。
        </p>
      </div>
      <div>
        <h3 class="font-700 text-white text-lg mb-4">サイトマップ</h3>
        <ul class="space-y-0 text-sm list-none p-0 m-0" role="list">
          <li>
            <a
              href="/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3 min-w-11"
              >ホーム</a
            >
          </li>
          <li>
            <a
              href="/services/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >サービス</a
            >
          </li>
          <li>
            <a
              href="/schools/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >Acecore Schools</a
            >
          </li>
          <li>
            <a
              href="/acestudio/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >AceStudio</a
            >
          </li>
          <li>
            <a
              href="/about/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >会社概要</a
            >
          </li>
          <li>
            <a
              href="/blog/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3 min-w-11"
              >ブログ</a
            >
          </li>
          <li>
            <a
              href="/contact/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >お問い合わせ</a
            >
          </li>
          <li>
            <a
              href="/privacy/"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >プライバシーポリシー</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h3 class="font-700 text-white text-lg mb-4">関連リンク</h3>
        <ul class="space-y-0 text-sm list-none p-0 m-0" role="list">
          <li>
            <a
              href={SITE.social.aceserver}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >Aceserver<span class="sr-only">（新しいタブで開きます）</span></a
            >
          </li>
          <li>
            <a
              href={SITE.social.x}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3 min-w-11"
              >X<span class="sr-only">（新しいタブで開きます）</span></a
            >
          </li>
          <li>
            <a
              href={SITE.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-300 hover:text-white no-underline transition-colors inline-block py-3"
              >GitHub<span class="sr-only">（新しいタブで開きます）</span></a
            >
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-slate-700 mt-8 pt-8 text-center text-sm">
      <p>&copy;{currentYear} Acecore</p>
    </div>
  </div>
</footer>
