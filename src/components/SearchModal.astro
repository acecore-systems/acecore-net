---
import { SITE } from '../data/site'
import { t, getLocaleFromUrl, getLocalizedUrl, type Locale } from '../i18n'

interface Props {
  locale?: Locale
}

const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
---

<dialog
  id="search-dialog"
  class="fixed inset-0 z-100 m-0 h-full w-full max-h-full max-w-full bg-transparent backdrop:bg-black/50"
  aria-labelledby="search-dialog-title"
  data-locale={locale}
  data-t-search-title={t(locale, 'common.search')}
  data-t-close={t(locale, 'common.close')}
  data-t-loading={t(locale, 'blog.searchLoading')}
  data-t-error={t(locale, 'blog.searchError')}
  data-t-retry={t(locale, 'blog.searchRetry')}
  data-t-placeholder={t(locale, 'common.searchPlaceholder')}
  data-t-zero-results={t(locale, 'blog.zeroResults')}
  data-t-many-results={t(locale, 'blog.manyResults')}
  data-t-one-result={t(locale, 'blog.oneResult')}
  data-t-filters={t(locale, 'blog.filtersLabel')}
  data-t-fallback-heading={t(locale, 'blog.searchFallbackHeading')}
  data-t-fallback-blog={t(locale, 'blog.searchFallbackBlogList')}
  data-t-fallback-services={t(locale, 'blog.searchFallbackServiceList')}
  data-t-fallback-contact={t(locale, 'blog.searchFallbackContact')}
  data-link-blog={getLocalizedUrl('/blog/', locale)}
  data-link-services={getLocalizedUrl('/services/', locale)}
  data-link-contact={getLocalizedUrl('/contact/', locale)}
>
  <div
    class="flex items-start justify-center min-h-full pt-16 sm:pt-24 px-4 pb-8"
  >
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl overflow-hidden">
      <div
        class="flex items-center justify-between px-4 pt-4 pb-2 border-b border-slate-200"
      >
        <span
          id="search-dialog-title"
          class="text-sm font-700 text-slate-700 flex items-center gap-2"
        >
          <div class="i-lucide-search text-sm" aria-hidden="true"></div>
          {t(locale, 'common.search')}
        </span>
        <button
          id="search-close"
          class="p-1.5 rounded-md text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors"
          aria-label={t(locale, 'common.close')}
        >
          <div class="i-lucide-x text-lg" aria-hidden="true"></div>
        </button>
      </div>
      <div id="search-container" class="px-4 pt-4 pb-2"></div>
      <div
        id="search-ad"
        class="hidden px-4 pb-4 border-t border-slate-100 mt-2 pt-3"
      >
        <ins
          class="adsbygoogle"
          style="display:block"
          data-ad-client={SITE.adsenseClientId}
          data-ad-slot={SITE.adSlotId}
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
      </div>
    </div>
  </div>
</dialog>
