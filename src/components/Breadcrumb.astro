---
import Icon from './Icon.astro'
import { t, getLocaleFromUrl, getLocalizedUrl, type Locale } from '../i18n'

interface BreadcrumbItem {
  label: string
  href?: string
}
interface Props {
  items: BreadcrumbItem[]
  locale?: Locale
}
const { items } = Astro.props
const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const currentPath = Astro.url.pathname
---

<nav aria-label={t(locale, 'common.breadcrumb')} class="text-sm mb-4" data-pagefind-ignore>
  <ol class="flex flex-wrap items-center gap-1 text-slate-500" role="list">
    <li>
      <a
        href={getLocalizedUrl('/', locale)}
        class="hover:text-brand-500 transition-colors inline-flex items-center gap-1"
      >
        <Icon name="home" class="text-xs" />
        <span>{t(locale, 'common.home')}</span>
      </a>
    </li>
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1">
          <Icon name="chevron-right" class="text-xs text-slate-400" />
          {(item.href || i === items.length - 1) ? (
            <a
              href={item.href ?? currentPath}
              aria-current={i === items.length - 1 ? 'page' : undefined}
              class:list={[
                'transition-colors',
                i === items.length - 1
                  ? 'text-slate-700 font-600 truncate max-w-60 sm:max-w-none'
                  : 'hover:text-brand-500',
              ]}
            >
              {item.label}
            </a>
          ) : (
            <span class="text-slate-700 font-600 truncate max-w-60 sm:max-w-none">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
