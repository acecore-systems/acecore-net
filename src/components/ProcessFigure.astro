---
interface StepItem {
  title: string
  description: string
  icon: string
  accent?: 'brand' | 'emerald' | 'amber' | 'slate'
}

interface Props {
  eyebrow?: string
  title: string
  description?: string
  steps: StepItem[]
}

const { eyebrow, title, description, steps } = Astro.props

const accents = {
  brand: {
    card: 'from-brand-50 via-white to-brand-100/70 border-brand-100',
    icon: 'bg-brand-100 text-brand-700',
    badge: 'text-brand-700',
    arrow: 'text-brand-300',
  },
  emerald: {
    card: 'from-emerald-50 via-white to-emerald-100/70 border-emerald-100',
    icon: 'bg-emerald-100 text-emerald-700',
    badge: 'text-emerald-700',
    arrow: 'text-emerald-300',
  },
  amber: {
    card: 'from-amber-50 via-white to-amber-100/70 border-amber-100',
    icon: 'bg-amber-100 text-amber-700',
    badge: 'text-amber-700',
    arrow: 'text-amber-300',
  },
  slate: {
    card: 'from-slate-50 via-white to-slate-100/80 border-slate-200',
    icon: 'bg-slate-100 text-slate-700',
    badge: 'text-slate-700',
    arrow: 'text-slate-300',
  },
} satisfies Record<NonNullable<StepItem['accent']>, Record<string, string>>
---

<div class="ac-card overflow-hidden bg-white">
  <div class="border-b border-slate-200 bg-[radial-gradient(circle_at_top_left,_rgba(38,75,125,0.12),_transparent_45%),linear-gradient(135deg,rgba(248,250,252,0.95),rgba(255,255,255,1))] px-6 py-4 sm:px-8">
    {eyebrow && <p class="text-xs font-700 tracking-[0.18em] text-brand-500 uppercase mb-2">{eyebrow}</p>}
    <div class="max-w-3xl">
      <h2 class="text-xl sm:text-2xl ac-heading mb-2">{title}</h2>
      {description && <p class="text-sm ac-muted leading-relaxed">{description}</p>}
    </div>
  </div>

  <div class="grid gap-3 px-6 py-5 sm:px-8 sm:grid-cols-2 lg:grid-cols-4">
    {steps.map((step, index) => {
      const accent = accents[step.accent ?? 'brand']

      return (
        <div class="relative">
          <article class:list={[
            'h-full rounded-xl border bg-gradient-to-br px-4 py-3.5 shadow-sm',
            accent.card,
          ]}>
            <div class="flex items-center gap-2.5 mb-2">
              <div class:list={['flex h-8 w-8 items-center justify-center rounded-lg text-base shrink-0', accent.icon]}>
                <div class={step.icon}></div>
              </div>
              <span class:list={['text-[10px] font-700 tracking-[0.2em] uppercase', accent.badge]}>
                Step {index + 1}
              </span>
            </div>
            <h3 class="text-sm font-700 text-slate-900 mb-1">{step.title}</h3>
            <p class="text-xs leading-5 text-slate-600">{step.description}</p>
          </article>

          {index < steps.length - 1 && (
            <div class:list={[
              'hidden lg:flex absolute right-[-0.55rem] top-1/2 z-10 h-5 w-5 -translate-y-1/2 items-center justify-center rounded-full bg-white shadow-sm',
              accent.arrow,
            ]}>
              <div class="i-lucide-arrow-right text-xs"></div>
            </div>
          )}
        </div>
      )
    })}
  </div>
</div>