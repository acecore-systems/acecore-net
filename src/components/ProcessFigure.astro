---
import Icon from './Icon.astro'

interface StepItem {
  title: string
  description: string
  icon: string
  accent?: 'brand' | 'emerald' | 'amber' | 'slate'
}

interface Props {
  eyebrow?: string
  title: string
  description?: string
  steps: readonly StepItem[]
  variant?: 'card' | 'inline'
}

const { eyebrow, title, description, steps, variant = 'inline' } = Astro.props

const accents = {
  brand: 'text-brand-600 bg-brand-50 border-brand-200',
  emerald: 'text-emerald-600 bg-emerald-50 border-emerald-200',
  amber: 'text-amber-600 bg-amber-50 border-amber-200',
  slate: 'text-slate-500 bg-slate-50 border-slate-200',
} satisfies Record<NonNullable<StepItem['accent']>, string>

const cardAccents = {
  brand: {
    card: 'from-brand-50 via-white to-brand-50/50 border-brand-100',
    icon: 'bg-brand-100 text-brand-700',
    badge: 'text-brand-600',
    arrow: 'text-brand-300',
  },
  emerald: {
    card: 'from-emerald-50 via-white to-emerald-50/50 border-emerald-100',
    icon: 'bg-emerald-100 text-emerald-700',
    badge: 'text-emerald-600',
    arrow: 'text-emerald-300',
  },
  amber: {
    card: 'from-amber-50 via-white to-amber-50/50 border-amber-100',
    icon: 'bg-amber-100 text-amber-700',
    badge: 'text-amber-600',
    arrow: 'text-amber-300',
  },
  slate: {
    card: 'from-slate-50 via-white to-slate-50/50 border-slate-200',
    icon: 'bg-slate-100 text-slate-600',
    badge: 'text-slate-500',
    arrow: 'text-slate-300',
  },
} satisfies Record<NonNullable<StepItem['accent']>, Record<string, string>>

const isCard = variant === 'card'
---

{
  isCard ? (
    <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
      <div class="border-b border-slate-200 bg-slate-50/50 px-6 py-4 sm:px-8">
        {eyebrow && (
          <p class="text-[11px] font-700 tracking-[0.18em] text-brand-500 uppercase mb-2">
            {eyebrow}
          </p>
        )}
        <div class="max-w-3xl">
          <h2 class="text-xl sm:text-2xl ac-heading mb-2">{title}</h2>
          {description && (
            <p class="text-sm ac-muted leading-relaxed">{description}</p>
          )}
        </div>
      </div>
      <div class="grid gap-3 px-6 py-5 sm:px-8 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((step, index) => {
          const ca = cardAccents[step.accent ?? 'brand']
          return (
            <div class="relative">
              <div
                class:list={[
                  'h-full rounded-xl border bg-gradient-to-br px-4 py-3 shadow-sm',
                  ca.card,
                ]}
              >
                <div class="flex items-center gap-2.5 mb-1.5">
                  <div
                    class:list={[
                      'flex h-7 w-7 items-center justify-center rounded-lg text-sm shrink-0',
                      ca.icon,
                    ]}
                  >
                    <Icon name={step.icon} />
                  </div>
                  <span
                    class:list={[
                      'text-[10px] font-700 tracking-[0.2em] uppercase',
                      ca.badge,
                    ]}
                  >
                    Step {index + 1}
                  </span>
                </div>
                <p class="text-sm font-700 text-slate-900 mb-0.5">
                  {step.title}
                </p>
                <p class="text-xs leading-relaxed text-slate-600">
                  {step.description}
                </p>
              </div>
              {index < steps.length - 1 && (
                <div
                  class:list={[
                    'hidden lg:flex absolute right-[-0.55rem] top-1/2 z-10 h-5 w-5 -translate-y-1/2 items-center justify-center rounded-full bg-white shadow-sm',
                    ca.arrow,
                  ]}
                >
                  <Icon name="arrow-right" class="text-xs" />
                </div>
              )}
            </div>
          )
        })}
      </div>
    </div>
  ) : (
    <figure class="not-prose my-8" role="group" aria-label={title}>
      {(eyebrow || title) && (
        <figcaption class="mb-4">
          {eyebrow && (
            <p class="text-[11px] font-700 tracking-[0.18em] text-brand-500 uppercase mb-1">
              {eyebrow}
            </p>
          )}
          <p class="text-base font-700 text-slate-800">{title}</p>
          {description && (
            <p class="text-sm text-slate-500 mt-1">{description}</p>
          )}
        </figcaption>
      )}
      <div class="flex flex-col sm:flex-row gap-0">
        {steps.map((step, index) => {
          const accent = accents[step.accent ?? 'brand']
          return (
            <div class="flex sm:flex-col items-start sm:items-center sm:flex-1 gap-3 sm:gap-0 sm:text-center">
              <div class="flex flex-col sm:flex-row items-center shrink-0">
                {index > 0 && (
                  <div class="hidden sm:block w-full h-px bg-slate-200 flex-1" />
                )}
                {index > 0 && <div class="sm:hidden w-px h-4 bg-slate-200" />}
                <div
                  class:list={[
                    'flex h-9 w-9 items-center justify-center rounded-full border text-base shrink-0',
                    accent,
                  ]}
                >
                  <div class={step.icon} />
                </div>
                {index < steps.length - 1 && (
                  <div class="hidden sm:block w-full h-px bg-slate-200 flex-1" />
                )}
              </div>
              <div class="sm:mt-2 sm:px-2 py-1 sm:py-0">
                <p class="text-sm font-600 text-slate-800">{step.title}</p>
                <p class="text-[13px] leading-relaxed text-slate-500">
                  {step.description}
                </p>
              </div>
            </div>
          )
        })}
      </div>
    </figure>
  )
}
