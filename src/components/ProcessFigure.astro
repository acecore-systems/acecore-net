---
interface StepItem {
  title: string
  description: string
  icon: string
  accent?: 'brand' | 'emerald' | 'amber' | 'slate'
}

interface Props {
  eyebrow?: string
  title: string
  description?: string
  steps: StepItem[]
}

const { eyebrow, title, description, steps } = Astro.props

const accents = {
  brand: 'text-brand-600 bg-brand-50 border-brand-200',
  emerald: 'text-emerald-600 bg-emerald-50 border-emerald-200',
  amber: 'text-amber-600 bg-amber-50 border-amber-200',
  slate: 'text-slate-500 bg-slate-50 border-slate-200',
} satisfies Record<NonNullable<StepItem['accent']>, string>
---

<figure class="not-prose my-8" role="img" aria-label={title}>
  {(eyebrow || title) && (
    <figcaption class="mb-4">
      {eyebrow && <p class="text-[11px] font-700 tracking-[0.18em] text-brand-400 uppercase mb-1">{eyebrow}</p>}
      <p class="text-base font-700 text-slate-800">{title}</p>
      {description && <p class="text-sm text-slate-500 mt-1">{description}</p>}
    </figcaption>
  )}
  <div class="flex flex-col sm:flex-row gap-0">
    {steps.map((step, index) => {
      const accent = accents[step.accent ?? 'brand']
      return (
        <div class="flex sm:flex-col items-start sm:items-center sm:flex-1 gap-3 sm:gap-0 sm:text-center">
          {/* connector + icon */}
          <div class="flex flex-col sm:flex-row items-center shrink-0">
            {index > 0 && <div class="hidden sm:block w-full h-px bg-slate-200 flex-1" />}
            {index > 0 && <div class="sm:hidden w-px h-4 bg-slate-200" />}
            <div class:list={['flex h-9 w-9 items-center justify-center rounded-full border text-base shrink-0', accent]}>
              <div class={step.icon}></div>
            </div>
            {index < steps.length - 1 && <div class="hidden sm:block w-full h-px bg-slate-200 flex-1" />}
          </div>
          {/* text */}
          <div class="sm:mt-2 sm:px-2 py-1 sm:py-0">
            <p class="text-sm font-600 text-slate-800">{step.title}</p>
            <p class="text-[13px] leading-relaxed text-slate-500">{step.description}</p>
          </div>
        </div>
      )
    })}
  </div>
</figure>