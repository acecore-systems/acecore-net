---
interface Props {
  adSlot: string
}

const { adSlot } = Astro.props
const CLIENT_ID = 'ca-pub-3935803464310919'
---

<ins
  class="adsbygoogle"
  style="display:block"
  data-ad-client={CLIENT_ID}
  data-ad-slot={adSlot}
  data-ad-format="auto"
  data-full-width-responsive="true"
></ins>
<script is:inline>
  (adsbygoogle = window.adsbygoogle || []).push({});
</script>
