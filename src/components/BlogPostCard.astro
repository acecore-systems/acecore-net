---
import {
  optimizeImage,
  generateSrcSet,
  resolveImageSource,
} from '../utils/image'
import {
  formatDate,
  getLocaleFromUrl,
  getLocalizedUrl,
  type Locale,
} from '../i18n'
import { getBaseSlug, getLocalizedAuthor } from '../utils/blog-i18n'
import { getAllAuthors, findAuthorById } from '../utils/authors'
import { getAllTags, getLocalizedTagName } from '../utils/tags'

interface Props {
  post: {
    id: string
    data: {
      title: string
      description: string
      date: Date
      image?: string
      uploadedImage?: string
      author?: string
      tags?: string[]
    }
  }
  locale?: Locale
}

const { post } = Astro.props
const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const baseSlug = getBaseSlug(post.id)
const postImage = resolveImageSource(post.data.uploadedImage, post.data.image)
const authors = await getAllAuthors()
const tags = await getAllTags()
const rawAuthor = findAuthorById(authors, post.data.author)
const author = rawAuthor ? getLocalizedAuthor(rawAuthor, locale) : null
---

<article
  class="ac-card group relative overflow-hidden transition-all duration-200 hover:border-brand-200 hover:shadow-md"
>
  <div class="flex flex-col sm:flex-row">
    {
      postImage && (
        <div class="bg-slate-100 sm:w-52 sm:shrink-0">
          <img
            src={optimizeImage(postImage)}
            srcset={generateSrcSet(postImage, [200, 400, 800])}
            sizes="(min-width: 640px) 208px, 100vw"
            alt={post.data.title}
            class="h-44 w-full object-cover sm:h-full"
            width="208"
            height="160"
            decoding="async"
            loading="lazy"
          />
        </div>
      )
    }
    <div class="p-6 sm:p-7">
      <div
        class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500"
      >
        <time datetime={post.data.date.toISOString()}
          >{formatDate(post.data.date, locale)}</time
        >
        {
          post.data.author && (
            <a
              href={getLocalizedUrl(
                `/blog/authors/${post.data.author}/`,
                locale,
              )}
              class="relative z-10 text-brand-600 underline underline-offset-3 hover:text-brand-700"
            >
              by {author?.name || post.data.author}
            </a>
          )
        }
      </div>
      <h2
        class="mt-3 mb-3 text-xl font-700 leading-snug text-slate-900 transition-colors group-hover:text-brand-600"
      >
        <a
          href={getLocalizedUrl(`/blog/${baseSlug}/`, locale)}
          class="text-inherit no-underline after:absolute after:inset-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
          >{post.data.title}</a
        >
      </h2>
      <p class="leading-relaxed text-slate-600">{post.data.description}</p>
      {
        post.data.tags && (
          <div class="mt-5 flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="ac-chip bg-brand-50 text-brand-600 hover:bg-brand-50 hover:text-brand-600">
                {getLocalizedTagName(tags, tag, locale)}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</article>
