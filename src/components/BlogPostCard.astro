---
import {
  optimizeImage,
  generateSrcSet,
  resolveImageSource,
} from '../utils/image'
import {
  formatDate,
  getLocaleFromUrl,
  getLocalizedUrl,
  type Locale,
} from '../i18n'
import { getBaseSlug, getLocalizedAuthor } from '../utils/blog-i18n'
import { getAllAuthors, findAuthorById } from '../utils/authors'
import { getAllTags, getLocalizedTagName } from '../utils/tags'
import Icon from './Icon.astro'

interface Props {
  post: {
    id: string
    data: {
      title: string
      description: string
      date: Date
      image?: string
      uploadedImage?: string
      author?: string
      tags?: string[]
    }
  }
  locale?: Locale
}

const { post } = Astro.props
const locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url)
const baseSlug = getBaseSlug(post.id)
const postImage = resolveImageSource(post.data.uploadedImage, post.data.image)
const authors = await getAllAuthors()
const tags = await getAllTags()
const rawAuthor = findAuthorById(authors, post.data.author)
const author = rawAuthor ? getLocalizedAuthor(rawAuthor, locale) : null
---

<article
  class="ac-card ac-rule-top group relative overflow-hidden transition-colors duration-200 hover:border-brand-200 hover:bg-slate-50/30 hover:shadow-[0_18px_38px_rgba(15,35,56,0.1)]"
>
  <a
    href={getLocalizedUrl(`/blog/${baseSlug}/`, locale)}
    class="absolute inset-0 z-10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
    aria-label={post.data.title}></a>
  <div class="flex flex-col sm:flex-row">
    {
      postImage && (
        <div class="overflow-hidden border-b border-slate-200 bg-slate-100 sm:w-56 sm:shrink-0 sm:border-b-0 sm:border-r">
          <img
            src={optimizeImage(postImage)}
            srcset={generateSrcSet(postImage, [200, 400, 800])}
            sizes="(min-width: 640px) 224px, 100vw"
            alt={post.data.title}
            class="h-44 w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] sm:h-full"
            width="224"
            height="168"
            decoding="async"
            loading="lazy"
          />
        </div>
      )
    }
    <div class="p-6 sm:p-7">
      <div
        class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-700 text-slate-500"
      >
        <time datetime={post.data.date.toISOString()}
          >{formatDate(post.data.date, locale)}</time
        >
        {
          post.data.author && (
            <a
              href={getLocalizedUrl(
                `/blog/authors/${post.data.author}/`,
                locale,
              )}
              class="relative z-20 text-brand-600 underline underline-offset-3 hover:text-brand-700"
            >
              by {author?.name || post.data.author}
            </a>
          )
        }
      </div>
      <h2
        class="mt-3 mb-3 break-words text-xl font-800 leading-snug text-slate-950 transition-colors group-hover:text-brand-600"
      >
        {post.data.title}
      </h2>
      <p class="leading-relaxed text-slate-600">{post.data.description}</p>
      {
        post.data.tags && (
          <div class="mt-5 flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <a
                href={getLocalizedUrl(`/blog/tags/${tag}/`, locale)}
                class="ac-chip relative z-20 gap-1 border-brand-100 bg-brand-50 text-brand-600"
              >
                {getLocalizedTagName(tags, tag, locale)}
              </a>
            ))}
          </div>
        )
      }
      <span
        class="mt-5 inline-flex text-brand-600 transition-transform group-hover:translate-x-1"
        aria-hidden="true"
      >
        <Icon name="arrow-right" class="text-base" />
      </span>
    </div>
  </div>
</article>
