---
import Icon from './Icon.astro'
import type { ServiceWorkLink } from '../data/works'
import { t, getLocalizedUrl, type Locale } from '../i18n'

interface Props {
  locale: Locale
  gaLabel: string
  gaLocation: string
  workLink?: ServiceWorkLink
}

const { locale, gaLabel, gaLocation, workLink } = Astro.props
const u = (path: string) => getLocalizedUrl(path, locale)
const contactUrl = u('/contact/')
---

<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
  <a
    href={contactUrl}
    class="ac-btn-outline gap-2 text-sm sm:w-auto"
    data-ga-event="cta_click"
    data-ga-label={gaLabel}
    data-ga-location={gaLocation}
    data-ga-destination={contactUrl}
  >
    <Icon name="message-circle" class="text-sm" />
    {t(locale, 'pages.services.miniCta')}
  </a>
  {
    workLink && (
      <a
        href={u(workLink.href)}
        class="inline-flex min-h-11 items-center gap-2 text-sm font-600 text-brand-600 underline-offset-2 hover:text-brand-700 hover:underline"
      >
        <Icon name="briefcase-business" class="text-sm" />
        {workLink.label}: {workLink.title}
      </a>
    )
  }
</div>
