---
import Icon from './Icon.astro'
import { t } from '../i18n/utils'
import type { Locale } from '../i18n'

interface Props {
  icon: string
  title: string
  description: string
  href?: string
  locale?: Locale
  tone?: 'brand' | 'emerald' | 'amber' | 'slate'
}

const {
  icon,
  title,
  description,
  href,
  locale = 'ja',
  tone = 'brand',
} = Astro.props
const Tag = href ? 'a' : 'div'
const isExternal = href?.startsWith('http')

const iconToneClasses = {
  brand: 'border-brand-100 bg-brand-50 text-brand-600',
  emerald: 'border-emerald-100 bg-emerald-50 text-emerald-600',
  amber: 'border-amber-100 bg-amber-50 text-amber-600',
  slate: 'border-slate-200 bg-slate-50 text-slate-600',
} satisfies Record<NonNullable<Props['tone']>, string>
---

<Tag
  {...href ? { href } : {}}
  {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  class="ac-card group block h-full p-6 no-underline transition-all duration-200 hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-400 focus-visible:ring-offset-2"
  {...href
    ? {
        'data-ga-event': 'cta_click',
        'data-ga-label': title,
        'data-ga-location': 'service_card',
        'data-ga-destination': href,
      }
    : {}}
>
  <span
    class:list={[
      'mb-5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border',
      iconToneClasses[tone],
    ]}
  >
    <Icon name={icon} class="text-xl" />
  </span>
  <h3
    class="mb-3 text-lg font-700 leading-snug text-slate-900 transition-colors group-hover:text-brand-600"
  >
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-slate-600">{description}</p>
  {
    isExternal && (
      <span class="sr-only">{t(locale, 'common.opensInNewTab')}</span>
    )
  }
</Tag>
