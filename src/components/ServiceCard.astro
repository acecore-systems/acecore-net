---
interface Props {
  icon: string
  title: string
  description: string
}

const { icon, title, description } = Astro.props
---

<div class="ac-card p-6 sm:p-8 hover:shadow-md transition-shadow">
  <div class={`${icon} text-3xl text-brand-500 mb-4`}></div>
  <h3 class="text-lg font-700 text-slate-900 mb-3">{title}</h3>
  <p class="text-sm text-slate-600 leading-relaxed">{description}</p>
</div>
