---
import Icon from './Icon.astro'
import { t } from '../i18n/utils'
import type { Locale } from '../i18n'

interface Props {
  icon: string
  title: string
  description: string
  href?: string
  locale?: Locale
}

const { icon, title, description, href, locale = 'ja' } = Astro.props
const Tag = href ? 'a' : 'div'
const isExternal = href?.startsWith('http')
---

<Tag
  {...href ? { href } : {}}
  {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  class="ac-card p-6 sm:p-8 hover:shadow-md transition-shadow block no-underline group"
  {...href
    ? {
        'data-ga-event': 'cta_click',
        'data-ga-label': title,
        'data-ga-location': 'service_card',
        'data-ga-destination': href,
      }
    : {}}
>
  <Icon name={icon} class="text-3xl text-brand-500 mb-4" />
  <h3
    class="text-lg font-700 text-slate-900 mb-3 group-hover:text-brand-500 transition-colors"
  >
    {title}
  </h3>
  <p class="text-sm text-slate-600 leading-relaxed">{description}</p>
  {isExternal && <span class="sr-only">{t(locale, 'common.opensInNewTab')}</span>}
</Tag>
