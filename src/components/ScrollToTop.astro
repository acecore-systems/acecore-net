<button
  id="scroll-to-top"
  aria-label="ページトップに戻る"
  class="fixed bottom-20 lg:bottom-6 right-6 z-50 hidden w-11 h-11 rounded-full bg-brand-500 text-white shadow-lg hover:bg-brand-600 transition-all cursor-pointer items-center justify-center"
>
  <div class="i-lucide-chevron-up text-xl"></div>
</button>

<script>
  function initScrollToTop() {
    const btn = document.getElementById('scroll-to-top');
    if (!btn) return;
    const threshold = 400;

    const toggle = () => {
      btn.style.display = window.scrollY > threshold ? 'flex' : 'none';
    };

    window.addEventListener('scroll', toggle, { passive: true });
    btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    toggle();
  }

  initScrollToTop();
  document.addEventListener('astro:after-swap', initScrollToTop);
</script>
