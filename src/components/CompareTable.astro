---
import Icon from './Icon.astro'

interface Props {
  title?: string
  before: { label: string; items: string[] }
  after: { label: string; items: string[] }
}

const { title, before, after } = Astro.props
---

<figure class="not-prose my-8">
  {
    title && (
      <figcaption class="text-base font-700 text-slate-800 mb-3">
        {title}
      </figcaption>
    )
  }
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="text-sm font-700 text-slate-500 mb-2 flex items-center gap-1.5">
        <Icon name="circle-x" class="text-red-400 shrink-0" />
        {before.label}
      </p>
      <ul class="space-y-1.5">
        {
          before.items.map((item) => (
            <li class="text-[13px] text-slate-600 flex items-start gap-1.5">
              <Icon name="minus" class="text-slate-300 mt-0.5 shrink-0" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="rounded-lg bg-brand-50/80 border border-brand-100 p-4">
      <p class="text-sm font-700 text-brand-600 mb-2 flex items-center gap-1.5">
        <Icon name="circle-check" class="text-brand-500 shrink-0" />
        {after.label}
      </p>
      <ul class="space-y-1.5">
        {
          after.items.map((item) => (
            <li class="text-[13px] text-brand-700 flex items-start gap-1.5">
              <Icon name="check" class="text-brand-500 mt-0.5 shrink-0" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</figure>
