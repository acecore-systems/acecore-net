---
import { optimizeImage, generateSrcSet } from '../utils/image'

interface GalleryImage {
  src: string
  alt: string
}

interface Props {
  title?: string
  items: GalleryImage[]
  columns?: 2 | 3
}

const { title, items, columns = 2 } = Astro.props
---

<figure class="not-prose my-8">
  {
    title && (
      <figcaption class="text-base font-700 text-slate-800 mb-3">
        {title}
      </figcaption>
    )
  }
  <div
    class:list={['grid gap-2', columns === 3 ? 'grid-cols-3' : 'grid-cols-2']}
  >
    {
      items.map((item) => (
        <img
          src={optimizeImage(item.src)}
          srcset={generateSrcSet(item.src, [200, 400, 800])}
          sizes={
            columns === 3
              ? '(min-width: 768px) 33vw, 50vw'
              : '(min-width: 768px) 50vw, 100vw'
          }
          alt={item.alt}
          class="w-full rounded-lg object-cover aspect-video"
          width="400"
          height="225"
          decoding="async"
          loading="lazy"
        />
      ))
    }
  </div>
</figure>
