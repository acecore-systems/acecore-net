---
import Icon from './Icon.astro'

interface Props {
  type?: 'info' | 'warning' | 'tip' | 'note'
  title?: string
  text: string
}

const { type = 'info', title, text } = Astro.props

const styles: Record<string, { bg: string; icon: string; heading: string }> = {
  info: {
    bg: 'bg-blue-50 border-blue-200',
    icon: 'info text-blue-500',
    heading: 'text-blue-800',
  },
  warning: {
    bg: 'bg-amber-50 border-amber-200',
    icon: 'triangle-alert text-amber-500',
    heading: 'text-amber-800',
  },
  tip: {
    bg: 'bg-emerald-50 border-emerald-200',
    icon: 'lightbulb text-emerald-500',
    heading: 'text-emerald-800',
  },
  note: {
    bg: 'bg-slate-50 border-slate-200',
    icon: 'bookmark text-slate-500',
    heading: 'text-slate-700',
  },
}
const s = styles[type] ?? styles.info
---

<aside
  role="note"
  class:list={['not-prose my-8 rounded-lg border p-4 flex gap-3', s.bg]}
>
  <Icon name={s.icon} class="text-lg mt-0.5 shrink-0" />
  <div>
    {title && <p class:list={['text-sm font-700 mb-1', s.heading]}>{title}</p>}
    <p class="text-[13px] leading-relaxed text-slate-700">{text}</p>
  </div>
</aside>
