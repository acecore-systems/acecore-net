---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import ProcessFigure from '../components/ProcessFigure.astro'
import CompareTable from '../components/CompareTable.astro'
import { optimizeImage, generateSrcSet } from '../utils/image'
import { SITE } from '../data/site'

const learningSteps = [
  {
    title: '興味を見つける',
    description: '学習塾やロボット体験を通して、学ぶ入口を個別に探します。',
    icon: 'i-lucide-sparkles',
    accent: 'amber',
  },
  {
    title: '手を動かして理解する',
    description: '実機、マインクラフト、プログラミング演習で体験と理解を結び付けます。',
    icon: 'i-lucide-bot',
    accent: 'brand',
  },
  {
    title: '実践に接続する',
    description: 'Web開発やツール活用など、現実の課題に使える学びへ引き上げます。',
    icon: 'i-lucide-code-xml',
    accent: 'emerald',
  },
  {
    title: '継続できる形にする',
    description: '受験、資格、日常のIT活用まで含めて、本人に合う継続導線を作ります。',
    icon: 'i-lucide-flag',
    accent: 'slate',
  },
] as const

const learningCompare = {
  title: '学び方の違い',
  before: {
    label: '独学の場合',
    items: ['何から始めればいいか迷う', 'つまずいても相談できない', 'モチベーション維持が難しい', '実践との接続が見えない'],
  },
  after: {
    label: 'Acecore Schools',
    items: ['一人ひとりに合った入口を提案', '講師にいつでも質問できる', '体験を通じて自然に継続', '受験・資格・実務に直結'],
  },
}

const schoolsLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      "name": "Acecore Schools",
      "description": "学習塾・ロボットプログラミング・実践プログラミング・パソコン/スマホ・高卒認定など幅広い教育プログラムを提供するITスクールです。",
      "url": "https://acecore.net/schools/",
      "parentOrganization": { "@type": "Organization", "name": "Acecore", "url": "https://acecore.net" },
      "telephone": SITE.phoneIntl,
      "email": SITE.email,
    },
    { "@type": "Course", "name": "学習塾", "description": "一人ひとりの生徒に合わせた個別指導で、基礎から応用まで学力を身につけます。定期テスト・受験対策にも対応。", "provider": { "@type": "EducationalOrganization", "name": "Acecore Schools" }, "url": "https://acecore.net/schools/#juku" },
    { "@type": "Course", "name": "ロボット / プログラミング", "description": "ロボット工作・ロボットプログラミング・マインクラフトプログラミングを通じてプログラミングの基礎を学びます。", "provider": { "@type": "EducationalOrganization", "name": "Acecore Schools" }, "url": "https://acecore.net/schools/#robot-programming" },
    { "@type": "Course", "name": "実践プログラミング", "description": "HTML/CSS/JavaScript、Python/Node.js、データベース設計など実務で使えるプログラミング技術を習得します。", "provider": { "@type": "EducationalOrganization", "name": "Acecore Schools" }, "url": "https://acecore.net/schools/#practical-programming" },
    { "@type": "Course", "name": "パソコン / スマホ", "description": "基本操作からオフィスソフト活用、セキュリティ対策まで、日常やビジネスに必要なITスキルを身につけます。", "provider": { "@type": "EducationalOrganization", "name": "Acecore Schools" }, "url": "https://acecore.net/schools/#pc-smartphone" },
    { "@type": "Course", "name": "高卒認定", "description": "各科目ごとの試験対策、個人に合わせた学習計画、模擬試験で高卒認定試験合格をサポートします。", "provider": { "@type": "EducationalOrganization", "name": "Acecore Schools" }, "url": "https://acecore.net/schools/#ged" },
  ],
}
---

<BaseLayout
  title="Acecore Schools"
  description="Acecore Schoolsは、学習塾・ロボットプログラミング・実践プログラミング・パソコン/スマホ・高卒認定など幅広い教育プログラムを提供するITスクールです。"
  jsonLd={schoolsLd}
>
  <Hero
    title="Acecore Schools"
    subtitle="一人ひとりに合わせた指導で、確かなスキルを"
    images={[{src: optimizeImage('https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1400&h=600&fit=crop&q=80&fm=webp'), alt: '教室での学習風景'}]}
  />

  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      <Breadcrumb items={[{ label: 'Acecore Schools' }]} />
      <div class="mb-12">
        <ProcessFigure
          variant="card"
          eyebrow="Learning Flow"
          title="Acecore Schoolsの学びを流れで見る"
          description="興味の入口から実践、継続までを一本の学習導線として見せています。"
          steps={learningSteps}
        />
      </div>

      <p class="text-lg text-slate-600 leading-relaxed mb-12">
        お子さまから大人の方まで、一人ひとりの目標やペースに合わせた個別指導を行っています。<a href="/services/#education" class="ac-link">サービス一覧</a>での位置づけもご覧いただけます。
      </p>

      <!-- 学習塾 -->
      <div class="mb-16" id="juku">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-book-open text-3xl text-brand-500" aria-hidden="true"></div>
          <h2 class="text-2xl ac-heading">学習塾</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          私たちの学習塾では、一人ひとりの生徒に合わせた指導を行い、基礎から応用までの学力を身につけることができます。経験豊富な講師陣が、生徒の成長をサポートします。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">特徴</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              個別指導で一人ひとりの理解度に合わせた丁寧な授業
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              基礎の定着から応用力の養成まで段階的にサポート
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              定期テスト・受験対策にも対応
            </li>
          </ul>
        </div>
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&h=450&fit=crop&q=80&fm=webp')}
          srcset={generateSrcSet(optimizeImage('https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&h=450&fit=crop&q=80&fm=webp'))}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt="教室での個別指導の様子"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- ロボット/プログラミング -->
      <div class="mb-16" id="robot-programming">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-bot text-3xl text-brand-500" aria-hidden="true"></div>
          <h2 class="text-2xl ac-heading">ロボット / プログラミング</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          最先端の技術を取り入れたロボットプログラミングの授業を提供しています。実際のロボットを使用して、プログラミングの基礎を学ぶことができます。
        </p>
        <div class="space-y-4">
          <div class="bg-slate-50 rounded-lg p-6">
            <h3 class="font-600 text-slate-900 mb-2">ロボットコース</h3>
            <p class="text-sm text-slate-600">
              タミヤ工作シリーズなどを使用した実際のロボット工作を通じて、ものづくりの楽しさと基本的な仕組みを学びます。
            </p>
          </div>
          <div class="bg-slate-50 rounded-lg p-6">
            <h3 class="font-600 text-slate-900 mb-2">ロボット プログラミングコース</h3>
            <p class="text-sm text-slate-600">
              ロボットをプログラムで制御する技術を学びます。センサーやモーターの制御を通じて、論理的思考力を育みます。
            </p>
          </div>
          <div class="bg-slate-50 rounded-lg p-6">
            <h3 class="font-600 text-slate-900 mb-2">マインクラフト プログラミングコース</h3>
            <p class="text-sm text-slate-600">
              大人気ゲーム「マインクラフト」を活用してプログラミングの基礎を学びます。遊びながら自然とプログラミング的思考が身につきます。
            </p>
          </div>
        </div>
      </div>

      <div class="mb-16">
        <CompareTable
          title={learningCompare.title}
          before={learningCompare.before}
          after={learningCompare.after}
        />
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?w=800&h=450&fit=crop&q=80&fm=webp')}
          srcset={generateSrcSet(optimizeImage('https://images.unsplash.com/photo-1488590528505-98d2b5aba04b?w=800&h=450&fit=crop&q=80&fm=webp'))}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt="プログラミング学習に取り組む生徒"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- 実践プログラミング -->
      <div class="mb-16" id="practical-programming">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-code-2 text-3xl text-brand-500" aria-hidden="true"></div>
          <h2 class="text-2xl ac-heading">実践プログラミング</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          実際の業務で使用されるプログラミング技術を学ぶことができるカリキュラムを提供しています。実践的なスキルを身につけることで、即戦力として活躍できます。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">学べる内容</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              HTML / CSS / JavaScript によるWebフロントエンド開発
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              Python / Node.js などを使ったバックエンド開発
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              データベース設計・API構築・クラウド活用
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              Git / チーム開発のワークフロー
            </li>
          </ul>
        </div>
      </div>

      <!-- パソコン/スマホ -->
      <div class="mb-16" id="pc-smartphone">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-monitor-smartphone text-3xl text-brand-500" aria-hidden="true"></div>
          <h2 class="text-2xl ac-heading">パソコン / スマホ</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          日常生活やビジネスシーンで必要とされるパソコン・スマホの操作技術を学ぶことができます。初心者から上級者まで、幅広いレベルの授業を提供しています。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">対応レベル</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              パソコン・スマホの基本操作（初心者歓迎）
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              Word / Excel / PowerPoint などオフィスソフトの活用
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              メール・SNS・オンライン会議のセットアップと使い方
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              セキュリティ対策・トラブルシューティング
            </li>
          </ul>
        </div>
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&h=450&fit=crop&q=80&fm=webp')}
          srcset={generateSrcSet(optimizeImage('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&h=450&fit=crop&q=80&fm=webp'))}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt="パソコンで学習する受講生"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- 高卒認定 -->
      <div class="mb-16" id="ged">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-file-badge text-3xl text-brand-500" aria-hidden="true"></div>
          <h2 class="text-2xl ac-heading">高卒認定</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          高等学校を卒業していない方を対象とした、高卒認定試験の対策授業を行っています。専門的な知識や技術を身につけ、高卒の資格を取得するサポートをします。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">サポート内容</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              各科目ごとの試験対策（国語・数学・英語・社会・理科）
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              個人の学力に合わせた学習計画の作成
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0" aria-hidden="true"></div>
              模擬試験・過去問演習による実践的な対策
            </li>
          </ul>
        </div>
      </div>

      <!-- お問い合わせ・申し込み -->
      <div class="bg-brand-50 rounded-xl p-8 text-center">
        <h2 class="text-xl ac-heading mb-4">お問い合わせ・お申し込み</h2>
        <p class="text-slate-600 mb-6">
          各コースの詳細やお申し込みは、お電話・メール・LINEで受け付けています。「どのコースが合うか分からない」というご相談もお気軽にどうぞ。
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-6">
          <div class="flex items-center gap-2">
            <div class="i-lucide-phone text-brand-500" aria-hidden="true"></div>
            <span class="font-600 text-slate-800">{SITE.phone}</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="i-lucide-mail text-brand-500" aria-hidden="true"></div>
            <a href={`mailto:${SITE.email}`} class="font-600 text-brand-500 hover:underline">{SITE.email}</a>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact/" class="ac-btn-primary">お問い合わせフォーム</a>
          <a
            href={SITE.line}
            target="_blank"
            rel="noopener noreferrer"
            class="ac-btn-outline"
          >
            LINEで問い合わせる<span class="sr-only">（新しいタブで開きます）</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
