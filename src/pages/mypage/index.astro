---
/**
 * マイページ
 *
 * ログイン済みユーザーの基本情報を表示する。
 * 認証チェックは functions/mypage/_middleware.ts で実施。
 * ユーザー情報はクライアント側で API から取得して描画する。
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="マイページ" robots="noindex, nofollow">
  <main class="max-w-2xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold">マイページ</h1>
      <button
        id="sign-out"
        class="text-sm text-slate-500 hover:text-red-600 transition-colors"
      >
        ログアウト
      </button>
    </div>

    <div id="loading" class="text-center text-slate-500 py-8">
      読み込み中...
    </div>

    <div id="content" class="hidden">
      <section class="bg-white rounded-lg border border-slate-200 p-6 mb-6">
        <h2 class="text-lg font-semibold mb-4">アカウント情報</h2>
        <dl class="space-y-3 text-sm">
          <div class="flex gap-4">
            <dt class="text-slate-500 w-32 shrink-0">メールアドレス</dt>
            <dd id="user-email"></dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-slate-500 w-32 shrink-0">ステータス</dt>
            <dd id="user-status"></dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-slate-500 w-32 shrink-0">ロール</dt>
            <dd id="user-roles"></dd>
          </div>
        </dl>
      </section>

      <section class="bg-white rounded-lg border border-slate-200 p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold">プロフィール</h2>
          <a
            href="/mypage/profile"
            class="text-sm text-brand-500 hover:text-brand-600 transition-colors"
          >
            編集
          </a>
        </div>
        <dl class="space-y-3 text-sm">
          <div class="flex gap-4">
            <dt class="text-slate-500 w-32 shrink-0">表示名</dt>
            <dd id="profile-name"></dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-slate-500 w-32 shrink-0">電話番号</dt>
            <dd id="profile-phone"></dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-slate-500 w-32 shrink-0">自己紹介</dt>
            <dd id="profile-bio" class="whitespace-pre-wrap"></dd>
          </div>
        </dl>
      </section>
    </div>
  </main>
</BaseLayout>

<script>
  async function loadUserData() {
    const res = await fetch('/api/me')
    if (!res.ok) {
      window.location.href = '/login'
      return
    }

    const data = await res.json()
    const { user, profile, roles } = data

    if (user) {
      setText('user-email', user.email)
      setText('user-status', user.status)
      setText('user-roles', roles.length > 0 ? roles.join(', ') : 'user')
    }

    setText('profile-name', profile?.displayName ?? '未設定')
    setText('profile-phone', profile?.phone ?? '未設定')
    setText('profile-bio', profile?.bio ?? '未設定')

    document.getElementById('loading')?.classList.add('hidden')
    document.getElementById('content')?.classList.remove('hidden')
  }

  function setText(id: string, text: string) {
    const el = document.getElementById(id)
    if (el) el.textContent = text
  }

  loadUserData()

  document.getElementById('sign-out')?.addEventListener('click', async () => {
    await fetch('/api/auth/sign-out', { method: 'POST' })
    window.location.href = '/login'
  })
</script>
