---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import BlogPostCard from '../../../components/BlogPostCard.astro'
import BlogSidebar from '../../../components/BlogSidebar.astro'
import { getCollection } from 'astro:content'
import authors from '../../../data/authors.json'

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  )
  const authorMap = new Map<string, typeof allPosts>()
  for (const post of allPosts) {
    if (post.data.author) {
      const list = authorMap.get(post.data.author) ?? []
      list.push(post)
      authorMap.set(post.data.author, list)
    }
  }
  return [...authorMap.entries()].map(([authorId, posts]) => ({
    params: { author: authorId },
    props: { authorId, posts, allPosts },
  }))
}

const { authorId, posts, allPosts } = Astro.props
const author = authors.find((a) => a.id === authorId)
const authorName = author?.name ?? authorId
---

<BaseLayout
  title={`${authorName} の記事一覧`}
  description={`${authorName} が執筆した記事の一覧です。`}
>
  <section class="ac-section">
    <div class="ac-container">
      <Breadcrumb items={[
        { label: 'ブログ', href: '/blog/' },
        { label: `著者: ${authorName}` },
      ]} />
      <div class="flex items-center gap-4 mb-8">
        {author && (author.avatarImage || author.avatar) ? (
          <img
            src={author.avatarImage || author.avatar}
            alt={authorName}
            class="w-16 h-16 rounded-full object-cover shrink-0"
            width="64"
            height="64"
            decoding="async"
          />
        ) : (
          <div class="w-16 h-16 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xl font-700 shrink-0">
            {authorName.charAt(0)}
          </div>
        )}
        <div>
          <h1 class="text-2xl sm:text-3xl ac-heading">
            {authorName}
          </h1>
          <p class="text-sm text-slate-500 mt-1">{posts.length}件の記事</p>
          {author?.bio && (
            <p class="text-sm text-slate-600 mt-2 whitespace-pre-line">{author.bio}</p>
          )}
        </div>
      </div>
      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
      <div class="space-y-6">
        {posts.map((post) => (
          <BlogPostCard post={post} />
        ))}
      </div>
      <BlogSidebar allPosts={allPosts} />
      </div>
    </div>
  </section>
</BaseLayout>
