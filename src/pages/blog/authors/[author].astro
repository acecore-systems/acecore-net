---
import BlogAuthorPage from '../../../views/BlogAuthorPage.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  )
  const authorMap = new Map<string, typeof allPosts>()
  for (const post of allPosts) {
    if (post.data.author) {
      const list = authorMap.get(post.data.author) ?? []
      list.push(post)
      authorMap.set(post.data.author, list)
    }
  }
  return [...authorMap.entries()].map(([authorId, posts]) => ({
    params: { author: authorId },
    props: { authorId, posts, allPosts },
  }))
}

const { authorId, posts, allPosts } = Astro.props
---

<BlogAuthorPage locale="ja" authorId={authorId} posts={posts} allPosts={allPosts} />
