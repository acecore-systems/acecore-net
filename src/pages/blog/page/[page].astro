---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import BlogPostCard from '../../../components/BlogPostCard.astro'
import BlogSidebar from '../../../components/BlogSidebar.astro'
import { getCollection } from 'astro:content'
import AdUnit from '../../../components/AdUnit.astro'
import { POSTS_PER_PAGE, buildPageNumbers } from '../../../utils/pagination'

import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  )
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE)
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: {
      posts: allPosts.slice((i + 1) * POSTS_PER_PAGE, (i + 2) * POSTS_PER_PAGE),
      currentPage: i + 2,
      totalPages,
      allPosts,
    },
  }))
}

const { posts, currentPage, totalPages, allPosts } = Astro.props

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Acecore ブログ記事一覧 - ${currentPage}ページ目`,
  "itemListElement": posts.map((post: CollectionEntry<'blog'>, i: number) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://acecore.net/blog/${post.id}/`,
  })),
}

const pageNumbers = buildPageNumbers(currentPage, totalPages)
---

<BaseLayout
  title={`ブログ (${currentPage}ページ目)`}
  description={`Acecore ブログの記事一覧（${currentPage}/${totalPages}ページ目）。システム開発・Web制作・サーバー運用・IT教育に関する技術情報や活動報告を発信しています。`}
  jsonLd={itemListLd}
  prevPage={currentPage === 2 ? '/blog/' : `/blog/page/${currentPage - 1}/`}
  nextPage={currentPage < totalPages ? `/blog/page/${currentPage + 1}/` : undefined}
>
  <section class="ac-section">
    <div class="ac-container">
      <Breadcrumb items={[
        { label: 'ブログ', href: '/blog/' },
        { label: `${currentPage}ページ目` },
      ]} />
      <h1 class="text-2xl sm:text-3xl ac-heading mb-8">
        ブログ <span class="text-base text-slate-400">({currentPage}/{totalPages}ページ)</span>
      </h1>
      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
      <div>
      <div class="space-y-6">
        {posts.map((post: CollectionEntry<'blog'>, i: number) => (
          <Fragment>
          {i > 0 && i % 3 === 0 && (
            <div class="ac-card overflow-hidden p-6">
              <AdUnit adSlot="3228710511" />
            </div>
          )}
          <BlogPostCard post={post} />
          </Fragment>
        ))}
      </div>

      <nav class="mt-10 flex justify-center items-center gap-2" aria-label="ページナビゲーション">
        <a href={currentPage === 2 ? '/blog/' : `/blog/page/${currentPage - 1}/`} class="px-3 py-2 text-sm text-slate-600 hover:text-brand-500 transition-colors">← 前へ</a>
        {pageNumbers.map((p) =>
          p === '...'
            ? <span class="px-2 text-slate-400">…</span>
            : p === currentPage
              ? <span class="px-4 py-2 rounded bg-brand-500 text-white text-sm font-600" aria-current="page">{p}</span>
              : <a href={p === 1 ? '/blog/' : `/blog/page/${p}/`} class="px-4 py-2 rounded border border-slate-300 text-sm text-slate-600 hover:bg-brand-50 hover:border-brand-300 transition-colors">{p}</a>
        )}
        {currentPage < totalPages ? <a href={`/blog/page/${currentPage + 1}/`} class="px-3 py-2 text-sm text-slate-600 hover:text-brand-500 transition-colors">次へ →</a> : <span class="px-3 py-2 text-sm text-slate-300" aria-disabled="true">次へ →</span>}
      </nav>
      </div>
      <BlogSidebar allPosts={allPosts} />
      </div>
    </div>
  </section>
</BaseLayout>
