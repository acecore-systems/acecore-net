---
import BlogArchivePage from '../../../views/BlogArchivePage.astro'
import { getCollection } from 'astro:content'
import { isBasePost } from '../../../utils/blog-i18n'

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).filter(isBasePost).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  )
  const monthMap = new Map<string, typeof allPosts>()
  for (const post of allPosts) {
    const d = post.data.date
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
    const list = monthMap.get(key) ?? []
    list.push(post)
    monthMap.set(key, list)
  }
  return [...monthMap.entries()].map(([month, posts]) => ({
    params: { month },
    props: { month, posts, allPosts },
  }))
}

const { month, posts, allPosts } = Astro.props
---

<BlogArchivePage locale="ja" month={month} posts={posts} allPosts={allPosts} />
