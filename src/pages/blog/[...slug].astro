---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import authors from '../../data/authors.json'
import ProcessFigure from '../../components/ProcessFigure.astro'
import InsightGrid from '../../components/InsightGrid.astro'
import StatBar from '../../components/StatBar.astro'
import Timeline from '../../components/Timeline.astro'
import CompareTable from '../../components/CompareTable.astro'
import Callout from '../../components/Callout.astro'
import Testimonial from '../../components/Testimonial.astro'
import Checklist from '../../components/Checklist.astro'
import YouTubeEmbed from '../../components/YouTubeEmbed.astro'
import Gallery from '../../components/Gallery.astro'
import LinkCard from '../../components/LinkCard.astro'
import Faq from '../../components/Faq.astro'
import PullQuote from '../../components/PullQuote.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await post.render()
const author = post.data.author
  ? authors.find((a) => a.id === post.data.author)
  : null

/*
  各記事のビジュアル定義（配列で複数配置可）
  photo / grid / flow / stat / timeline / compare / callout
  testimonial / checklist / youtube / gallery / linkcard / faq / pullquote
*/
const blogVisuals: Record<string, Array<{ type: string; [k: string]: any }>> = {
  'service-introduction': [
    {
      type: 'stat',
      props: {
        items: [
          { value: '3', label: 'つの事業', icon: 'i-lucide-layers' },
          { value: '100%', label: '静的サイト', icon: 'i-lucide-gauge' },
          { value: '∞', label: 'サポート', icon: 'i-lucide-life-buoy' },
        ],
      },
    },
    {
      type: 'checklist',
      props: {
        title: '提供サービス一覧',
        items: [
          { text: 'Webサイト制作・運用支援' },
          { text: 'ロボット・プログラミング教室' },
          { text: 'Minecraftサーバー運営' },
          { text: 'IT勉強会・技術イベント開催' },
          { text: 'コミュニティ運営サポート' },
        ],
      },
    },
  ],
  'community-and-education': [
    {
      type: 'grid',
      props: {
        title: '活動の広がり',
        items: [
          { title: 'Aceserver', description: '交流の起点としてのMinecraftサーバー運営。', icon: 'i-lucide-gamepad-2', tone: 'brand' },
          { title: '勉強会', description: '初心者でも参加しやすい技術イベントを定期開催。', icon: 'i-lucide-presentation', tone: 'amber' },
          { title: 'Schools', description: '体験を実務スキルへつなぐ教育プログラム。', icon: 'i-lucide-school', tone: 'emerald' },
          { title: 'OSS・地域', description: '得た知見を地域やコミュニティへ循環。', icon: 'i-lucide-git-branch-plus', tone: 'slate' },
        ],
      },
    },
    {
      type: 'testimonial',
      props: {
        quote: '地域の人たちと技術を共有できる場があるのは本当にありがたい。独学では気づけないことがたくさんあります。',
        name: '勉強会参加者',
        role: 'コミュニティメンバー',
      },
    },
    {
      type: 'pullquote',
      props: {
        text: '学びの場は、一方通行じゃなくて、みんなで作っていくもの',
        attribution: 'Acecore Schools',
      },
    },
  ],
  'aceserver-hijacked': [
    {
      type: 'callout',
      props: {
        type: 'warning',
        title: 'セキュリティの教訓',
        text: 'サーバー運営では、OP権限の管理やバックアップ体制の整備が不可欠です。今回の騒動を機に、セキュリティ対策を全面的に見直しました。',
      },
    },
    {
      type: 'timeline',
      props: {
        title: '事件の経緯',
        items: [
          { date: '発覚当日', title: '異変の発見', description: 'ログイン時に見慣れない構造物を確認。' },
          { date: '調査開始', title: '被害状況の確認', description: 'ワールドデータとログを精査。' },
          { date: '対策実施', title: '権限の見直し', description: 'OP権限の再整理とホワイトリスト導入。' },
          { date: '復旧完了', title: '通常運営を再開', description: 'バックアップから復旧し、対策を反映。' },
        ],
      },
    },
    {
      type: 'faq',
      props: {
        title: 'よくある疑問',
        items: [
          { question: 'Aceserverは今でも遊べますか？', answer: '再開に向けて準備を進めています。セキュリティ対策を強化した上で安全に運営できる体制を整えてから再公開する予定です。' },
          { question: '乗っ取りの被害はどの程度でしたか？', answer: 'ワールドの一部が改変されましたが、バックアップからの復旧に成功しました。ユーザーの個人情報などの流出はありません。' },
        ],
      },
    },
  ],
  'metaverse-is-close': [
    {
      type: 'gallery',
      props: {
        title: 'メタバースの世界',
        items: [
          { src: 'https://images.unsplash.com/photo-1622979135225-d2ba269cf1ac?w=400&h=300&fit=crop&q=80', alt: 'VRヘッドセット' },
          { src: 'https://images.unsplash.com/photo-1614064641938-3bbee52942c7?w=400&h=300&fit=crop&q=80', alt: '仮想空間のイメージ' },
          { src: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=400&h=300&fit=crop&q=80', alt: 'ゲーミング環境' },
          { src: 'https://images.unsplash.com/photo-1592478411213-6153e4ebc07d?w=400&h=300&fit=crop&q=80', alt: 'デジタルワールド' },
        ],
      },
    },
    {
      type: 'linkcard',
      props: {
        href: 'https://www.meta.com/ja-jp/quest/',
        title: 'Meta Quest ─ メタバースへの入口',
        description: 'Meta社のVRデバイスが切り拓く仮想空間体験。',
        icon: 'i-lucide-glasses',
      },
    },
  ],
  'robot-workshop-event': [
    {
      type: 'photo',
      src: 'https://images.unsplash.com/photo-1561557944-6e7860d1a7eb?w=800&h=400&fit=crop&q=80',
      alt: 'ロボット工作のイメージ',
      caption: 'タミヤ工作シリーズを使って、組み立てから改造まで体験できます。',
    },
    {
      type: 'youtube',
      props: {
        /* 実際の動画IDに置換してください */
        videoId: 'MmB9b5njVbA',
        title: 'ロボット工作の様子',
        caption: '実際のワークショップの雰囲気をご覧いただけます。',
      },
    },
  ],
  'website-renewal': [
    {
      type: 'flow',
      props: {
        title: 'リニューアルの流れ',
        steps: [
          { title: '課題整理', description: '旧サイトの不足点を洗い出し。', icon: 'i-lucide-clipboard-list', accent: 'slate' },
          { title: '構造再設計', description: 'サービス・ブログ・会社情報を分離。', icon: 'i-lucide-waypoints', accent: 'brand' },
          { title: '速度改善', description: 'Astro＋静的生成で軽量化。', icon: 'i-lucide-gauge', accent: 'emerald' },
          { title: '継続発信', description: 'ブログ基盤で記事更新しやすく。', icon: 'i-lucide-pen-line', accent: 'amber' },
        ],
      },
    },
    {
      type: 'compare',
      props: {
        title: 'リニューアル前後の比較',
        before: {
          label: '旧サイト',
          items: ['単一ページ構成', '更新が手作業', '表示速度が遅い', 'モバイル非対応'],
        },
        after: {
          label: '新サイト',
          items: ['サービス別のページ構成', 'ブログで簡単に更新', 'Astroで高速表示', 'レスポンシブ対応'],
        },
      },
    },
  ],
}

const articleVisuals = blogVisuals[post.slug] ?? []
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="ac-section">
    <div class="ac-container max-w-3xl">
      <div class="mb-8">
        <a
          href="/blog/"
          class="text-sm text-brand-500 hover:underline inline-flex items-center gap-1 mb-4"
        >
          <div class="i-lucide-arrow-left text-sm"></div>
          ブログ一覧に戻る
        </a>
        <h1 class="text-3xl sm:text-4xl ac-heading mb-4">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-sm text-slate-400">
          <time>{post.data.date.toLocaleDateString('ja-JP')}</time>
          {author && <span>by {author.name}</span>}
        </div>
        {post.data.tags && (
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs bg-brand-50 text-brand-600 px-2 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
      {(post.data.image || post.data.imageUrl) && (
        <div class="mb-8 rounded-xl overflow-hidden">
          <img
            src={post.data.image || post.data.imageUrl}
            alt={post.data.title}
            class="w-full h-auto"
          />
        </div>
      )}
      <div class="prose prose-slate prose-lg max-w-none">
        <Content />
        {articleVisuals.map((v: any) =>
          v.type === 'photo' ? (
            <figure class="not-prose my-8">
              <img src={v.src} alt={v.alt} class="w-full rounded-lg" loading="lazy" />
              {v.caption && <figcaption class="text-sm text-slate-500 mt-2">{v.caption}</figcaption>}
            </figure>
          ) : v.type === 'grid' ? (
            <InsightGrid {...v.props} />
          ) : v.type === 'flow' ? (
            <ProcessFigure {...v.props} />
          ) : v.type === 'stat' ? (
            <StatBar {...v.props} />
          ) : v.type === 'timeline' ? (
            <Timeline {...v.props} />
          ) : v.type === 'compare' ? (
            <CompareTable {...v.props} />
          ) : v.type === 'callout' ? (
            <Callout {...v.props} />
          ) : v.type === 'testimonial' ? (
            <Testimonial {...v.props} />
          ) : v.type === 'checklist' ? (
            <Checklist {...v.props} />
          ) : v.type === 'youtube' ? (
            <YouTubeEmbed {...v.props} />
          ) : v.type === 'gallery' ? (
            <Gallery {...v.props} />
          ) : v.type === 'linkcard' ? (
            <LinkCard {...v.props} />
          ) : v.type === 'faq' ? (
            <Faq {...v.props} />
          ) : v.type === 'pullquote' ? (
            <PullQuote {...v.props} />
          ) : null
        )}
      </div>

      {author && (
        <div class="mt-12 pt-8 border-t border-slate-200">
          <div class="flex items-start gap-4">
            {(author.avatarImage || author.avatar) ? (
              <img
                src={author.avatarImage || author.avatar}
                alt={author.name}
                class="w-16 h-16 rounded-full object-cover shrink-0"
              />
            ) : (
              <div class="w-16 h-16 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xl font-700 shrink-0">
                {author.name.charAt(0)}
              </div>
            )}
            <div>
              <h3 class="font-700 text-lg text-slate-900">{author.name}</h3>
              {author.bio && (
                <p class="text-sm text-slate-600 mt-1 whitespace-pre-line">{author.bio}</p>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
