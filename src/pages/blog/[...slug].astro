---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import authors from '../../data/authors.json'
import ProcessFigure from '../../components/ProcessFigure.astro'
import InsightGrid from '../../components/InsightGrid.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await post.render()
const author = post.data.author
  ? authors.find((a) => a.id === post.data.author)
  : null

/*
  各記事のビジュアル定義
  type:
    - 'photo'  … 写真（Unsplash）+ キャプション
    - 'grid'   … InsightGrid（インライン挿絵）
    - 'flow'   … ProcessFigure（インライン挿絵）
*/
const blogVisuals: Record<string, {
  type: 'photo' | 'grid' | 'flow'
  photo?: { src: string; alt: string; caption?: string }
  grid?: Parameters<typeof InsightGrid>[0]
  flow?: Parameters<typeof ProcessFigure>[0]
}> = {
  'service-introduction': {
    type: 'photo',
    photo: {
      src: 'https://images.unsplash.com/photo-1553877522-43269d4ea984?w=800&h=400&fit=crop&q=80',
      alt: 'チームでのシステム開発イメージ',
      caption: '課題整理から運用支援まで、ワンストップで対応する体制を整えています。',
    },
  },
  'community-and-education': {
    type: 'grid',
    grid: {
      title: '活動の広がり',
      items: [
        { title: 'Aceserver', description: '交流の起点としてのMinecraftサーバー運営。', icon: 'i-lucide-gamepad-2', tone: 'brand' },
        { title: '勉強会', description: '初心者でも参加しやすい技術イベントを定期開催。', icon: 'i-lucide-presentation', tone: 'amber' },
        { title: 'Schools', description: '体験を実務スキルへつなぐ教育プログラム。', icon: 'i-lucide-school', tone: 'emerald' },
        { title: 'OSS・地域', description: '得た知見を地域やコミュニティへ循環。', icon: 'i-lucide-git-branch-plus', tone: 'slate' },
      ],
    },
  },
  'aceserver-hijacked': {
    type: 'photo',
    photo: {
      src: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=800&h=400&fit=crop&q=80',
      alt: 'ゲーミング環境のイメージ',
      caption: 'Aceserverで起きた、ある日の騒動の記録。',
    },
  },
  'metaverse-is-close': {
    type: 'grid',
    grid: {
      title: 'メタバースの論点整理',
      items: [
        { title: '企業の動き', description: 'FacebookやMicrosoftが描く仮想空間戦略。', icon: 'i-lucide-building-2', tone: 'slate' },
        { title: 'VR不要論', description: 'ヘッドセット前提ではない別の解釈。', icon: 'i-lucide-glasses', tone: 'amber' },
        { title: 'Minecraftの可能性', description: '既にある交流空間としての再評価。', icon: 'i-lucide-cuboid', tone: 'brand' },
        { title: '事業への接続', description: 'Acecoreがその文脈で何を作れるか。', icon: 'i-lucide-rocket', tone: 'emerald' },
      ],
    },
  },
  'robot-workshop-event': {
    type: 'photo',
    photo: {
      src: 'https://images.unsplash.com/photo-1561557944-6e7860d1a7eb?w=800&h=400&fit=crop&q=80',
      alt: 'ロボット工作のイメージ',
      caption: 'タミヤ工作シリーズを使って、組み立てから改造まで体験できます。',
    },
  },
  'website-renewal': {
    type: 'flow',
    flow: {
      title: 'リニューアルの流れ',
      steps: [
        { title: '課題整理', description: '旧サイトの不足点を洗い出し。', icon: 'i-lucide-clipboard-list', accent: 'slate' },
        { title: '構造再設計', description: 'サービス・ブログ・会社情報を分離。', icon: 'i-lucide-waypoints', accent: 'brand' },
        { title: '速度改善', description: 'Astro＋静的生成で軽量化。', icon: 'i-lucide-gauge', accent: 'emerald' },
        { title: '継続発信', description: 'ブログ基盤で記事更新しやすく。', icon: 'i-lucide-pen-line', accent: 'amber' },
      ],
    },
  },
}

const articleVisual = blogVisuals[post.slug]
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="ac-section">
    <div class="ac-container max-w-3xl">
      <div class="mb-8">
        <a
          href="/blog/"
          class="text-sm text-brand-500 hover:underline inline-flex items-center gap-1 mb-4"
        >
          <div class="i-lucide-arrow-left text-sm"></div>
          ブログ一覧に戻る
        </a>
        <h1 class="text-3xl sm:text-4xl ac-heading mb-4">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-sm text-slate-400">
          <time>{post.data.date.toLocaleDateString('ja-JP')}</time>
          {author && <span>by {author.name}</span>}
        </div>
        {post.data.tags && (
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs bg-brand-50 text-brand-600 px-2 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
      {(post.data.image || post.data.imageUrl) && (
        <div class="mb-8 rounded-xl overflow-hidden">
          <img
            src={post.data.image || post.data.imageUrl}
            alt={post.data.title}
            class="w-full h-auto"
          />
        </div>
      )}
      <div class="prose prose-slate prose-lg max-w-none">
        <Content />
        {articleVisual && articleVisual.type === 'photo' && articleVisual.photo && (
          <figure class="not-prose my-8">
            <img
              src={articleVisual.photo.src}
              alt={articleVisual.photo.alt}
              class="w-full rounded-lg"
              loading="lazy"
            />
            {articleVisual.photo.caption && (
              <figcaption class="text-sm text-slate-500 mt-2">{articleVisual.photo.caption}</figcaption>
            )}
          </figure>
        )}
        {articleVisual && articleVisual.type === 'grid' && articleVisual.grid && (
          <InsightGrid {...articleVisual.grid} />
        )}
        {articleVisual && articleVisual.type === 'flow' && articleVisual.flow && (
          <ProcessFigure {...articleVisual.flow} />
        )}
      </div>

      {author && (
        <div class="mt-12 pt-8 border-t border-slate-200">
          <div class="flex items-start gap-4">
            {(author.avatarImage || author.avatar) ? (
              <img
                src={author.avatarImage || author.avatar}
                alt={author.name}
                class="w-16 h-16 rounded-full object-cover shrink-0"
              />
            ) : (
              <div class="w-16 h-16 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xl font-700 shrink-0">
                {author.name.charAt(0)}
              </div>
            )}
            <div>
              <h3 class="font-700 text-lg text-slate-900">{author.name}</h3>
              {author.bio && (
                <p class="text-sm text-slate-600 mt-1 whitespace-pre-line">{author.bio}</p>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
