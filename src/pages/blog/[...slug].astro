---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import authors from '../../data/authors.json'
import SplitContent from '../../components/SplitContent.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await post.render()
const author = post.data.author
  ? authors.find((a) => a.id === post.data.author)
  : null

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
)
const currentIndex = allPosts.findIndex((p) => p.slug === post.slug)
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null

/*
  各記事のビジュアル定義
  afterSection: h2 で区切られたセクションの直後に配置
    0 = イントロ直後 / 1 = 最初の h2 の後 / N = N番目の h2 の後
*/
const blogVisuals: Record<string, Array<{ type: string; afterSection: number; [k: string]: any }>> = {
  /* ── サービス紹介
     h2: 1.業務システム / 2.サーバー / 3.Web / 4.デザイン / 5.ITスクール ── */
  'service-introduction': [
    {
      type: 'callout',
      afterSection: 0,
      props: {
        variant: 'info',
        title: 'Acecoreのサービス体系',
        body: 'Web制作・サーバー運用・教育支援まで、ワンストップで提供しています。',
      },
    },
    {
      type: 'checklist',
      afterSection: 5,
      props: {
        title: '提供サービス一覧',
        items: [
          { text: 'Webサイト制作・運用支援' },
          { text: 'ロボット・プログラミング教室' },
          { text: 'Minecraftサーバー運営' },
          { text: 'IT勉強会・技術イベント開催' },
          { text: 'コミュニティ運営サポート' },
        ],
      },
    },
  ],

  /* ── コミュニティと教育
     h2: Aceserver / 勉強会 / Schools / OSS / 地域連携 ── */
  'community-and-education': [
    {
      type: 'grid',
      afterSection: 0,
      props: {
        title: '活動の広がり',
        items: [
          { title: 'Aceserver', description: '交流の起点としてのMinecraftサーバー運営。', icon: 'i-lucide-gamepad-2', tone: 'brand' },
          { title: '勉強会', description: '初心者でも参加しやすい技術イベントを定期開催。', icon: 'i-lucide-presentation', tone: 'amber' },
          { title: 'Schools', description: '体験を実務スキルへつなぐ教育プログラム。', icon: 'i-lucide-school', tone: 'emerald' },
          { title: 'OSS・地域', description: '得た知見を地域やコミュニティへ循環。', icon: 'i-lucide-git-branch-plus', tone: 'slate' },
        ],
      },
    },
    {
      type: 'testimonial',
      afterSection: 2,
      props: {
        quote: '地域の人たちと技術を共有できる場があるのは本当にありがたい。独学では気づけないことがたくさんあります。',
        name: '勉強会参加者',
        role: 'コミュニティメンバー',
      },
    },
    {
      type: 'pullquote',
      afterSection: 4,
      props: {
        text: '学びの場は、一方通行じゃなくて、みんなで作っていくもの',
        attribution: 'Acecore Schools',
      },
    },
  ],

  /* ── Aceserver 乗っ取り事件
     h2: エースサーバーが乗っ取られた ── */
  'aceserver-hijacked': [
    {
      type: 'callout',
      afterSection: 0,
      props: {
        type: 'warning',
        title: 'セキュリティの教訓',
        text: 'サーバー運営では、OP権限の管理やバックアップ体制の整備が不可欠です。今回の騒動を機に、セキュリティ対策を全面的に見直しました。',
      },
    },
    {
      type: 'timeline',
      afterSection: 1,
      props: {
        title: '事件の経緯',
        items: [
          { date: '発覚当日', title: '異変の発見', description: 'ログイン時に見慣れない構造物を確認。' },
          { date: '調査開始', title: '被害状況の確認', description: 'ワールドデータとログを精査。' },
          { date: '対策実施', title: '権限の見直し', description: 'OP権限の再整理とホワイトリスト導入。' },
          { date: '復旧完了', title: '通常運営を再開', description: 'バックアップから復旧し、対策を反映。' },
        ],
      },
    },
    {
      type: 'youtube',
      afterSection: 1,
      props: {
        videoId: '03XvopRIHCc',
        title: 'Aceserver YouTubeチャンネル',
        caption: 'Aceserverの最新情報やコミュニティの様子を配信しています。',
      },
    },
    {
      type: 'faq',
      afterSection: 1,
      props: {
        title: 'よくある疑問',
        items: [
          { question: 'Aceserverは今でも遊べますか？', answer: '再開に向けて準備を進めています。セキュリティ対策を強化した上で安全に運営できる体制を整えてから再公開する予定です。' },
          { question: '乗っ取りの被害はどの程度でしたか？', answer: 'ワールドの一部が改変されましたが、バックアップからの復旧に成功しました。ユーザーの個人情報などの流出はありません。' },
        ],
      },
    },
  ],

  /* ── メタバースは近い（h2 なし → セクション 0 のみ）── */
  'metaverse-is-close': [
    {
      type: 'gallery',
      afterSection: 0,
      props: {
        title: 'メタバースの世界',
        items: [
          { src: 'https://images.unsplash.com/photo-1622979135225-d2ba269cf1ac?w=400&h=300&fit=crop&q=80&fm=webp', alt: 'VRヘッドセット' },
          { src: 'https://images.unsplash.com/photo-1614064641938-3bbee52942c7?w=400&h=300&fit=crop&q=80&fm=webp', alt: '仮想空間のイメージ' },
          { src: 'https://images.unsplash.com/photo-1511512578047-dfb367046420?w=400&h=300&fit=crop&q=80&fm=webp', alt: 'ゲーミング環境' },
          { src: 'https://images.unsplash.com/photo-1592478411213-6153e4ebc07d?w=400&h=300&fit=crop&q=80&fm=webp', alt: 'デジタルワールド' },
        ],
      },
    },
    {
      type: 'linkcard',
      afterSection: 0,
      props: {
        href: 'https://www.meta.com/ja-jp/quest/',
        title: 'Meta Quest ─ メタバースへの入口',
        description: 'Meta社のVRデバイスが切り拓く仮想空間体験。',
        icon: 'i-lucide-glasses',
      },
    },
  ],

  /* ── ロボット工作イベント
     h2: イベント詳細 / 特典情報 / イベントの様子 / お問い合わせ ── */
  'robot-workshop-event': [
    {
      type: 'photo',
      afterSection: 3,
      src: 'https://images.unsplash.com/photo-1561557944-6e7860d1a7eb?w=800&h=400&fit=crop&q=80&fm=webp',
      alt: 'ロボット工作のイメージ',
      caption: 'タミヤ工作シリーズを使って、組み立てから改造まで体験できます。',
    },
  ],

  /* ── サイトリニューアル
     h2: 背景 / 新サイトの特徴 / 今後の展望 ── */
  'website-renewal': [
    {
      type: 'flow',
      afterSection: 1,
      props: {
        title: 'リニューアルの流れ',
        steps: [
          { title: '課題整理', description: '旧サイトの不足点を洗い出し。', icon: 'i-lucide-clipboard-list', accent: 'slate' },
          { title: '構造再設計', description: 'サービス・ブログ・会社情報を分離。', icon: 'i-lucide-waypoints', accent: 'brand' },
          { title: '速度改善', description: 'Astro＋静的生成で軽量化。', icon: 'i-lucide-gauge', accent: 'emerald' },
          { title: '継続発信', description: 'ブログ基盤で記事更新しやすく。', icon: 'i-lucide-pen-line', accent: 'amber' },
        ],
      },
    },
    {
      type: 'compare',
      afterSection: 2,
      props: {
        title: 'リニューアル前後の比較',
        before: {
          label: '旧サイト',
          items: ['単一ページ構成', '更新が手作業', '表示速度が遅い', 'モバイル非対応'],
        },
        after: {
          label: '新サイト',
          items: ['サービス別のページ構成', 'ブログで簡単に更新', 'Astroで高速表示', 'レスポンシブ対応'],
        },
      },
    },
  ],
}

const articleVisuals = blogVisuals[post.slug] ?? []

const ogImage = post.data.imageUrl || undefined
const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  ...(ogImage && { "image": ogImage }),
  ...(author && { "author": { "@type": "Person", "name": author.name } }),
  "publisher": {
    "@type": "Organization",
    "name": "Acecore",
    "url": "https://acecore.net"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://acecore.net/blog/${post.slug}/`
  }
}
---

<BaseLayout title={post.data.title} description={post.data.description} image={ogImage} ogType="article" jsonLd={blogPostingLd}>
  <article class="ac-section">
    <div class="ac-container max-w-3xl">
      <div class="mb-8">
        <a
          href="/blog/"
          class="text-sm text-brand-500 hover:underline inline-flex items-center gap-1 mb-4"
        >
          <div class="i-lucide-arrow-left text-sm"></div>
          ブログ一覧に戻る
        </a>
        <h1 class="text-3xl sm:text-4xl ac-heading mb-4">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-sm text-slate-500">
          <time>{post.data.date.toLocaleDateString('ja-JP')}</time>
          {author && <span>by {author.name}</span>}
        </div>
        {post.data.tags && (
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs bg-brand-50 text-brand-600 px-2 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
      {(post.data.image || post.data.imageUrl) && (
        <div class="mb-8 rounded-xl overflow-hidden">
          <img
            src={post.data.image || post.data.imageUrl}
            alt={post.data.title}
            class="w-full h-auto"
            decoding="async"
          />
        </div>
      )}
      <div class="prose prose-slate prose-lg max-w-none">
        <SplitContent visuals={articleVisuals}>
          <Content />
        </SplitContent>
      </div>

      {author && (
        <div class="mt-12 pt-8 border-t border-slate-200">
          <div class="flex items-start gap-4">
            {(author.avatarImage || author.avatar) ? (
              <img
                src={author.avatarImage || author.avatar}
                alt={author.name}
                class="w-16 h-16 rounded-full object-cover shrink-0"
              />
            ) : (
              <div class="w-16 h-16 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xl font-700 shrink-0">
                {author.name.charAt(0)}
              </div>
            )}
            <div>
              <h3 class="font-700 text-lg text-slate-900">{author.name}</h3>
              {author.bio && (
                <p class="text-sm text-slate-600 mt-1 whitespace-pre-line">{author.bio}</p>
              )}
            </div>
          </div>
        </div>
      )}

      <div class="mt-12 pt-8 border-t border-slate-200 bg-brand-50 rounded-xl p-6 sm:p-8 text-center">
        <p class="text-lg font-600 text-slate-800 mb-2">ご相談・ご依頼はお気軽に</p>
        <p class="text-sm text-slate-600 mb-4">記事の内容に関するご質問や、サービスについてのご相談をお待ちしています。</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/contact/" class="ac-btn-primary">お問い合わせ</a>
          <a href="/services/" class="ac-btn-outline">サービス一覧</a>
        </div>
      </div>

      {(prevPost || nextPost) && (
        <nav class="mt-8 pt-8 border-t border-slate-200 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {prevPost ? (
            <a
              href={`/blog/${prevPost.slug}/`}
              class="group flex flex-col p-4 rounded-lg border border-slate-200 hover:border-brand-300 transition-colors"
            >
              <span class="text-xs text-slate-500 mb-1">← 前の記事</span>
              <span class="text-sm font-600 text-slate-700 group-hover:text-brand-600 transition-colors">
                {prevPost.data.title}
              </span>
            </a>
          ) : <div />}
          {nextPost && (
            <a
              href={`/blog/${nextPost.slug}/`}
              class="group flex flex-col p-4 rounded-lg border border-slate-200 hover:border-brand-300 transition-colors sm:text-right"
            >
              <span class="text-xs text-slate-500 mb-1">次の記事 →</span>
              <span class="text-sm font-600 text-slate-700 group-hover:text-brand-600 transition-colors">
                {nextPost.data.title}
              </span>
            </a>
          )}
        </nav>
      )}
    </div>
  </article>
</BaseLayout>
