---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero from '../../components/Hero.astro'
import { getCollection } from 'astro:content'
import authors from '../../data/authors.json'
import { optimizeImage } from '../../utils/image'
import AdUnit from '../../components/AdUnit.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
---

<BaseLayout
  title="ブログ"
  description="Acecore（エースコア）のブログ。システム開発・Web制作・サーバー運用・IT教育に関する技術情報や活動報告、お知らせを発信しています。"
>
  <Hero title="ブログ" subtitle="技術情報・活動報告・お知らせ" images={[{src: optimizeImage('https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1400&h=600&fit=crop&q=80&fm=webp'), alt: 'ブログ執筆のイメージ'}]} />

  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      {
        posts.length === 0 ? (
          <p class="text-center text-slate-500">記事の準備中です。</p>
        ) : (
          <div class="space-y-6">
            {posts.map((post, i) => (
              <Fragment>
              {i > 0 && i % 3 === 0 && (
                <div class="ac-card overflow-hidden p-6">
                  <AdUnit adSlot="3228710511" />
                </div>
              )}
              <a
                href={`/blog/${post.id}/`}
                class="block ac-card overflow-hidden no-underline hover:shadow-md transition-shadow group"
              >
                <div class="flex flex-col sm:flex-row">
                  {(post.data.image || post.data.imageUrl) && (
                    <div class="sm:w-48 sm:shrink-0">
                      <img
                        src={optimizeImage(post.data.image || post.data.imageUrl)}
                        alt={post.data.title}
                        class="w-full h-40 sm:h-full object-cover"
                        width="192"
                        height="160"
                        decoding="async"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-6 sm:p-8">
                    <div class="flex items-center gap-3 text-sm text-slate-500">
                      <time>{post.data.date.toLocaleDateString('ja-JP')}</time>
                      {post.data.author && <span>by {authors.find((a) => a.id === post.data.author)?.name || post.data.author}</span>}
                    </div>
                    <h2 class="text-xl font-700 text-slate-900 mt-2 mb-3 group-hover:text-brand-500 transition-colors">
                      {post.data.title}
                    </h2>
                    <p class="text-slate-600">{post.data.description}</p>
                    {post.data.tags && (
                      <div class="flex flex-wrap gap-2 mt-4">
                        {post.data.tags.map((tag: string) => (
                          <span class="text-xs bg-brand-50 text-brand-600 px-2 py-1 rounded-full">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
              </Fragment>
            ))}
          </div>
        )
      }

      <div class="mt-12 bg-brand-50 rounded-xl p-6 sm:p-8 text-center">
        <p class="text-lg font-700 text-slate-800 mb-2">サービスについてもっと知りたい方へ</p>
        <p class="text-sm text-slate-600 mb-4">システム開発・Web制作・デザイン・ITスクールなど、幅広くサポートしています。</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/services/" class="ac-btn-primary">サービス一覧を見る</a>
          <a href="/contact/" class="ac-btn-outline">無料で相談する</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
