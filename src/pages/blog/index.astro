---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero from '../../components/Hero.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import BlogPostCard from '../../components/BlogPostCard.astro'
import BlogSidebar from '../../components/BlogSidebar.astro'
import { getCollection } from 'astro:content'
import { optimizeImage } from '../../utils/image'
import AdUnit from '../../components/AdUnit.astro'

const POSTS_PER_PAGE = 6

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE)
const posts = allPosts.slice(0, POSTS_PER_PAGE)

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Acecore ブログ記事一覧",
  "itemListElement": posts.map((post, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://acecore.net/blog/${post.id}/`,
  })),
}
---

<BaseLayout
  title="ブログ"
  description="Acecore（エースコア）のブログ。システム開発・Web制作・サーバー運用・IT教育に関する技術情報や活動報告、お知らせを発信しています。"
  jsonLd={itemListLd}
  nextPage={totalPages > 1 ? '/blog/page/2/' : undefined}
>
  <Hero title="ブログ" subtitle="技術情報・活動報告・お知らせ" images={[{src: optimizeImage('https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1400&h=600&fit=crop&q=80&fm=webp'), alt: 'ブログ執筆のイメージ'}]} />

  <section class="ac-section">
    <div class="ac-container">
      <Breadcrumb items={[{ label: 'ブログ' }]} />
      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
      <div>
      {
        posts.length === 0 ? (
          <p class="text-center text-slate-500">記事の準備中です。</p>
        ) : (
          <div class="space-y-6">
            {posts.map((post, i) => (
              <Fragment>
              {i > 0 && i % 3 === 0 && (
                <div class="ac-card overflow-hidden p-6">
                  <AdUnit adSlot="3228710511" />
                </div>
              )}
              <BlogPostCard post={post} />
              </Fragment>
            ))}
          </div>
        )
      }

      {totalPages > 1 && (
        <nav class="mt-10 flex justify-center items-center gap-2" aria-label="ページナビゲーション">
          <span class="px-4 py-2 rounded bg-brand-500 text-white text-sm font-600">1</span>
          {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map((page) => (
            <a href={`/blog/page/${page}/`} class="px-4 py-2 rounded border border-slate-300 text-sm text-slate-600 hover:bg-brand-50 hover:border-brand-300 transition-colors">
              {page}
            </a>
          ))}
        </nav>
      )}

      <div class="mt-12 bg-brand-50 rounded-xl p-6 sm:p-8 text-center">
        <p class="text-lg font-700 text-slate-800 mb-2">サービスについてもっと知りたい方へ</p>
        <p class="text-sm text-slate-600 mb-4">システム開発・Web制作・デザイン・ITスクールなど、幅広くサポートしています。</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/services/" class="ac-btn-primary">サービス一覧を見る</a>
          <a href="/contact/" class="ac-btn-outline">無料で相談する</a>
        </div>
      </div>
      </div>
      <BlogSidebar allPosts={allPosts} />
      </div>
    </div>
  </section>
</BaseLayout>
