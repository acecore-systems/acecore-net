---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import ProcessFigure from '../components/ProcessFigure.astro'
import Checklist from '../components/Checklist.astro'
import { optimizeImage, generateSrcSet } from '../utils/image'

const valueCycle = [
  {
    title: '技術を実装する',
    description: 'システム開発やサーバー運用を通じて、現場で機能する基盤を作ります。',
    icon: 'i-lucide-cpu',
    accent: 'brand',
  },
  {
    title: '表現へ変換する',
    description: 'Web制作やデザインで、伝わる体験として外側へ届けます。',
    icon: 'i-lucide-palette',
    accent: 'amber',
  },
  {
    title: '人と場を育てる',
    description: 'コミュニティや教育の活動を通じて、新しい参加者や学びを生み出します。',
    icon: 'i-lucide-users',
    accent: 'emerald',
  },
  {
    title: '次の挑戦へ還元する',
    description: '得られた知見をまた開発や支援に戻し、活動全体を強くします。',
    icon: 'i-lucide-repeat-2',
    accent: 'slate',
  },
]

const activityChecklist = [
  { text: '勉強会・ワークショップの定期開催' },
  { text: 'オープンソースへのコード公開・貢献' },
  { text: '地域教育機関との連携指導' },
  { text: '外部パートナーとの共創プロジェクト' },
  { text: 'Aceserverコミュニティ運営' },
]
import { SITE } from '../data/site'

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Acecore",
  "url": "https://acecore.net",
  "logo": "https://acecore.net/favicon.svg",
  "description": "Acecore（エースコア）は、テクノロジーとクリエイティブの力で多様な価値を創出するテクノロジー集団です。",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "JP",
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": SITE.phoneIntl,
    "email": SITE.email,
    "contactType": "customer service",
    "availableLanguage": "Japanese",
  },
  "sameAs": [
    "https://x.com/acecorenet",
    "https://github.com/acecore-systems",
    "https://asv.acecore.net",
  ],
  "knowsAbout": ["システム開発", "Web制作", "サーバー運用", "デザイン", "IT教育"],
}
---

<BaseLayout
  title="会社概要"
  description="Acecore（エースコア）の会社概要・理念・活動内容をご紹介。技術とクリエイティブの循環を軸に、開発・教育・コミュニティ活動を展開しています。"
  jsonLd={organizationLd}
>
  <Hero
    title="会社概要"
    subtitle="Acecoreが目指すこと、大切にしていること"
    images={[{src: optimizeImage('https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1400&h=600&fit=crop&q=80&fm=webp'), alt: 'チームディスカッション'}]}
  />

  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      <Breadcrumb items={[{ label: '会社概要' }]} />
      <div class="mb-12">
        <ProcessFigure
          variant="card"
          eyebrow="Mission Loop"
          title="Acecoreの価値が循環する仕組み"
          description="Acecore が何を起点に価値を広げているのかを図解化しました。"
          steps={valueCycle}
        />
      </div>

      <!-- 理念 -->
      <h2 class="text-2xl ac-heading mb-6">理念</h2>
      <div class="bg-brand-50 rounded-xl p-8 mb-12">
        <p class="text-xl font-600 text-brand-700 text-center">
          「技術でつながる、クリエイティブで広がる」
        </p>
      </div>

      <p class="text-lg text-slate-600 leading-relaxed mb-4">
        Acecore（エースコア）は、テクノロジーとクリエイティブの力で多様な価値を創出するテクノロジー集団です。
        システム開発、Webサイト制作、サーバー運用、デザイン、IT教育をワンストップで提供し、
        個人から法人まで幅広いお客様のニーズにお応えします。
      </p>
      <p class="text-lg text-slate-600 leading-relaxed mb-12">
        私たちは「技術の力で人々をつなげ、クリエイティブの力で可能性を広げる」ことをミッションとしています。
        単に技術を提供するだけでなく、お客様やコミュニティと共に成長し、
        持続可能な価値を生み出すことを大切にしています。
      </p>

      <div class="mb-12">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=450&fit=crop&q=80&fm=webp')}
          srcset={generateSrcSet(optimizeImage('https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=450&fit=crop&q=80&fm=webp'))}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt="チームでのコラボレーション作業"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <div class="mb-12">
        <Checklist
          title="Acecoreの主な活動"
          items={activityChecklist}
        />
      </div>

      <div class="mb-12">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1531482615713-2afd69097998?w=800&h=450&fit=crop&q=80&fm=webp')}
          srcset={generateSrcSet(optimizeImage('https://images.unsplash.com/photo-1531482615713-2afd69097998?w=800&h=450&fit=crop&q=80&fm=webp'))}
          sizes="(min-width: 1024px) 56rem, 100vw"
          alt="勉強会・ワークショップの様子"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- 活動と取り組み -->
      <h2 class="text-2xl ac-heading mb-6">活動と取り組み</h2>
      <div class="space-y-6 mb-12">
        <div class="flex gap-4 items-start">
          <div
            class="i-lucide-users text-2xl text-brand-500 shrink-0 mt-1" aria-hidden="true"
          >
          </div>
          <div>
            <h3 class="font-700 text-lg mb-1">コミュニティ活動</h3>
            <p class="text-slate-600">
              「つながり・発見・共創」をテーマに、技術勉強会やワークショップを定期開催しています。
              参加者同士が刺激を受け合い、新しいアイデアが生まれる場を提供しています。
              <a href="/blog/" class="ac-link">ブログ</a>でも活動報告を発信しています。
            </p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div
            class="i-lucide-git-branch text-2xl text-brand-500 shrink-0 mt-1" aria-hidden="true"
          >
          </div>
          <div>
            <h3 class="font-700 text-lg mb-1">オープンソース貢献</h3>
            <p class="text-slate-600">
              オープンソースソフトウェアの利活用と技術コミュニティへの還元を積極的に推進しています。
              社内で開発したツールやライブラリの一部をGitHubで公開しています。
            </p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div
            class="i-lucide-map-pin text-2xl text-brand-500 shrink-0 mt-1" aria-hidden="true"
          >
          </div>
          <div>
            <h3 class="font-700 text-lg mb-1">地域連携</h3>
            <p class="text-slate-600">
              地域の教育機関やビジネスと連携し、IT活用の促進とデジタル人材の育成に取り組んでいます。
              <a href="/schools/" class="ac-link">Acecore Schools</a>での指導もその一環です。
            </p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div
            class="i-lucide-handshake text-2xl text-brand-500 shrink-0 mt-1" aria-hidden="true"
          >
          </div>
          <div>
            <h3 class="font-700 text-lg mb-1">パートナーシップ</h3>
            <p class="text-slate-600">
              プロジェクト協力やビジネスパートナーシップを歓迎しています。
              <a href="/services/" class="ac-link">技術・デザイン・教育</a>など幅広い分野で連携可能です。
            </p>
          </div>
        </div>
      </div>

      <!-- 関連リンク -->
      <h2 class="text-2xl ac-heading mb-6">関連リンク</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
        <a
          href="https://asv.acecore.net/"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow"
        >
          <div class="flex items-center gap-3 mb-2">
            <div class="i-lucide-gamepad-2 text-xl text-brand-500" aria-hidden="true"></div>
            <h3 class="font-700 text-brand-500">Aceserver ポータル</h3>
          </div>
          <p class="text-sm text-slate-600">
            マインクラフト無料公開サーバーの公式サイトです。
          </p>
          <span class="sr-only">（新しいタブで開きます）</span>
        </a>
        <a
          href="https://x.com/acecorenet"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow"
        >
          <div class="flex items-center gap-3 mb-2">
            <div class="i-lucide-at-sign text-xl text-brand-500" aria-hidden="true"></div>
            <h3 class="font-700 text-brand-500">X（旧Twitter）</h3>
          </div>
          <p class="text-sm text-slate-600">
            Acecoreの最新情報を発信しています。
          </p>
          <span class="sr-only">（新しいタブで開きます）</span>
        </a>
        <a
          href="https://github.com/acecore-systems"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow"
        >
          <div class="flex items-center gap-3 mb-2">
            <div class="i-lucide-github text-xl text-brand-500" aria-hidden="true"></div>
            <h3 class="font-700 text-brand-500">GitHub</h3>
          </div>
          <p class="text-sm text-slate-600">
            オープンソースプロジェクトを公開しています。
          </p>
          <span class="sr-only">（新しいタブで開きます）</span>
        </a>
        <a
          href="https://discord.gg/acsv"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow"
        >
          <div class="flex items-center gap-3 mb-2">
            <div class="i-lucide-message-circle text-xl text-brand-500" aria-hidden="true"></div>
            <h3 class="font-700 text-brand-500">Aceserver Discord</h3>
          </div>
          <p class="text-sm text-slate-600">
            Aceserverのコミュニティが活動するDiscordサーバーです。
          </p>
          <span class="sr-only">（新しいタブで開きます）</span>
        </a>
      </div>

      <!-- CTA -->
      <div class="text-center bg-slate-50 rounded-xl p-8">
        <p class="text-lg font-700 text-slate-800 mb-2">
          Acecoreと一緒に、次の一歩を
        </p>
        <p class="text-sm text-slate-600 mb-6">
          サービスのご相談、パートナーシップのご提案、いつでもお待ちしています。
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact/" class="ac-btn-primary">お問い合わせ</a>
          <a href="/services/" class="ac-btn-outline">サービス一覧を見る</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
