---
import BlogTagPage from '../../../../views/BlogTagPage.astro'
import { getCollection } from 'astro:content'
import { locales, defaultLocale, type Locale } from '../../../../i18n'

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  )
  const tagMap = new Map<string, typeof allPosts>()
  for (const post of allPosts) {
    for (const tag of post.data.tags ?? []) {
      const list = tagMap.get(tag) ?? []
      list.push(post)
      tagMap.set(tag, list)
    }
  }
  return locales
    .filter((l) => l !== defaultLocale)
    .flatMap((locale) =>
      [...tagMap.entries()].map(([tag, posts]) => ({
        params: { locale, tag },
        props: { tag, posts, allPosts },
      })),
    )
}

const locale = Astro.params.locale as Locale
const { tag, posts, allPosts } = Astro.props
---

<BlogTagPage locale={locale} tag={tag} posts={posts} allPosts={allPosts} />
