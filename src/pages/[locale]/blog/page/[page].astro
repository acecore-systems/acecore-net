---
import BlogPaginationPage from '../../../../views/BlogPaginationPage.astro'
import { getCollection } from 'astro:content'
import { POSTS_PER_PAGE } from '../../../../utils/pagination'
import { locales, defaultLocale, type Locale } from '../../../../i18n'
import { isBasePost } from '../../../../utils/blog-i18n'

export async function getStaticPaths() {
  const allRawPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  )
  const allPosts = allRawPosts.filter(isBasePost).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  )
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE)
  return locales
    .filter((l) => l !== defaultLocale)
    .flatMap((locale) =>
      Array.from({ length: totalPages - 1 }, (_, i) => ({
        params: { locale, page: String(i + 2) },
        props: {
          posts: allPosts.slice(
            (i + 1) * POSTS_PER_PAGE,
            (i + 2) * POSTS_PER_PAGE,
          ),
          currentPage: i + 2,
          totalPages,
          allPosts: allRawPosts,
        },
      })),
    )
}

const locale = Astro.params.locale as Locale
const { posts, currentPage, totalPages, allPosts } = Astro.props
---

<BlogPaginationPage
  locale={locale}
  posts={posts}
  currentPage={currentPage}
  totalPages={totalPages}
  allPosts={allPosts}
/>
