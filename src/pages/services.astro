---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import InsightGrid from '../components/InsightGrid.astro'
import Timeline from '../components/Timeline.astro'
import { optimizeImage } from '../utils/image'

const serviceMap = [
  {
    title: '開発',
    description: '業務システムやアプリを、運用フローに合わせて設計・実装します。',
    icon: 'i-lucide-code-2',
    tone: 'brand',
  },
  {
    title: '運用基盤',
    description: 'クラウドやサーバーを安定運用し、監視や保守まで含めて整えます。',
    icon: 'i-lucide-server',
    tone: 'emerald',
  },
  {
    title: '情報発信',
    description: 'Webサイトやデザイン制作で、伝えるべき内容を整理して届けます。',
    icon: 'i-lucide-globe',
    tone: 'amber',
  },
  {
    title: '育成支援',
    description: '導入した技術を現場で回せるよう、教育と伴走支援まで接続します。',
    icon: 'i-lucide-graduation-cap',
    tone: 'slate',
  },
]

const deliveryTimeline = [
  { date: 'Step 1', title: 'ヒアリング', description: '目的と制約を整理し、優先順位を明確に。' },
  { date: 'Step 2', title: '設計・提案', description: '必要な技術・画面・運用ルールを整理。' },
  { date: 'Step 3', title: '制作・構築', description: '開発・デザイン・インフラを横断して実装。' },
  { date: 'Step 4', title: '公開・保守', description: '改善提案・追加開発まで含めた継続支援。' },
]
---

<BaseLayout
  title="サービス"
  description="Acecoreが提供するシステム開発、Webサイト制作、サーバー運用、デザイン、IT教育サービスの詳細をご紹介します。"
>
  <Hero
    title="サービス"
    subtitle="ワンストップで提供する多彩なITソリューション"
    images={[{src: optimizeImage('https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1400&h=600&fit=crop&q=80&fm=webp'), alt: 'テクノロジーオフィス'}]}
  />

  <section class="ac-section bg-slate-50">
    <div class="ac-container">
      <InsightGrid
        variant="card"
        eyebrow="Service Map"
        title="Acecoreの支援範囲を図で把握する"
        description="開発・運用・発信・育成までを一続きの支援線として設計しています。"
        items={serviceMap}
      />
    </div>
  </section>

  <section class="ac-section">
    <div class="ac-container max-w-4xl">
      <nav class="mb-12 flex flex-wrap gap-2 justify-center">
        <a href="#system-development" class="text-sm px-4 py-2 min-h-11 inline-flex items-center rounded-full border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-600 transition-colors">開発</a>
        <a href="#server" class="text-sm px-4 py-2 min-h-11 inline-flex items-center rounded-full border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-600 transition-colors">サーバー</a>
        <a href="#web" class="text-sm px-4 py-2 min-h-11 inline-flex items-center rounded-full border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-600 transition-colors">Web制作</a>
        <a href="#design" class="text-sm px-4 py-2 min-h-11 inline-flex items-center rounded-full border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-600 transition-colors">デザイン</a>
        <a href="#education" class="text-sm px-4 py-2 min-h-11 inline-flex items-center rounded-full border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-600 transition-colors">ITスクール</a>
        <a href="#aceserver" class="text-sm px-4 py-2 min-h-11 inline-flex items-center rounded-full border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-600 transition-colors">Aceserver</a>
        <a href="#acestudio" class="text-sm px-4 py-2 min-h-11 inline-flex items-center rounded-full border border-slate-200 text-slate-600 hover:border-brand-400 hover:text-brand-600 transition-colors">AceStudio</a>
      </nav>

      <!-- 業務システム・アプリ開発 -->
      <div class="mb-16" id="system-development">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-code-2 text-3xl text-brand-500"></div>
          <h2 class="text-2xl ac-heading">業務システム・アプリ開発</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          業務効率化・自動化・データ管理など、お客様の目的に応じたシステムやアプリケーションの開発を行います。
          小規模な社内ツールから大規模なWebサービスまで幅広く対応可能です。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">対応例</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              業務管理システム・CRM・ERPの設計・構築
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              Webアプリケーション・SPA・モバイルアプリの開発
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              API設計・外部サービス連携・データ基盤構築
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              レガシーシステムのモダナイゼーション
            </li>
          </ul>
        </div>
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&h=450&fit=crop&q=80&fm=webp')}
          alt="コードエディタでの開発作業のイメージ"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- サーバー構築・運用 -->
      <div class="mb-16" id="server">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-server text-3xl text-brand-500"></div>
          <h2 class="text-2xl ac-heading">サーバー構築・運用</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          セキュアで安定したサーバー環境の構築と運用を得意としています。
          Acecoreでは<a
            href="https://asv.acecore.net"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-500 hover:underline">Aceserver（マインクラフト公開サーバー）</a
          >を長期運用しており、そこで培ったノウハウを企業向けにもご提供します。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">対応例</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              クラウドサーバー（AWS / Azure / GCP / Cloudflare）の設計・構築
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              Linux / Windows サーバーの運用・監視・保守
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              ゲームサーバー・コミュニティサーバーの構築
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              セキュリティ対策・バックアップ体制の整備
            </li>
          </ul>
        </div>
      </div>

      <!-- Webサイト制作・運用 -->
      <div class="mb-16" id="web">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-globe text-3xl text-brand-500"></div>
          <h2 class="text-2xl ac-heading">Webサイト制作・運用</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          コーポレートサイト、ポートフォリオ、ECサイト、コミュニティサイトなど、
          各種Webサイトの企画から制作、運用保守までを一貫して対応します。
          最新の技術スタックとSEO対策で、高品質なサイトを実現します。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">対応例</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              コーポレートサイト・ランディングページの制作
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              CMS構築・ブログ・メディアサイト
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              ECサイト・オンラインショップの構築
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              SEO対策・パフォーマンス最適化・アクセシビリティ改善
            </li>
          </ul>
        </div>
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1547658719-da2b51169166?w=800&h=450&fit=crop&q=80&fm=webp')}
          alt="Webデザインの制作プロセス"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <div class="mb-16">
        <Timeline
          title="導入から改善までの伴走イメージ"
          items={deliveryTimeline}
        />
      </div>

      <!-- デザイン・クリエイティブ -->
      <div class="mb-16" id="design">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-palette text-3xl text-brand-500"></div>
          <h2 class="text-2xl ac-heading">デザイン・クリエイティブ</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          ロゴデザイン、印刷物、バナー、キャラクターデザインなど幅広いクリエイティブ制作を手掛けています。
          お客様の「伝えたい」を的確に形にすることを大切にしています。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">対応例</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              ロゴ・ブランドアイデンティティの設計
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              名刺・パンフレット・ポスターなどの印刷物
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              Webバナー・SNS用クリエイティブ
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              キャラクターデザイン・イラスト制作
            </li>
          </ul>
        </div>
      </div>

      <div class="mb-16">
        <img
          src={optimizeImage('https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=800&h=450&fit=crop&q=80&fm=webp')}
          alt="クリエイティブなデザインワークスペース"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <!-- ITスクール -->
      <div class="mb-16" id="education">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-graduation-cap text-3xl text-brand-500"></div>
          <h2 class="text-2xl ac-heading">ITスクール / Acecore Schools</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          実務で通用するITスキルを、現役エンジニアが直接指導するスクールです。
          学習塾・ロボットプログラミング・実践プログラミング・パソコン/スマホ教室・高卒認定対策など、幅広い教育プログラムを提供しています。
        </p>
        <div class="bg-slate-50 rounded-lg p-6">
          <h3 class="font-600 text-sm text-slate-900 mb-3">コース一覧</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              学習塾（個別指導・定期テスト/受験対策）
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              ロボット / プログラミング（ロボット工作・マイクラプログラミング）
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              実践プログラミング（Web開発・バックエンド・データベース）
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              パソコン / スマホ（基本操作・オフィスソフト・セキュリティ）
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              高卒認定（試験対策・個別学習計画）
            </li>
          </ul>
        </div>
        <div class="mt-4">
          <a href="/schools/" class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1">
            <div class="i-lucide-arrow-right text-sm"></div>
            Acecore Schools の詳細を見る
          </a>
        </div>
      </div>

      <!-- Aceserver -->
      <div class="mb-16" id="aceserver">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-gamepad-2 text-3xl text-brand-500"></div>
          <h2 class="text-2xl ac-heading">Aceserver（マインクラフト公開サーバー）</h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          Aceserver（エースサーバー）は、Acecoreが運営するマインクラフトの無料公開サーバーです。
          「みんなの居場所で有ること」を理念に、JAVA版・統合版のどちらからでも参加でき、バニラに近い自由な環境でマルチプレイを楽しめます。
          数百人規模の同時接続にも耐える安定運用実績があり、ここで培ったインフラ技術は企業向けサービスにもフィードバックされています。
        </p>
        <div class="bg-slate-50 rounded-lg p-6 mb-4">
          <h3 class="font-600 text-sm text-slate-900 mb-3">特徴</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              誰でも無料で参加可能（アカウントさえあればOK）
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              JAVA版・統合版クロスプレイ対応
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              バニラに近い自由度の高いゲーム環境
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              活発なDiscordコミュニティで交流・情報共有
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              配信・宣伝OK（申請不要で自由にご活用いただけます）
            </li>
          </ul>
        </div>
        <div class="flex flex-wrap gap-3 mb-4">
          <a
            href="https://asv.acecore.net/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1"
          >
            <div class="i-lucide-external-link text-sm"></div>
            Aceserver ポータル
          </a>
          <a
            href="https://aceserver-wiki.acecore.systems/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1"
          >
            <div class="i-lucide-external-link text-sm"></div>
            Aceserver Wiki
          </a>
          <a
            href="https://discord.gg/acsv"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1"
          >
            <div class="i-lucide-external-link text-sm"></div>
            Discord
          </a>
        </div>
      </div>

      <!-- AceStudio -->
      <div class="mb-16" id="acestudio">
        <div class="flex items-center gap-3 mb-4">
          <div class="i-lucide-clapperboard text-3xl text-brand-500"></div>
          <h2 class="text-2xl ac-heading">AceStudio <span class="text-sm font-400 text-slate-500 ml-2">Coming Soon</span></h2>
        </div>
        <p class="text-slate-600 leading-relaxed mb-4">
          AceStudio（エーススタジオ）は、Acecoreが開発中の新サービスです。
          クリエイターの力を最大限に引き出すプラットフォームとして、
          デザイン・映像・音楽・開発など幅広い領域でのクリエイティブ活動を支援します。
        </p>
        <div class="bg-slate-50 rounded-lg p-6 mb-4">
          <h3 class="font-600 text-sm text-slate-900 mb-3">想定する機能・領域</h3>
          <ul class="text-sm text-slate-600 space-y-2 list-none p-0 m-0">
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              クリエイター向けのコラボレーション環境
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              デザイン・映像・音楽・プログラミングなど多領域対応
            </li>
            <li class="flex items-center gap-2">
              <div class="i-lucide-check text-brand-500 shrink-0"></div>
              制作から公開までをシームレスに支援するワークフロー
            </li>
          </ul>
        </div>
        <p class="text-sm text-slate-500 mb-4">
          サービスの詳細は、準備が整い次第公開いたします。最新情報は<a href="https://x.com/acecorenet" target="_blank" rel="noopener noreferrer" class="text-brand-500 hover:underline">X</a>やブログで随時お知らせします。
        </p>
        <div class="mt-2">
          <a href="/acestudio/" class="text-brand-500 hover:underline text-sm inline-flex items-center gap-1">
            <div class="i-lucide-arrow-right text-sm"></div>
            AceStudio の詳細を見る
          </a>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center bg-brand-50 rounded-xl p-8">
        <p class="text-lg text-slate-700 mb-6">
          サービスに関するご質問・ご相談はお気軽にどうぞ。
        </p>
        <a href="/contact/" class="ac-btn-primary">お問い合わせ</a>
      </div>
    </div>
  </section>
</BaseLayout>
