---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
---

<BaseLayout
  title="お問い合わせ"
  description="Acecoreへのお問い合わせはこちらから。サービスに関するご質問、お見積り、パートナーシップのご相談などお気軽にどうぞ。"
>
  <Hero title="お問い合わせ" subtitle="ご質問・ご相談・ご依頼はこちらから" />

  <section class="ac-section">
    <div class="ac-container max-w-2xl">
      <form id="contact-form" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-600 text-slate-700 mb-2">
            お名前 <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
        </div>
        <div>
          <label
            for="email"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            メールアドレス <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
        </div>
        <div>
          <label
            for="subject"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            件名
          </label>
          <input
            type="text"
            id="subject"
            name="subject"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
        </div>
        <div>
          <label
            for="message"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            お問い合わせ内容 <span class="text-red-500">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"
          ></textarea>
        </div>
        <div>
          <button type="submit" class="ac-btn-primary w-full sm:w-auto">
            送信する
          </button>
        </div>
        <div id="form-status" class="hidden text-center py-4 rounded-lg">
        </div>
      </form>
    </div>
  </section>

  <section class="bg-slate-50 py-12">
    <div class="ac-container max-w-2xl">
      <h2 class="text-xl ac-heading mb-6 text-center">
        その他のお問い合わせ方法
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a
          href="https://discord.gg/acsv"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow text-center"
        >
          <div class="i-lucide-message-circle text-2xl text-brand-500 mx-auto mb-2"></div>
          <h3 class="font-600 text-slate-900 mb-1">Discord</h3>
          <p class="text-sm text-slate-600">
            コミュニティに参加してお気軽にお声がけください
          </p>
        </a>
        <a
          href="https://twitter.com/AceCoreS"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow text-center"
        >
          <div class="i-lucide-twitter text-2xl text-brand-500 mx-auto mb-2"></div>
          <h3 class="font-600 text-slate-900 mb-1">X（旧Twitter）</h3>
          <p class="text-sm text-slate-600">
            DMでのお問い合わせも受け付けています
          </p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const status = document.getElementById('form-status') as HTMLDivElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const formData = new FormData(form)
    const data = Object.fromEntries(formData)

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (res.ok) {
        status.textContent =
          'お問い合わせを受け付けました。ありがとうございます。'
        status.className =
          'text-center py-4 rounded-lg bg-green-50 text-green-700'
        form.reset()
      } else {
        throw new Error('送信に失敗しました')
      }
    } catch {
      status.textContent =
        '送信に失敗しました。恐れ入りますが、Discord または X よりお問い合わせください。'
      status.className = 'text-center py-4 rounded-lg bg-red-50 text-red-700'
    }
  })
</script>
