---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
---

<BaseLayout
  title="お問い合わせ"
  description="Acecoreへのお問い合わせはこちらから。サービスに関するご質問、お見積り、パートナーシップのご相談などお気軽にどうぞ。"
>
  <Hero title="お問い合わせ" subtitle="ご質問・ご相談・ご依頼はこちらから" images={[{src: 'https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1400&h=600&fit=crop&q=80&fm=webp', alt: 'コミュニケーションイメージ'}]} />

  <section class="ac-section">
    <div class="ac-container max-w-2xl">
      <form action="https://ssgform.com/s/a4JOVjLjyygh" method="post" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-600 text-slate-700 mb-2">
            お名前 <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="お名前"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
        </div>
        <div>
          <label
            for="email"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            メールアドレス <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="メールアドレス"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
        </div>
        <div>
          <label
            for="subject"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            件名
          </label>
          <input
            type="text"
            id="subject"
            name="件名"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
        </div>
        <div>
          <label
            for="message"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            お問い合わせ内容 <span class="text-red-500">*</span>
          </label>
          <textarea
            id="message"
            name="お問い合わせ内容"
            rows="6"
            required
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"
          ></textarea>
        </div>
        <div>
          <button type="submit" class="ac-btn-primary w-full sm:w-auto">
            送信する
          </button>
        </div>
      </form>
    </div>
  </section>

  <section class="bg-slate-50 py-12">
    <div class="ac-container max-w-2xl">
      <h2 class="text-xl ac-heading mb-6 text-center">
        その他のお問い合わせ方法
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="ac-card p-6 text-center">
          <div class="i-lucide-phone text-2xl text-brand-500 mx-auto mb-2"></div>
          <h3 class="font-600 text-slate-900 mb-1">お電話</h3>
          <p class="text-sm text-slate-600 font-600">
            <a href="tel:05088902788" class="text-brand-500 hover:underline">050-8890-2788</a>
          </p>
        </div>
        <div class="ac-card p-6 text-center">
          <div class="i-lucide-mail text-2xl text-brand-500 mx-auto mb-2"></div>
          <h3 class="font-600 text-slate-900 mb-1">メール</h3>
          <p class="text-sm text-slate-600">
            <a href="mailto:info@acecore.net" class="text-brand-500 hover:underline">info@acecore.net</a>
          </p>
        </div>
        <a
          href="https://lin.ee/DjIrdqj"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow text-center"
        >
          <div class="i-lucide-message-circle text-2xl text-brand-500 mx-auto mb-2"></div>
          <h3 class="font-600 text-slate-900 mb-1">LINE</h3>
          <p class="text-sm text-slate-600">
            LINEでもお気軽にお問い合わせください
          </p>
        </a>
        <a
          href="https://x.com/acecorenet"
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow text-center"
        >
          <div class="i-lucide-at-sign text-2xl text-brand-500 mx-auto mb-2"></div>
          <h3 class="font-600 text-slate-900 mb-1">X</h3>
          <p class="text-sm text-slate-600">
            DMでのお問い合わせも受け付けています
          </p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
