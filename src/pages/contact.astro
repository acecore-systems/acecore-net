---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { optimizeImage } from '../utils/image'
import { SITE } from '../data/site'
---

<BaseLayout
  title="お問い合わせ"
  description="Acecoreへのお問い合わせはこちらから。サービスに関するご質問、お見積り、パートナーシップのご相談などお気軽にどうぞ。"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "お問い合わせ | Acecore",
    "description": "Acecoreへのお問い合わせはこちらから。サービスに関するご質問、お見積り、パートナーシップのご相談などお気軽にどうぞ。",
    "url": "https://acecore.net/contact/",
    "mainEntity": {
      "@type": "Organization",
      "name": "Acecore",
      "telephone": SITE.phoneIntl,
      "email": SITE.email
    }
  }}
>
  <Hero title="お問い合わせ" subtitle="ご質問・ご相談・ご依頼はこちらから" images={[{src: optimizeImage('https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1400&h=600&fit=crop&q=80&fm=webp'), alt: 'コミュニケーションイメージ'}]} />

  <section class="ac-section">
    <div class="ac-container max-w-2xl">	    <Breadcrumb items={[{ label: 'お問い合わせ' }]} />      <div class="bg-brand-50 rounded-lg p-6 mb-8">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 text-sm text-slate-700">
          <div class="flex items-center gap-2">
            <div class="i-lucide-clock text-brand-500 shrink-0" aria-hidden="true"></div>
            <span>通常1〜2営業日以内にご返信</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="i-lucide-badge-check text-brand-500 shrink-0" aria-hidden="true"></div>
            <span>お見積り無料</span>
          </div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-8 text-sm">
        <div class="flex items-center gap-2">
          <div class="i-lucide-phone text-brand-500" aria-hidden="true"></div>
          <span class="font-600 text-slate-800">{SITE.phone}</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="i-lucide-mail text-brand-500" aria-hidden="true"></div>
          <a href={`mailto:${SITE.email}`} class="font-600 text-brand-500 hover:underline">{SITE.email}</a>
        </div>
        <a
          href={SITE.line}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 font-600 text-brand-500 hover:underline"
        >
          <div class="i-lucide-message-circle text-brand-500" aria-hidden="true"></div>
          LINEで問い合わせる<span class="sr-only">（新しいタブで開きます）</span>
        </a>
      </div>
      <form action="https://ssgform.com/s/a4JOVjLjyygh" method="post" class="space-y-6">
        <div>
          <label for="category" class="block text-sm font-600 text-slate-700 mb-2">
            お問い合わせ種別 <span class="text-red-500" aria-hidden="true">*</span><span class="sr-only">（必須）</span>
          </label>
          <select
            id="category"
            name="お問い合わせ種別"
            required
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          >
            <option value="" disabled selected>選択してください</option>
            <option value="サービスについて">サービスについて</option>
            <option value="お見積り依頼">お見積り依頼</option>
            <option value="パートナーシップ">パートナーシップのご相談</option>
            <option value="採用について">採用について</option>
            <option value="その他">その他</option>
          </select>
          <p class="text-xs text-red-600 mt-1 hidden" id="category-error" role="alert"></p>
        </div>
        <div>
          <label for="name" class="block text-sm font-600 text-slate-700 mb-2">
            お名前 <span class="text-red-500" aria-hidden="true">*</span><span class="sr-only">（必須）</span>
          </label>
          <input
            type="text"
            id="name"
            name="お名前"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
          <p class="text-xs text-red-600 mt-1 hidden" id="name-error" role="alert"></p>
        </div>
        <div>
          <label
            for="email"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            メールアドレス <span class="text-red-500" aria-hidden="true">*</span><span class="sr-only">（必須）</span>
          </label>
          <input
            type="email"
            id="email"
            name="メールアドレス"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
          <p class="text-xs text-red-600 mt-1 hidden" id="email-error" role="alert"></p>
        </div>
        <div>
          <label
            for="subject"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            件名
          </label>
          <input
            type="text"
            id="subject"
            name="件名"
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          />
        </div>
        <div>
          <label
            for="message"
            class="block text-sm font-600 text-slate-700 mb-2"
          >
            お問い合わせ内容 <span class="text-red-500" aria-hidden="true">*</span><span class="sr-only">（必須）</span>
          </label>
          <textarea
            id="message"
            name="お問い合わせ内容"
            rows="6"
            required
            class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-white text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"
          ></textarea>
          <p class="text-xs text-red-600 mt-1 hidden" id="message-error" role="alert"></p>
        </div>
        <div class="cf-turnstile" data-sitekey={SITE.turnstileSiteKey} data-language="ja" data-theme="light"></div>
        <div>
          <button type="submit" id="contact-submit" class="ac-btn-primary w-full sm:w-auto disabled:opacity-50 disabled:cursor-not-allowed">
            送信する
          </button>
          <p class="text-xs text-slate-600 mt-3">
            送信後、確認メールが届きます。届かない場合は迷惑メールフォルダもご確認ください。
          </p>
        </div>
        <div id="form-feedback" class="hidden rounded-lg p-4 text-sm" role="alert"></div>
      </form>
    </div>
  </section>

  <section class="bg-slate-50 py-12">
    <div class="ac-container max-w-2xl">
      <h2 class="text-xl ac-heading mb-6 text-center">
        その他のお問い合わせ方法
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="ac-card p-6 text-center">
          <div class="i-lucide-phone text-2xl text-brand-500 mx-auto mb-2" aria-hidden="true"></div>
          <h3 class="font-600 text-slate-900 mb-1">お電話</h3>
          <p class="text-sm text-slate-600 font-600">
            <a href={`tel:${SITE.phone.replace(/-/g, '')}`} class="text-brand-500 hover:underline">{SITE.phone}</a>
          </p>
        </div>
        <div class="ac-card p-6 text-center">
          <div class="i-lucide-mail text-2xl text-brand-500 mx-auto mb-2" aria-hidden="true"></div>
          <h3 class="font-600 text-slate-900 mb-1">メール</h3>
          <p class="text-sm text-slate-600">
            <a href={`mailto:${SITE.email}`} class="text-brand-500 hover:underline">{SITE.email}</a>
          </p>
        </div>
        <a
          href={SITE.line}
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow text-center"
        >
          <div class="i-lucide-message-circle text-2xl text-brand-500 mx-auto mb-2" aria-hidden="true"></div>
          <h3 class="font-600 text-slate-900 mb-1">LINE</h3>
          <p class="text-sm text-slate-600">
            LINEでもお気軽にお問い合わせください
          </p>
          <span class="sr-only">（新しいタブで開きます）</span>
        </a>
        <a
          href={SITE.social.x}
          target="_blank"
          rel="noopener noreferrer"
          class="ac-card p-6 no-underline hover:shadow-md transition-shadow text-center"
        >
          <div class="i-lucide-at-sign text-2xl text-brand-500 mx-auto mb-2" aria-hidden="true"></div>
          <h3 class="font-600 text-slate-900 mb-1">X</h3>
          <p class="text-sm text-slate-600">
            DMでのお問い合わせも受け付けています
          </p>
          <span class="sr-only">（新しいタブで開きます）</span>
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
  {
    const turnstileEl = document.querySelector('.cf-turnstile');
    if (turnstileEl) {
      const io = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          io.disconnect();
          const s = document.createElement('script');
          s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
          s.async = true;
          document.head.appendChild(s);
        }
      }, { rootMargin: '200px' });
      io.observe(turnstileEl);
    }
  }
  </script>
  <script is:inline>
  {
    const rules = {
      category: function(v) { return v ? '' : 'お問い合わせ種別を選択してください'; },
      name: function(v) { return v.trim() ? '' : 'お名前を入力してください'; },
      email: function(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? '' : '正しいメールアドレスを入力してください'; },
      message: function(v) { return v.trim() ? '' : 'お問い合わせ内容を入力してください'; }
    };
    function showError(id, msg) {
      const el = document.getElementById(id + '-error');
      const input = document.getElementById(id);
      if (!el || !input) return;
      if (msg) {
        el.textContent = msg;
        el.classList.remove('hidden');
        input.classList.add('border-red-400');
        input.setAttribute('aria-invalid', 'true');
        input.setAttribute('aria-describedby', id + '-error');
      } else {
        el.textContent = '';
        el.classList.add('hidden');
        input.classList.remove('border-red-400');
        input.removeAttribute('aria-invalid');
        input.removeAttribute('aria-describedby');
      }
    }
    Object.keys(rules).forEach(function(id) {
      var el = document.getElementById(id);
      if (el) {
        el.addEventListener('blur', function() {
          showError(id, rules[id](el.value));
        });
        el.addEventListener('input', function() {
          if (el.getAttribute('aria-invalid')) showError(id, rules[id](el.value));
        });
      }
    });
  }
  </script>
  <script is:inline>
  {
    const form = document.querySelector('form[action*="ssgform"]');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        const btn = document.getElementById('contact-submit');
        const feedback = document.getElementById('form-feedback');
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '送信中…';
        feedback.className = 'hidden rounded-lg p-4 text-sm';
        fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        }).then(function(res) {
          if (res.ok) {
            feedback.textContent = 'お問い合わせを送信しました。確認メールをご確認ください。';
            feedback.className = 'rounded-lg p-4 text-sm bg-emerald-50 text-emerald-800 border border-emerald-200';
            form.reset();
            if (typeof turnstile !== 'undefined') turnstile.reset();
          } else {
            throw new Error('送信に失敗しました');
          }
        }).catch(function() {
          feedback.textContent = '送信に失敗しました。時間をおいて再度お試しいただくか、メール・お電話でお問い合わせください。';
          feedback.className = 'rounded-lg p-4 text-sm bg-red-50 text-red-800 border border-red-200';
        }).finally(function() {
          btn.disabled = false;
          btn.textContent = originalText;
        });
      });
    }
  }
  </script>
</BaseLayout>
