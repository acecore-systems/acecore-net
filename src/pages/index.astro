---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import ServiceCard from '../components/ServiceCard.astro'
import InsightGrid from '../components/InsightGrid.astro'
import { getCollection } from 'astro:content'
import authors from '../data/authors.json'
import { optimizeImage, generateSrcSet } from '../utils/image'
import { SITE } from '../data/site'

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)

const coreLayers = [
  {
    title: 'システム設計',
    description:
      '業務課題を要件に落とし込み、実装と運用まで見据えて仕組みを作ります。',
    icon: 'i-lucide-code-2',
    tone: 'brand',
  },
  {
    title: 'インフラ運用',
    description:
      '公開サーバー運用の経験をもとに、止めにくい環境と改善サイクルを整えます。',
    icon: 'i-lucide-server-cog',
    tone: 'emerald',
  },
  {
    title: '伝わるデザイン',
    description:
      '見た目の装飾ではなく、情報整理と体験設計としてデザインを扱います。',
    icon: 'i-lucide-swatch-book',
    tone: 'amber',
  },
  {
    title: '教育と伴走',
    description:
      '現場で使える知識を学習支援に変換し、地域や次世代へ循環させます。',
    icon: 'i-lucide-graduation-cap',
    tone: 'slate',
  },
] as const
const firstHeroSrc = optimizeImage(
  'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1400&h=600&fit=crop&q=80&fm=webp',
)

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Acecore | システム開発・Web制作・IT教育',
  description:
    'Acecore（エースコア）は、システム開発・Webサイト制作・サーバー運用・デザイン・IT教育をワンストップで提供するテクノロジー集団です。',
  url: 'https://acecore.net/',
}
---

<BaseLayout
  title="ホーム"
  jsonLd={webPageLd}
  preloadImage={{
    src: firstHeroSrc,
    srcset: generateSrcSet(firstHeroSrc),
    sizes: '100vw',
  }}
>
  <Hero
    title="開発からデザイン、教育まで。ワンストップで届けるIT支援"
    subtitle="システム開発・Web制作・サーバー運用・デザイン・IT教育を、一つの窓口でまとめてお任せいただけます。"
    showCTA={true}
    images={[
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: 'コワーキングスペースで働くチーム',
      },
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: 'チームワークでプロジェクトを推進',
      },
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: 'ミーティング風景',
      },
      {
        src: optimizeImage(
          'https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1400&h=600&fit=crop&q=80&fm=webp',
        ),
        alt: 'ビジネス戦略の打ち合わせ',
      },
    ]}
  />

  <!-- サービス紹介 -->
  <section class="ac-section bg-slate-50">
    <div class="ac-container">
      <h2 class="text-2xl sm:text-3xl ac-heading text-center mb-4">
        主なサービス
      </h2>
      <p class="ac-muted text-center max-w-2xl mx-auto mb-12">
        「何から頼めばいいか分からない」という方もご安心ください。個人から法人まで柔軟に対応します。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <ServiceCard
          icon="i-lucide-code-2"
          title="業務システム・アプリ開発"
          description="日々の業務を効率化したい、データ管理を改善したいといった課題を、最適なシステムで解決します。小規模ツールから大規模サービスまで対応可能です。"
          href="/services/#system-development"
        />
        <ServiceCard
          icon="i-lucide-server"
          title="サーバー構築・運用"
          description="サーバーが落ちない、遅くならない環境をお届けします。数百人規模の同時接続を支えてきた運用実績があります。"
          href="/services/#server"
        />
        <ServiceCard
          icon="i-lucide-globe"
          title="Webサイト制作・運用"
          description="見た目だけでなく集客や使いやすさまで考え抜いたWebサイトを制作。公開後の更新・保守もお任せください。"
          href="/services/#web"
        />
        <ServiceCard
          icon="i-lucide-palette"
          title="デザイン・クリエイティブ"
          description="ロゴ・名刺・バナー・キャラクターなど、あなたの「伝えたい」を見える形にします。"
          href="/services/#design"
        />
        <ServiceCard
          icon="i-lucide-graduation-cap"
          title="ITスクール / Acecore Schools"
          description="お子さまから大人まで、一人ひとりに合わせた個別指導。プログラミング・学習塾・高卒認定対策に対応しています。"
          href="/schools/"
        />
        <ServiceCard
          icon="i-lucide-gamepad-2"
          title="Aceserver"
          description="誰でも無料で参加できるマインクラフト公開サーバー。JAVA版・統合版に対応し、活発なコミュニティがあなたを待っています。"
          href={SITE.social.aceserver}
        />
      </div>
      <div class="text-center mt-10">
        <a href="/services/" class="ac-btn-outline">サービス詳細を見る</a>
      </div>
    </div>
  </section>

  <section class="ac-section">
    <div class="ac-container">
      <InsightGrid
        variant="card"
        eyebrow="Visual Overview"
        title="Acecoreが支える4つのレイヤー"
        description="技術、運用、表現、教育を分断せず、一つの支援線として扱っています。"
        items={coreLayers}
      />
    </div>
  </section>

  <!-- 会社紹介 -->
  <section class="ac-section">
    <div class="ac-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl sm:text-3xl ac-heading mb-6">Acecoreについて</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-4">
          技術の勉強会やワークショップを定期開催し、お客様やコミュニティと一緒に学び合う場を大切にしています。
        </p>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          オープンソース活用・地域連携・<a href="/schools/" class="ac-link"
            >教育分野</a
          >への貢献を通じて、技術と人をつなげるパートナーシップを築いています。
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a href="/about/" class="ac-btn-primary">会社概要を見る</a>
          <a href="/services/" class="ac-btn-outline">サービス一覧を見る</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ブログ最新記事 -->
  {
    posts.length > 0 && (
      <section class="ac-section bg-slate-50">
        <div class="ac-container">
          <h2 class="text-2xl sm:text-3xl ac-heading text-center mb-12">
            最新のブログ
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="ac-card overflow-hidden no-underline hover:shadow-md transition-shadow group"
              >
                {post.data.image && (
                  <img
                    src={optimizeImage(post.data.image)}
                    srcset={generateSrcSet(post.data.image, [200, 400, 800])}
                    sizes="(min-width: 768px) 33vw, 100vw"
                    alt={post.data.title}
                    class="w-full h-40 object-cover"
                    width="400"
                    height="160"
                    decoding="async"
                    loading="lazy"
                  />
                )}
                <div class="p-6">
                  <div class="flex items-center gap-2 text-xs text-slate-600">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('ja-JP')}
                    </time>
                    {post.data.author && (
                      <span>
                        by{' '}
                        {authors.find((a) => a.id === post.data.author)?.name ||
                          post.data.author}
                      </span>
                    )}
                  </div>
                  <h3 class="text-lg font-700 text-slate-900 mt-2 mb-3 group-hover:text-brand-500 transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-slate-600 line-clamp-3">
                    {post.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
          <div class="text-center mt-10">
            <a href="/blog/" class="ac-btn-outline">
              すべての記事を見る
            </a>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
