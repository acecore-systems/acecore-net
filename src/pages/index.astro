---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import ServiceCard from '../components/ServiceCard.astro'
import ProcessFigure from '../components/ProcessFigure.astro'
import InsightGrid from '../components/InsightGrid.astro'
import { getCollection } from 'astro:content'
import authors from '../data/authors.json'

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)

const coreLayers = [
  {
    title: 'システム設計',
    description: '業務課題を要件に落とし込み、実装と運用まで見据えて仕組みを作ります。',
    icon: 'i-lucide-code-2',
    tone: 'brand',
  },
  {
    title: 'インフラ運用',
    description: '公開サーバー運用の経験をもとに、止めにくい環境と改善サイクルを整えます。',
    icon: 'i-lucide-server-cog',
    tone: 'emerald',
  },
  {
    title: '伝わるデザイン',
    description: '見た目の装飾ではなく、情報整理と体験設計としてデザインを扱います。',
    icon: 'i-lucide-swatch-book',
    tone: 'amber',
  },
  {
    title: '教育と伴走',
    description: '現場で使える知識を学習支援に変換し、地域や次世代へ循環させます。',
    icon: 'i-lucide-graduation-cap',
    tone: 'slate',
  },
]

const supportFlow = [
  {
    title: '相談を整理する',
    description: '現状の課題、必要な機能、運用体制を整理して優先順位を定めます。',
    icon: 'i-lucide-messages-square',
    accent: 'brand',
  },
  {
    title: '作るべき形を設計する',
    description: 'Web、システム、サーバー、デザインを横断して最適な構成を組み立てます。',
    icon: 'i-lucide-drafting-compass',
    accent: 'emerald',
  },
  {
    title: '公開と定着を進める',
    description: '制作して終わりにせず、公開後の更新や保守も含めて整備します。',
    icon: 'i-lucide-rocket',
    accent: 'amber',
  },
  {
    title: '成果を次へつなぐ',
    description: '教育、改善提案、運用ノウハウ化まで含めて長く使える状態に育てます。',
    icon: 'i-lucide-refresh-cw',
    accent: 'slate',
  },
]
---

<BaseLayout title="ホーム">
  <Hero
    title="技術でつながる、クリエイティブで広がる"
    subtitle="Acecore（エースコア）は、システム開発・Web制作・サーバー運用・デザイン・IT教育をワンストップで提供するテクノロジー集団です。"
    showCTA={true}
    images={[
      'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1400&h=600&fit=crop&q=80',
      'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1400&h=600&fit=crop&q=80',
      'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1400&h=600&fit=crop&q=80',
      'https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1400&h=600&fit=crop&q=80',
    ]}
  />

  <!-- サービス紹介 -->
  <section class="ac-section bg-slate-50">
    <div class="ac-container">
      <h2 class="text-2xl sm:text-3xl ac-heading text-center mb-4">
        主なサービス
      </h2>
      <p class="ac-muted text-center max-w-2xl mx-auto mb-12">
        個人から法人まで、多様なニーズに合わせて柔軟にサポートします。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <ServiceCard
          icon="i-lucide-code-2"
          title="業務システム・アプリ開発"
          description="業務効率化・自動化・データ管理など、目的に応じたシステム・アプリを開発。小規模案件から大規模プロジェクトまで幅広く対応します。"
          href="/services/#system-development"
        />
        <ServiceCard
          icon="i-lucide-server"
          title="サーバー構築・運用"
          description="セキュアで安定したサーバー構築・運用をご提供。Aceserverなど公共性の高い運用実績も多数あります。"
          href="/services/#server"
        />
        <ServiceCard
          icon="i-lucide-globe"
          title="Webサイト制作・運用"
          description="コーポレートサイト、ポートフォリオ、ECサイトなどを企画・制作。デザインから運用保守まで一貫対応します。"
          href="/services/#web"
        />
        <ServiceCard
          icon="i-lucide-palette"
          title="デザイン・クリエイティブ"
          description="ロゴ、印刷物、バナー、キャラクターデザインなど幅広い制作実績。「伝えたい」を形にします。"
          href="/services/#design"
        />
        <ServiceCard
          icon="i-lucide-graduation-cap"
          title="ITスクール / Acecore Schools"
          description="学習塾・ロボプロ・実践プログラミング・パソコン教室・高卒認定対策など、幅広い教育プログラムを提供。"
          href="/schools/"
        />
        <ServiceCard
          icon="i-lucide-gamepad-2"
          title="Aceserver"
          description="誰でも参加可能なマインクラフト無料公開サーバー。JAVA版・統合版対応で、自由で活発なコミュニティを運営しています。"
          href="https://asv.acecore.net/"
        />
      </div>
      <div class="text-center mt-10">
        <a href="/services/" class="ac-btn-outline">サービス詳細を見る</a>
      </div>
    </div>
  </section>

  <section class="ac-section">
    <div class="ac-container space-y-8">
      <InsightGrid
        eyebrow="Visual Overview"
        title="Acecoreが支える4つのレイヤー"
        description="business-plan 側で使っていたような『構造を一目で見せる』考え方を、コーポレートサイト向けに再構成しました。技術、運用、表現、教育を分断せず、一つの支援線として扱っています。"
        items={coreLayers}
      />
      <ProcessFigure
        eyebrow="Support Flow"
        title="相談から運用定着までの流れ"
        description="案件単位の制作だけでなく、公開後に安定して使い続けられるところまでを支援範囲に含めています。"
        steps={supportFlow}
      />
    </div>
  </section>

  <!-- 会社紹介 -->
  <section class="ac-section">
    <div class="ac-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl sm:text-3xl ac-heading mb-6">Acecoreについて</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-4">
          「つながり・発見・共創」をテーマに、コミュニティ活動や勉強会を定期開催しています。
        </p>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          オープンソース活用・地域連携・教育分野への貢献を通じて、技術と人をつなげるパートナーシップを築いています。
        </p>
        <a href="/about/" class="ac-btn-primary">会社概要を見る</a>
      </div>
    </div>
  </section>

  <!-- ブログ最新記事 -->
  {
    posts.length > 0 && (
      <section class="ac-section bg-slate-50">
        <div class="ac-container">
          <h2 class="text-2xl sm:text-3xl ac-heading text-center mb-12">
            最新のブログ
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {posts.map((post) => (
              <a
                href={`/blog/${post.slug}/`}
                class="ac-card overflow-hidden no-underline hover:shadow-md transition-shadow group"
              >
                {(post.data.image || post.data.imageUrl) && (
                  <img
                    src={post.data.image || post.data.imageUrl}
                    alt={post.data.title}
                    class="w-full h-40 object-cover"
                    loading="lazy"
                  />
                )}
                <div class="p-6">
                  <div class="flex items-center gap-2 text-xs text-slate-400">
                    <time>{post.data.date.toLocaleDateString('ja-JP')}</time>
                    {post.data.author && <span>by {authors.find((a) => a.id === post.data.author)?.name || post.data.author}</span>}
                  </div>
                  <h3 class="text-lg font-700 text-slate-900 mt-2 mb-3 group-hover:text-brand-500 transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-slate-600 line-clamp-3">
                    {post.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
          <div class="text-center mt-10">
            <a href="/blog/" class="ac-btn-outline">
              すべての記事を見る
            </a>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
