---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { optimizeImage } from '../utils/image'

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4)
---

<BaseLayout
  title="ページが見つかりません"
  description="お探しのページは見つかりませんでした。URLをご確認いただくか、トップページからお探しください。"
  robots="noindex, nofollow"
>
  <section class="ac-section">
    <div class="ac-container text-center py-20">
      <p class="text-6xl font-700 text-brand-500 mb-4">404</p>
      <h1 class="text-2xl sm:text-3xl font-700 text-slate-800 mb-4">
        ページが見つかりません
      </h1>
      <p class="text-slate-600 mb-8 max-w-md mx-auto">
        お探しのページは移動または削除された可能性があります。<br />
        URLをご確認いただくか、以下から検索・お探しください。
      </p>

      <div class="max-w-md mx-auto mb-10">
        <button
          data-search-trigger
          class="w-full flex items-center gap-3 px-4 py-3 rounded-lg border border-slate-300 text-slate-500 hover:border-brand-300 hover:text-brand-500 transition-colors cursor-pointer text-left"
        >
          <div class="i-lucide-search text-lg" aria-hidden="true"></div>
          <span>サイト内を検索する...</span>
          <kbd
            class="ml-auto text-xs bg-slate-100 px-2 py-0.5 rounded hidden sm:inline"
            >Ctrl+K</kbd
          >
        </button>
      </div>

      <div class="flex flex-wrap justify-center gap-4 mb-12">
        <a href="/" class="ac-btn-primary">トップページへ</a>
        <a href="/blog/" class="ac-btn-outline">ブログを見る</a>
      </div>

      <div class="max-w-2xl mx-auto text-left">
        <h2 class="text-lg font-700 text-slate-700 mb-4">最新の記事</h2>
        <div class="space-y-3">
          {
            recentPosts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="flex items-center gap-4 p-3 rounded-lg hover:bg-slate-50 transition-colors no-underline group"
              >
                {post.data.image && (
                  <img
                    src={optimizeImage(post.data.image)}
                    alt={post.data.title}
                    class="w-16 h-16 rounded-lg object-cover shrink-0"
                    width="64"
                    height="64"
                    decoding="async"
                    loading="lazy"
                  />
                )}
                <div>
                  <p class="text-sm font-600 text-slate-800 group-hover:text-brand-500 transition-colors">
                    {post.data.title}
                  </p>
                  <p class="text-xs text-slate-500 mt-1">
                    {post.data.date.toLocaleDateString('ja-JP')}
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document
    .querySelector<HTMLElement>('[data-search-trigger]')
    ?.addEventListener('click', () => {
      ;(window as any).openSearch?.()
    })
</script>
