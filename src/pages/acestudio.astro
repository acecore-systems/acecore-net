---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import InsightGrid from '../components/InsightGrid.astro'
import PullQuote from '../components/PullQuote.astro'
import Faq from '../components/Faq.astro'

const faqItems = [
  { question: 'AceStudioはいつリリースされますか？', answer: '現在準備中です。リリース時期が決まり次第、Xやブログでお知らせします。' },
  { question: '利用に費用はかかりますか？', answer: '料金体系は現在検討中です。無料で始められるプランも用意する予定です。' },
  { question: 'どんなクリエイティブ活動が対象ですか？', answer: 'デザイン・映像・音楽・プログラミングなど、デジタルクリエイティブ全般を幅広くサポートします。' },
  { question: '事前登録や予約はできますか？', answer: '現時点では事前登録の受付は行っていませんが、Xをフォローいただければ最新情報をお届けできます。' },
]

const studioAreas = [
  {
    title: 'コンテンツ制作',
    description: '映像、配信、デザイン、開発を横断しながら企画を形にします。',
    icon: 'i-lucide-film',
    tone: 'brand',
  },
  {
    title: 'クリエイター支援',
    description: '個人の発信や制作活動を仕組み面から支える設計を進めています。',
    icon: 'i-lucide-badge-help',
    tone: 'amber',
  },
  {
    title: 'コミュニティ運営',
    description: '作品のファンや参加者が継続的につながる場づくりを重視します。',
    icon: 'i-lucide-messages-square',
    tone: 'emerald',
  },
  {
    title: '収益モデル検証',
    description: '検討中の収益モデルを、実際の運用へ落とし込んでいきます。',
    icon: 'i-lucide-chart-no-axes-combined',
    tone: 'slate',
  },
]
---

<BaseLayout
  title="AceStudio"
  description="AceStudio（エーススタジオ）は、Acecoreが開発中のクリエイティブプラットフォームです。詳細は近日公開予定。"
>
  <Hero
    title="AceStudio"
    subtitle="Coming Soon"
    images={[{src: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=1400&h=600&fit=crop&q=80&fm=webp', alt: 'レトロテクノロジー'}]}
  />

  <section class="ac-section">
    <div class="ac-container max-w-3xl text-center">
      <div class="text-left mb-12">
        <InsightGrid
          variant="card"
          eyebrow="Studio Scope"
          title="AceStudioが準備している4つの領域"
          description="コンテンツ × コミュニティ × 収益化の考え方を、公開サイト向けに要約しています。"
          items={studioAreas}
        />
      </div>

      <div class="mb-12">
        <img
          src="https://images.unsplash.com/photo-1574717024653-61fd2cf4d44d?w=800&h=450&fit=crop&q=80&fm=webp"
          alt="映像制作・クリエイティブワーク"
          class="w-full rounded-lg object-cover aspect-video"
          width="800"
          height="450"
          decoding="async"
          loading="lazy"
        />
      </div>

      <div class="mb-12">
        <div class="i-lucide-clapperboard text-6xl text-brand-500 mx-auto mb-6"></div>
        <h2 class="text-2xl ac-heading mb-6">新しいクリエイティブ体験を、まもなく。</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-4">
          AceStudio（エーススタジオ）は、Acecoreが開発中の新サービスです。
        </p>
        <p class="text-lg text-slate-600 leading-relaxed mb-4">
          クリエイターの力を最大限に引き出すプラットフォームとして、
          デザイン・映像・音楽・開発など幅広い領域でのクリエイティブ活動を支援します。
        </p>
        <p class="text-slate-500">
          サービスの詳細は、準備が整い次第このページで公開いたします。
        </p>
      </div>

      <div class="text-left mb-12">
        <PullQuote
          text="作るだけで終わらない。届けて、育てて、回す。"
          attribution="AceStudioの設計思想"
        />
      </div>

      <div class="text-left mb-12">
        <Faq
          title="AceStudioについてのよくある質問"
          items={faqItems}
        />
      </div>

      <div class="bg-slate-50 rounded-xl p-8 mb-12">
        <h3 class="font-700 text-lg text-slate-900 mb-4">最新情報をお届けします</h3>
        <p class="text-slate-600 mb-6">
          リリース情報や最新の開発状況は、AcecoreのXアカウントやブログで随時お知らせしていきます。
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://x.com/acecorenet"
            target="_blank"
            rel="noopener noreferrer"
            class="ac-btn-outline"
          >
            Xでフォローする
          </a>
          <a href="/blog/" class="ac-btn-outline">
            ブログを見る
          </a>
        </div>
      </div>

      <div class="text-center">
        <p class="text-slate-600 mb-4">
          AceStudioに関するお問い合わせやご要望はこちらから
        </p>
        <a href="/contact/" class="ac-btn-primary">お問い合わせ</a>
      </div>
    </div>
  </section>
</BaseLayout>
